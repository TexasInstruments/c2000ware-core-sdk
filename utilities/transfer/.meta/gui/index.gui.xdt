% let transferCommon;
% if (system.getProducts()[0].name.includes("C2000"))
% { transferCommon = system.getScript("/utilities/transfer/transferCommon.js");
% } else
% { transferCommon = system.getScript("/transfer/transferCommon.js");}
% 
% let gui = system.modules[transferCommon.getTransferPath() + "gui.js"].$static;
% let exportCommon = system.getScript(transferCommon.getTransferPath() + "export/export_mods_common.js");
% let expModuleNames = exportCommon.getExportModModuleNames();
% let Collateral = null;
% if (transferCommon.isC28x()) { Collateral  = system.getScript("/driverlib/sysconfig_collateral_links.js"); }
% let exporter = gui.exporter;
% let buttonMode = "disabled";
% let exportMod;
% let expInst;
% if (exporter) {
%   buttonMode = exporter.mode.includes("Bidirectional")?"enabled":"disabled"
%   exportMod = system.modules[transferCommon.getTransferPath() + "exporter.js"];
%   expInst = exportMod.$instances[0];
% }
% if (gui.deviceDiagnosticExportMode == "xds"){
%   buttonMode = "enabled";
% }
%
% let clockingClinic = system.getScript(transferCommon.getTransferPath() + "clinic/f28x/clocking_clinic.js");
% let errataClinic = system.getScript(transferCommon.getTransferPath() + "clinic/f28x/errata_clinic.js");
% let deviceConstants = system.getScript(transferCommon.getTransferPath() + "clinic/f28x/device_constants.js");
% let memoryExports = system.getScript(transferCommon.getTransferPath() + "export/mods/export_mod_memory.js");
%
% var prereqRegisters = clockingClinic.prereqRegisters;
% var clockCalculators = clockingClinic.clockCalculators;
% var clockingChecks = clockingClinic.clockingChecks;
% var errataChecks = errataClinic.errataChecks;
% var errataPrereqRegisters = errataClinic.errataPrereqRegisters;


<link rel="import" href="components/ti-core-stylesheets/ti-core-stylesheets.html">
<script type="module" src="./components/@ti/build/gc-components.esm.js"></script>
<script type="module" src="./index.js"></script>
% if (exporter && expInst.packageMode == "START/END"){
<script type="module" src="./codec.js"></script>
% }
<style>
    /* ==========================================================================
     * CDT Silicon Intelligence Design System v2
     * Texas Instruments C2000 Clinic Diagnostic Tool
     *
     * Aesthetic: Precision Instrument — warm amber data on deep charcoal,
     * copper trace borders, TI-orange accents. Think Tektronix meets the
     * terminal, engineered for extended lab sessions.
     * ========================================================================== */

    /* Distinctive web fonts — JetBrains Mono for data legibility,
       Barlow Condensed for structural headings */
    @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Barlow+Condensed:wght@400;500;600;700&display=swap');

    :root {
        /* ── Backgrounds ────────────────────────────────────────────────────── */
        /* Warm charcoal — not blue-grey, not GitHub-dark; engineer's workbench */
        --cdt-bg-primary:    #111210;
        --cdt-bg-secondary:  #1a1917;
        --cdt-bg-tertiary:   #242320;
        --cdt-bg-elevated:   rgba(36, 35, 32, 0.85);
        --cdt-bg-gradient:   linear-gradient(145deg, #1e1d1a 0%, #111210 100%);
        --cdt-bg-deep:       rgba(11, 11, 10, 0.7);

        /* ── Borders ────────────────────────────────────────────────────────── */
        /* Copper-tinted — evokes PCB trace aesthetic */
        --cdt-border-primary:  #3a3530;
        --cdt-border-secondary: #524c44;
        --cdt-border-accent:   #c87941;   /* copper */
        --cdt-border-subtle:   rgba(58, 53, 48, 0.8);

        /* ── Text ───────────────────────────────────────────────────────────── */
        /* Warm white — not cold #f0f6fc; easier on eyes under lab lighting */
        --cdt-text-primary:   #f2ead8;
        --cdt-text-secondary: #c8bda8;
        --cdt-text-muted:     #8a7f70;
        --cdt-text-dimmed:    #5c5448;

        /* ── Accent Colors ──────────────────────────────────────────────────── */
        /* TI Orange as primary — on-brand, distinctive, not generic blue */
        --cdt-accent-orange:  #e8771a;   /* TI brand orange — primary interactive */
        --cdt-accent-amber:   #f5c842;   /* warm amber — data values, highlights */
        --cdt-accent-cyan:    #2ec4b6;   /* oscilloscope teal — secondary accent */
        --cdt-accent-blue:    #5b8dd9;   /* cool blue — info state, links */
        --cdt-accent-red:     #e05252;   /* clear red — errors */
        --cdt-accent-green:   #4caf7d;   /* phosphor green — pass states */
        --cdt-accent-copper:  #c87941;   /* copper — structural accents */
        --cdt-accent-purple:  #9b72cf;   /* purple — secondary data */

        /* ── Status Colors ──────────────────────────────────────────────────── */
        --cdt-status-pass:    #4caf7d;
        --cdt-status-fail:    #e05252;
        --cdt-status-warning: #e8a020;
        --cdt-status-info:    #5b8dd9;

        /* ── GPIO State Colors ──────────────────────────────────────────────── */
        --cdt-gpio-input-high:  #6fcf97;
        --cdt-gpio-input-low:   #eb8383;
        --cdt-gpio-output-high: #27764f;
        --cdt-gpio-output-low:  #b03030;
        --cdt-gpio-analog:      #8b5cf6;
        --cdt-gpio-periph:      #2563eb;

        /* ── Typography ─────────────────────────────────────────────────────── */
        /* JetBrains Mono: designed for code/data — far superior to Consolas */
        --cdt-font-mono: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
        /* Barlow Condensed: structural, engineering-grade headings */
        --cdt-font-ui:   'Barlow Condensed', 'Segoe UI', system-ui, sans-serif;

        /* ── Font Sizes ─────────────────────────────────────────────────────── */
        --cdt-font-xs:  10px;
        --cdt-font-sm:  12px;
        --cdt-font-md:  13px;
        --cdt-font-lg:  14px;
        --cdt-font-xl:  16px;
        --cdt-font-xxl: 18px;

        /* ── Spacing ────────────────────────────────────────────────────────── */
        --cdt-space-xs: 4px;
        --cdt-space-sm: 8px;
        --cdt-space-md: 12px;
        --cdt-space-lg: 16px;
        --cdt-space-xl: 24px;

        /* ── Border Radius ──────────────────────────────────────────────────── */
        --cdt-radius-sm: 3px;
        --cdt-radius-md: 5px;
        --cdt-radius-lg: 7px;

        /* ── Derived / Alpha ────────────────────────────────────────────────── */
        --cdt-accent-orange-10:  rgba(232, 119, 26,  0.12);
        --cdt-accent-orange-20:  rgba(232, 119, 26,  0.22);
        --cdt-accent-amber-10:   rgba(245, 200, 66,  0.10);
        --cdt-accent-cyan-10:    rgba(46,  196, 182, 0.10);
        --cdt-accent-blue-10:    rgba(91,  141, 217, 0.12);
        --cdt-accent-blue-light: #7aaae6;
        --cdt-led-pass-glow:     0 0 6px rgba(76, 175, 125, 0.7), 0 0 12px rgba(76, 175, 125, 0.35);
        --cdt-led-fail-glow:     0 0 6px rgba(224, 82, 82,   0.7), 0 0 12px rgba(224, 82, 82,   0.35);
        --cdt-led-warn-glow:     0 0 6px rgba(232, 160, 32,  0.7), 0 0 12px rgba(232, 160, 32,  0.35);

        /* ── GUI Composer Theme Bridge ───────────────────────────────────────── */
        --gc-color-surface:          var(--cdt-bg-secondary);
        --gc-color-surface-variant:  var(--cdt-bg-tertiary);
        --gc-color-on-surface:       var(--cdt-text-secondary);
        --gc-color-on-surface-variant: var(--cdt-text-muted);
        --gc-color-border:           var(--cdt-border-primary);
        --gc-color-primary:          var(--cdt-accent-orange);
        --gc-color-primary-variant:  #f09040;
        --gc-color-on-primary:       var(--cdt-text-primary);
        --gc-color-secondary:        var(--cdt-accent-cyan);
        --gc-color-on-secondary:     var(--cdt-bg-primary);
        --gc-color-error:            var(--cdt-status-fail);
        --gc-color-on-error:         var(--cdt-text-primary);
        --gc-color-success:          var(--cdt-status-pass);
        --gc-color-warning:          var(--cdt-status-warning);
    }

    /* LED glow animation — triggers on state change via class swap */
    @keyframes led-pulse-pass {
        0%   { box-shadow: var(--cdt-led-pass-glow); opacity: 1; }
        50%  { box-shadow: 0 0 3px rgba(76, 175, 125, 0.4); opacity: 0.85; }
        100% { box-shadow: var(--cdt-led-pass-glow); opacity: 1; }
    }
    @keyframes led-pulse-fail {
        0%   { box-shadow: var(--cdt-led-fail-glow); }
        50%  { box-shadow: 0 0 3px rgba(224, 82, 82, 0.4); }
        100% { box-shadow: var(--cdt-led-fail-glow); }
    }
    @keyframes value-flash {
        0%   { color: var(--cdt-accent-amber); }
        40%  { color: #fff; }
        100% { color: var(--cdt-accent-amber); }
    }
    @keyframes panel-in {
        from { opacity: 0; transform: translateY(4px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ==========================================================================
     * GUI Composer Widget Theme Overrides
     * ========================================================================== */

    gc-widget-tab-container {
        --gc-tab-background:          var(--cdt-bg-secondary);
        --gc-tab-color:               var(--cdt-text-secondary);
        --gc-tab-selected-background: var(--cdt-bg-primary);
        --gc-tab-selected-color:      var(--cdt-accent-orange);
        --gc-tab-border-color:        var(--cdt-border-primary);
        background: var(--cdt-bg-primary);
    }

    gc-widget-tab-panel {
        background: var(--cdt-bg-primary);
        color: var(--cdt-text-secondary);
    }

    gc-widget-container[elevation="1"] {
        background: var(--cdt-bg-gradient);
        border: 1px solid var(--cdt-border-primary);
        border-radius: var(--cdt-radius-lg);
        color: var(--cdt-text-secondary);
        --gc-heading-color: var(--cdt-text-primary);
        --gc-heading-border-color: var(--cdt-border-primary);
        animation: panel-in 0.18s ease both;
    }

    /* Buttons — warm charcoal base, TI orange on interaction */
    gc-widget-button {
        --gc-button-background:       var(--cdt-bg-tertiary);
        --gc-button-color:            var(--cdt-text-secondary);
        --gc-button-border-color:     var(--cdt-border-primary);
        --gc-button-hover-background: var(--cdt-accent-orange);
        --gc-button-hover-color:      #fff;
        transition: all 0.12s ease;
    }

    gc-widget-button[button-type="primary"] {
        --gc-button-background:       var(--cdt-accent-orange);
        --gc-button-color:            #fff;
        --gc-button-border-color:     var(--cdt-accent-orange);
        --gc-button-hover-background: #f09040;
    }

    gc-widget-button:active { transform: scale(0.97); }

    gc-widget-button[disabled] {
        --gc-button-background:   var(--cdt-bg-tertiary);
        --gc-button-color:        var(--cdt-text-dimmed);
        --gc-button-border-color: var(--cdt-border-primary);
        opacity: 0.5;
        cursor: not-allowed;
    }

    gc-widget-button:focus-visible,
    gc-widget-select:focus-visible,
    gc-widget-led:focus-visible {
        outline: 2px solid var(--cdt-accent-orange);
        outline-offset: 2px;
    }

    gc-widget-label { color: var(--cdt-text-secondary); }

    /* LEDs — off state is a dim warm grey, not cold blue-grey */
    gc-widget-led { --gc-off-color: #3a3530; }

    gc-widget-select {
        --gc-select-background:   var(--cdt-bg-tertiary);
        --gc-select-color:        var(--cdt-text-secondary);
        --gc-select-border-color: var(--cdt-border-primary);
    }

    input[type="number"],
    input[type="text"] {
        background: var(--cdt-bg-tertiary);
        color: var(--cdt-accent-amber);
        border: 1px solid var(--cdt-border-primary);
        border-radius: var(--cdt-radius-sm);
        padding: var(--cdt-space-xs) var(--cdt-space-sm);
        font-family: var(--cdt-font-mono);
        font-size: var(--cdt-font-sm);
    }

    input[type="number"]:focus,
    input[type="text"]:focus {
        outline: none;
        border-color: var(--cdt-accent-orange);
        box-shadow: 0 0 0 2px var(--cdt-accent-orange-10);
    }

    gc-widget-menubar {
        --gc-menubar-background:    var(--cdt-bg-secondary);
        --gc-menubar-color:         var(--cdt-text-secondary);
        --gc-menubar-border-color:  var(--cdt-border-primary);
        background: var(--cdt-bg-secondary);
        border-bottom: 1px solid var(--cdt-border-primary);
    }

    /* Scrollbars — copper-tinted thumb */
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: var(--cdt-bg-primary); }
    ::-webkit-scrollbar-thumb {
        background: var(--cdt-border-secondary);
        border-radius: 4px;
        border: 2px solid var(--cdt-bg-primary);
    }
    ::-webkit-scrollbar-thumb:hover { background: var(--cdt-accent-copper); }

    /* Selection — warm amber */
    ::selection {
        background: rgba(232, 119, 26, 0.35);
        color: var(--cdt-text-primary);
    }

    /* Base Styles */
    html, body, #editorRoot, #viewport, gc-widget-tab-bar, gc-widget-tab-panel,
    gc-widget-container, gc-layout-horizontal, gc-layout-vertical {
        background: var(--cdt-bg-primary) !important;
    }
    body {
        margin: 0;
        color: var(--cdt-text-secondary);
        font-family: var(--cdt-font-ui);
        font-size: var(--cdt-font-md);
        letter-spacing: 0.01em;
    }

    #editorRoot {
        z-index: 0;
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        overflow: hidden;
        opacity: 1;
        margin: 0;
        background: var(--cdt-bg-primary);
    }

    #viewport {
        width: 100%;
        margin: 0;
        padding: 0;
        --gc-overflow: auto;
        background: var(--cdt-bg-primary);
    }

    .container {
        width: 100%;
        height: 100%;
        margin: 0;
    }

    .tile {
        margin: var(--cdt-space-md);
    }

    .tile.instruments {
        width: 300px;
        min-width: 400px;
        height: 320px;
    }

    .tile.info > * {
        margin: 0;
    }

    #page_modules {
        --gc-overflow: auto;
        background: var(--cdt-bg-primary);
    }

    #page_data > gc-widget-container {
        margin: 0 auto;
    }

    .almost_full_width {
        width: 98%;
    }

    /* ==========================================================================
     * Panel Tile Base Styles - Industrial Blueprint
     * ========================================================================== */

    /* Base panel styling - shared by all module tiles */
    .page_module_tile,
    .page_module_tile_long,
    .page_module_tile_medium,
    .page_module_tile_system {
        --gc-padding: var(--cdt-space-md);
        width: fit-content;
        height: auto;
        background: var(--cdt-bg-gradient);
        border: 1px solid var(--cdt-border-primary);
        border-radius: var(--cdt-radius-lg);
        color: var(--cdt-text-secondary);
    }

    /* Size variants - only define unique properties */
    .page_module_tile {
        min-width: 260px;
        min-height: 180px;
        /* Fixed height for peripheral module tiles to ensure consistent grid alignment */
        height: 180px;
        overflow-y: auto;
    }
    .page_module_tile_long { min-width: 300px; min-height: 400px; }
    .page_module_tile_medium { min-width: 260px; min-height: 300px; }

    /* Errata panel - flexible width for comfortable reading when on its own row */
    #page_module_errata_tile {
        flex: 1 1 auto;
        min-width: 350px;
        max-width: 700px;
    }

    /* ==========================================================================
     * Panel Title Styling — Barlow Condensed, copper underline
     * ========================================================================== */
    .panel_title {
        display: inline-block;
        font-family: var(--cdt-font-ui);
        font-size: 17px;
        font-weight: 600;
        color: var(--cdt-text-primary);
        padding-bottom: var(--cdt-space-xs);
        margin-bottom: var(--cdt-space-sm);
        /* Copper underline — PCB trace aesthetic */
        border-bottom: 2px solid var(--cdt-accent-copper);
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .panel_title_container {
        width: 100%;
        padding: var(--cdt-space-sm) var(--cdt-space-md) 0 var(--cdt-space-md);
        box-sizing: border-box;
    }

    /* Hide gc-widget-container native headings for panels with custom titles */
    #page_module_system_tile,
    #page_module_pinmux_tile,
    #page_module_memory_tile,
    #page_module_interrupt_tile,
    #page_module_clocking_tile,
    #page_module_errata_tile,
    #cputimer_panel,
    .page_module_tile,
    .page_module_specific_tile,
    .gpio_panel,
    .cputimer_panel {
        --gc-heading-display: none;
        --gc-heading-visibility: hidden;
    }

    /* ==========================================================================
     * System Panel - Industrial Blueprint
     * ========================================================================== */

    .page_module_tile_system { margin: 5px; }

    .system_entry {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 95%;
        padding: var(--cdt-space-xs) var(--cdt-space-md);
        margin: 2px auto;
        box-sizing: border-box;
        background: var(--cdt-bg-elevated);
        border-radius: var(--cdt-radius-sm);
        transition: background 0.12s ease, border-color 0.12s ease;
        border-left: 2px solid transparent;
    }

    .system_entry:hover {
        background: var(--cdt-accent-orange-10);
        border-left-color: var(--cdt-accent-copper);
    }

    .system_entry_label {
        font-size: var(--cdt-font-sm);
        flex-shrink: 0;
        min-width: 140px;
        /* Muted warm tone for labels — recedes behind data values */
        color: var(--cdt-text-muted);
        font-family: var(--cdt-font-ui);
        font-weight: 500;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .system_entry_value {
        font-size: var(--cdt-font-md);
        font-weight: 500;
        text-align: right;
        margin-left: var(--cdt-space-md);
        flex-grow: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        /* Amber — the classic "oscilloscope trace" color; data stands out at a glance */
        color: var(--cdt-accent-amber);
        font-family: var(--cdt-font-mono);
    }

    /* ==========================================================================
     * Target Status Card (Enhanced Debugger Status - Option B)
     * ========================================================================== */

    .target_status_card {
        /* Warm orange-tinted gradient — feels like a live instrument readout */
        background: linear-gradient(145deg,
            rgba(36, 35, 32, 0.9) 0%,
            rgba(232, 119, 26, 0.06) 100%);
        border: 1px solid var(--cdt-accent-copper);
        border-radius: var(--cdt-radius-md);
        margin: var(--cdt-space-sm) auto;
        padding: var(--cdt-space-xs) 0;
        width: 95%;
        /* Subtle copper glow on the card border */
        box-shadow: 0 0 0 1px rgba(200, 121, 65, 0.08), inset 0 1px 0 rgba(245, 200, 66, 0.04);
    }

    .target_status_header {
        font-family: var(--cdt-font-ui);
        font-size: var(--cdt-font-sm);
        font-weight: 700;
        color: var(--cdt-accent-orange);
        text-transform: uppercase;
        letter-spacing: 2px;
        padding: var(--cdt-space-xs) var(--cdt-space-md);
        border-bottom: 1px solid var(--cdt-border-primary);
        margin-bottom: var(--cdt-space-xs);
    }

    .target_status_entry {
        background: transparent;
        margin: 1px auto;
    }

    .target_status_entry:hover {
        background: var(--cdt-accent-orange-10);
    }

    .target_state_indicator {
        display: flex;
        align-items: center;
        gap: var(--cdt-space-sm);
    }

    .target_state_led { flex-shrink: 0; }

    .target_state_text { min-width: 80px; }

    /* RUNNING — phosphor green with glow; unmistakably active */
    .target_state_running {
        color: var(--cdt-status-pass);
        font-weight: 700;
        font-family: var(--cdt-font-ui);
        letter-spacing: 1px;
        text-shadow: 0 0 8px rgba(76, 175, 125, 0.5);
    }

    /* HALTED — warm red, not harsh; clearly stopped */
    .target_state_halted {
        color: var(--cdt-status-fail);
        font-weight: 700;
        font-family: var(--cdt-font-ui);
        letter-spacing: 1px;
    }

    /* PC value — amber mono, feels like a register readout */
    .target_pc_value {
        font-family: var(--cdt-font-mono);
        color: var(--cdt-accent-amber);
        letter-spacing: 0.5px;
        font-size: var(--cdt-font-sm);
    }

    /* ==========================================================================
     * DIE ID / UID Expandable Section
     * ========================================================================== */
    .die_uid_section {
        width: 95%;
        margin: var(--cdt-space-sm) auto var(--cdt-space-xs) auto;
        border: 1px solid var(--cdt-border-primary);
        border-radius: var(--cdt-radius-md);
        background: var(--cdt-bg-elevated);
        overflow: hidden;
    }

    .die_uid_summary {
        display: flex;
        align-items: center;
        gap: var(--cdt-space-sm);
        padding: var(--cdt-space-xs) var(--cdt-space-md);
        font-family: var(--cdt-font-ui);
        font-size: var(--cdt-font-sm);
        font-weight: 700;
        color: var(--cdt-accent-copper);
        text-transform: uppercase;
        letter-spacing: 1.5px;
        cursor: pointer;
        list-style: none;
        user-select: none;
        border-bottom: 1px solid transparent;
        transition: background 0.12s ease, border-color 0.12s ease;
    }
    .die_uid_summary::-webkit-details-marker { display: none; }

    .die_uid_section[open] > .die_uid_summary {
        border-bottom-color: var(--cdt-border-primary);
        background: var(--cdt-accent-orange-10);
    }

    .die_uid_summary:hover {
        background: var(--cdt-accent-orange-10);
    }

    /* Animated chevron */
    .die_uid_chevron {
        margin-left: auto;
        font-size: 10px;
        color: var(--cdt-text-muted);
        transition: transform 0.18s ease;
        line-height: 1;
    }
    .die_uid_section[open] .die_uid_chevron {
        transform: rotate(90deg);
    }

    .die_uid_content {
        padding: var(--cdt-space-xs) var(--cdt-space-sm) var(--cdt-space-sm) var(--cdt-space-sm);
    }

    .die_uid_row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 3px var(--cdt-space-sm);
        margin: 1px 0;
        border-radius: var(--cdt-radius-sm);
        transition: background 0.1s ease;
    }
    .die_uid_row:hover { background: var(--cdt-accent-orange-10); }

    .die_uid_label {
        font-family: var(--cdt-font-ui);
        font-size: var(--cdt-font-xs);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--cdt-text-muted);
        min-width: 100px;
        flex-shrink: 0;
    }
    .die_uid_addr {
        font-family: var(--cdt-font-mono);
        font-size: 9px;
        color: var(--cdt-text-dimmed);
        font-weight: 400;
        text-transform: none;
        letter-spacing: 0;
    }

    /* Hex value — amber monospace, the signature "register readout" look */
    .die_uid_hex {
        font-family: var(--cdt-font-mono);
        font-size: var(--cdt-font-sm);
        color: var(--cdt-accent-amber);
        letter-spacing: 0.5px;
        text-align: right;
    }

    /* 64-bit combined UID — slightly larger, full width */
    .die_uid_row_combined {
        margin-top: var(--cdt-space-xs);
        border-top: 1px solid var(--cdt-border-primary);
        padding-top: var(--cdt-space-xs);
    }
    .die_uid_hex_full {
        font-size: var(--cdt-font-sm);
        color: var(--cdt-accent-orange);
        font-weight: 500;
        word-break: break-all;
    }

    /* Copy button */
    .die_uid_copy_btn {
        background: none;
        border: 1px solid var(--cdt-border-primary);
        border-radius: var(--cdt-radius-sm);
        color: var(--cdt-text-muted);
        font-size: 10px;
        padding: 1px 5px;
        cursor: pointer;
        font-family: var(--cdt-font-ui);
        transition: all 0.12s ease;
        margin-left: var(--cdt-space-xs);
        flex-shrink: 0;
    }
    .die_uid_copy_btn:hover {
        border-color: var(--cdt-accent-copper);
        color: var(--cdt-accent-copper);
    }
    .die_uid_copy_btn.copied {
        border-color: var(--cdt-status-pass);
        color: var(--cdt-status-pass);
    }

    /* ==========================================================================
     * Update Button Styling
     * ========================================================================== */

    .page_module_specific_register_button {
        position: absolute;
        right: var(--cdt-space-sm);
        top: var(--cdt-space-sm);
    }

    .page_module_specific_button_container {
        position: absolute;
        right: var(--cdt-space-sm);
        top: var(--cdt-space-sm);
        display: flex;
        gap: var(--cdt-space-sm);
        z-index: 10;
    }

    .page_module_specific_tile {
        --gc-padding: var(--cdt-space-md);
        width: calc(100vw - 100px);
        max-width: 800px;
        min-width: 300px;
        height: calc(100vh - 250px);
        min-height: 300px;
        max-height: 600px;
        --gc-overflow: auto;
        background: var(--cdt-bg-gradient);
        border: 1px solid var(--cdt-border-primary);
        border-radius: var(--cdt-radius-lg);
        color: var(--cdt-text-secondary);
    }

    .page_module_specific_tile .page_module_specific_export:first-of-type {
        margin-top: 0;
    }

    .page_module_specific_export {
        width: 90%;
        --gc-padding: 0px;
    }

    .page_module_specific_con {
        width: 100%;
        max-width: 100%;
        --gc-padding: 0px 5px;
        box-sizing: border-box;
    }

    .page_module_lbl {
        width: auto;
        max-width: none;
        font-size: var(--cdt-font-sm);
        white-space: nowrap;
        flex-shrink: 0;
        color: var(--cdt-text-muted);
    }

    /* ==========================================================================
     * Errata Panel - Industrial Blueprint
     * ========================================================================== */

    .errata_display_button {
        width: 70%;
        z-index: 1;
        color: var(--cdt-accent-blue);
        text-decoration: none;
        position: relative;
        left: 5px;
        font-family: var(--cdt-font-mono);
        font-size: var(--cdt-font-sm);
        transition: color 0.15s ease;
    }

    .errata_display_button:hover {
        color: var(--cdt-accent-cyan);
        text-decoration: underline;
    }

    /* Section headers: Barlow Condensed + copper accent bar */
    .errata_section_header {
        width: 95%;
        padding: var(--cdt-space-sm) var(--cdt-space-sm) var(--cdt-space-xs) var(--cdt-space-sm);
        margin-top: var(--cdt-space-md);
        margin-bottom: var(--cdt-space-xs);
        border-bottom: 1px solid var(--cdt-border-primary);
        font-family: var(--cdt-font-ui);
        font-size: 11px;
        font-weight: 700;
        color: var(--cdt-accent-copper);
        text-transform: uppercase;
        letter-spacing: 2px;
        display: flex;
        align-items: center;
        gap: var(--cdt-space-sm);
    }

    .errata_section_header::before {
        content: '';
        display: inline-block;
        width: 3px;
        height: 12px;
        /* Copper bar — PCB trace accent */
        background: var(--cdt-accent-copper);
        border-radius: 2px;
        box-shadow: 0 0 4px rgba(200, 121, 65, 0.5);
    }

    .errata_section_header:first-of-type { margin-top: 0; }

    /* Clinic Panel Section Headers */
    .clinic_section_header {
        width: 95%;
        padding: var(--cdt-space-sm) var(--cdt-space-sm) var(--cdt-space-xs) var(--cdt-space-sm);
        margin-top: var(--cdt-space-md);
        margin-bottom: var(--cdt-space-xs);
        border-bottom: 1px solid var(--cdt-border-primary);
        font-family: var(--cdt-font-ui);
        font-size: 11px;
        font-weight: 700;
        color: var(--cdt-accent-orange);
        text-transform: uppercase;
        letter-spacing: 2px;
        display: flex;
        align-items: center;
        gap: var(--cdt-space-sm);
    }

    .clinic_section_header::before {
        content: '';
        display: inline-block;
        width: 3px;
        height: 12px;
        background: var(--cdt-accent-orange);
        border-radius: 2px;
        box-shadow: 0 0 4px rgba(232, 119, 26, 0.5);
    }

    .clinic_section_header:first-of-type { margin-top: 0; }

    /* ==========================================================================
     * Clinic LED Status Colors — glow effects for instrument authenticity
     * ========================================================================== */

    .clinic_led {
        --gc-off-color: #3a3530;
    }

    /* PASS — phosphor green glow */
    .clinic_led_valid {
        --gc-on-color: var(--cdt-status-pass);
        --gc-off-color: #3a3530;
        filter: drop-shadow(0 0 3px rgba(76, 175, 125, 0.6));
    }

    /* FAIL — red with glow, unmissable */
    .clinic_led_invalid {
        --gc-on-color: var(--cdt-status-fail);
        --gc-off-color: #3a3530;
        filter: drop-shadow(0 0 3px rgba(224, 82, 82, 0.6));
    }

    /* WARNING — amber glow */
    .clinic_led_warning {
        --gc-on-color: var(--cdt-status-warning);
        --gc-off-color: #3a3530;
        filter: drop-shadow(0 0 3px rgba(232, 160, 32, 0.5));
    }

    .clinic_led_summary {
        --gc-on-color: var(--cdt-accent-amber);
        --gc-off-color: #3a3530;
    }

    .clinic_led_small {
        --gc-led-size: 8px;
        --gc-off-color: #3a3530;
    }

    .clinic_led_mini {
        --gc-led-size: 6px;
        --gc-off-color: var(--cdt-border-secondary);
    }

    /* ==========================================================================
     * PIE Interrupt Panel Styles
     * ========================================================================== */

    /* PIE Overview Row */
    .pie_overview_row {
        display: flex;
        align-items: center;
        gap: var(--cdt-space-lg);
        padding: var(--cdt-space-sm) var(--cdt-space-md);
        background: var(--cdt-bg-elevated);
        border-radius: var(--cdt-radius-sm);
        margin-bottom: var(--cdt-space-md);
        flex-wrap: wrap;
        width: 100%;
    }

    .pie_overview_item {
        display: flex;
        align-items: center;
        gap: var(--cdt-space-sm);
    }

    .pie_overview_label {
        font-size: var(--cdt-font-sm);
        color: var(--cdt-text-muted);
    }

    .pie_summary_counts {
        margin-left: auto;
        display: flex;
        gap: var(--cdt-space-md);
        align-items: center;
    }

    .pie_count_label {
        font-size: var(--cdt-font-xs);
        color: var(--cdt-text-dimmed);
    }

    .pie_count_value {
        font-size: var(--cdt-font-md);
        font-weight: 600;
        color: var(--cdt-status-pass);
        font-family: var(--cdt-font-mono);
    }

    .pie_count_value.pending {
        color: var(--cdt-status-warning);
    }

    /* PIE Group Grid - 4 columns */
    .pie_group_grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--cdt-space-sm);
        width: 100%;
        padding: 0 var(--cdt-space-xs);
    }

    @media (max-width: 800px) {
        .pie_group_grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* PIE Group Card */
    .pie_group_card {
        background: var(--cdt-bg-elevated);
        border: 1px solid var(--cdt-border-primary);
        border-radius: var(--cdt-radius-md);
        padding: var(--cdt-space-sm);
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .pie_group_card:hover {
        border-color: var(--cdt-accent-blue);
        background: rgba(21, 101, 192, 0.08);
    }

    .pie_group_card.has_pending {
        border-color: var(--cdt-status-warning);
        background: rgba(255, 170, 0, 0.08);
    }

    .pie_group_header {
        display: flex;
        align-items: center;
        gap: var(--cdt-space-sm);
        margin-bottom: var(--cdt-space-xs);
    }

    .pie_group_num {
        font-size: 10px;
        font-weight: 700;
        color: var(--cdt-accent-blue);
        background: rgba(21, 101, 192, 0.15);
        padding: 2px 5px;
        border-radius: 3px;
        font-family: var(--cdt-font-mono);
    }

    .pie_group_name {
        font-size: 10px;
        color: var(--cdt-text-secondary);
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pie_group_stats {
        display: flex;
        gap: var(--cdt-space-md);
        font-size: 10px;
        color: var(--cdt-text-muted);
        font-family: var(--cdt-font-mono);
    }

    .pie_stat {
        display: flex;
        gap: 2px;
    }

    .pie_stat.pending {
        color: var(--cdt-status-warning);
    }

    /* Active Interrupts Section */
    .pie_active_container {
        background: var(--cdt-bg-elevated);
        border: 1px solid var(--cdt-border-primary);
        border-radius: var(--cdt-radius-md);
        padding: var(--cdt-space-md);
        min-height: 36px;
        width: 100%;
    }

    .pie_active_empty {
        font-size: var(--cdt-font-sm);
        color: var(--cdt-text-dimmed);
        text-align: center;
        font-style: italic;
    }

    .pie_active_list {
        display: flex;
        flex-wrap: wrap;
        gap: var(--cdt-space-sm);
    }

    .pie_active_badge {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        padding: 4px 10px;
        border-radius: var(--cdt-radius-sm);
        font-family: var(--cdt-font-mono);
        background: rgba(255, 170, 0, 0.15);
        color: var(--cdt-status-warning);
        border: 1px solid var(--cdt-status-warning);
    }

    .pie_active_badge .pie_int_loc {
        font-size: 9px;
        color: var(--cdt-text-muted);
    }

    /* ==========================================================================
     * Memory Bar Styles - Industrial Blueprint
     * ========================================================================== */

    .memory_bar_container {
        width: 100%;
        padding: var(--cdt-space-sm) 0;
    }

    .memory_bar_label {
        display: flex;
        justify-content: space-between;
        font-size: var(--cdt-font-sm);
        margin-bottom: var(--cdt-space-xs);
        color: var(--cdt-text-muted);
        font-family: var(--cdt-font-mono);
    }

    .memory_bar_wrapper {
        width: 100%;
        height: 12px;
        background-color: var(--cdt-bg-tertiary);
        border-radius: var(--cdt-radius-md);
        overflow: hidden;
        border: 1px solid var(--cdt-border-primary);
    }

    .memory_bar_fill {
        height: 100%;
        background: linear-gradient(90deg, var(--cdt-status-pass) 0%, #56d364 100%);
        border-radius: var(--cdt-radius-sm);
        transition: width 0.3s ease;
    }

    .memory_bar_fill.flash {
        background: linear-gradient(90deg, var(--cdt-accent-blue) 0%, #79c0ff 100%);
    }

    .memory_bar_fill.ram {
        background: linear-gradient(90deg, var(--cdt-accent-orange) 0%, #ffa657 100%);
    }

    /* ==========================================================================
     * Memory Map File Upload Styles
     * ========================================================================== */

    .memory_upload_row {
        display: flex;
        align-items: center;
        gap: var(--cdt-space-sm);
        margin-bottom: var(--cdt-space-sm);
        padding: var(--cdt-space-xs) var(--cdt-space-sm);
        background: var(--cdt-bg-tertiary);
        border-radius: var(--cdt-radius-sm);
        width: 100%;
    }

    .memory_upload_btn {
        font-size: var(--cdt-font-xs);
        padding: 4px 8px;
        background: var(--cdt-accent-blue);
        color: white;
        border: none;
        border-radius: var(--cdt-radius-sm);
        cursor: pointer;
        transition: background 0.2s;
        white-space: nowrap;
    }

    .memory_upload_btn:hover {
        background: #79c0ff;
    }

    .memory_upload_btn.clear {
        background: #8b949e;
    }

    .memory_upload_btn.clear:hover {
        background: #a0a8b0;
    }

    .memory_file_input {
        display: none;
    }

    .memory_file_label {
        font-size: var(--cdt-font-xs);
        color: var(--cdt-text-muted);
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-family: var(--cdt-font-mono);
    }

    /* Stacked memory bar for showing sections */
    .memory_bar_stacked {
        display: flex;
        height: 100%;
        width: 100%;
    }

    .memory_bar_segment {
        height: 100%;
        transition: width 0.3s ease;
    }

    .memory_bar_segment.text { background: #3fb950; }
    .memory_bar_segment.const { background: #a371f7; }
    .memory_bar_segment.data { background: #58a6ff; }
    .memory_bar_segment.bss { background: #f0883e; }
    .memory_bar_segment.stack { background: #f85149; }
    .memory_bar_segment.other { background: #8b949e; }

    /* Memory breakdown table */
    .memory_breakdown {
        width: 100%;
        font-size: var(--cdt-font-xs);
        margin-top: var(--cdt-space-xs);
        padding: 0 var(--cdt-space-xs);
    }

    .memory_breakdown_row {
        display: flex;
        justify-content: space-between;
        padding: 2px 0;
        border-bottom: 1px solid var(--cdt-border-secondary);
    }

    .memory_breakdown_row:last-child {
        border-bottom: none;
    }

    .memory_breakdown_section {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .memory_breakdown_dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .memory_breakdown_dot.text { background: #3fb950; }
    .memory_breakdown_dot.const { background: #a371f7; }
    .memory_breakdown_dot.data { background: #58a6ff; }
    .memory_breakdown_dot.bss { background: #f0883e; }
    .memory_breakdown_dot.stack { background: #f85149; }
    .memory_breakdown_dot.other { background: #8b949e; }

    /* Expanded memory bar - shows used portion at 100% width */
    .memory_expanded_section {
        margin-top: var(--cdt-space-xs);
        display: none; /* Hidden until .map loaded */
    }

    .memory_expanded_label {
        font-size: var(--cdt-font-xs);
        color: var(--cdt-text-muted);
        margin-bottom: 4px;
        display: flex;
        justify-content: space-between;
    }

    .memory_expanded_wrapper {
        height: 16px;
        background: var(--cdt-bg-tertiary);
        border-radius: 4px;
        overflow: hidden;
        border: 1px solid var(--cdt-border-secondary);
    }

    .memory_expanded_bar {
        display: flex;
        height: 100%;
        width: 100%;
    }

    .memory_breakdown_value {
        font-family: var(--cdt-font-mono);
        color: var(--cdt-text-muted);
    }

    /* ==========================================================================
     * Export All Button Row
     * ========================================================================== */

    .export_all_row {
        width: 100%;
        padding: var(--cdt-space-md);
        margin-top: var(--cdt-space-md);
        border-top: 1px solid var(--cdt-border-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--cdt-space-md);
    }

    .export_all_row gc-widget-button {
        min-width: 120px;
    }

    .export_all_row gc-widget-select {
        min-width: 100px;
    }

    /* ==========================================================================
     * Pinmux Panel - Industrial Blueprint
     * ========================================================================== */

    .page_module_tile_pinmux {
        --gc-padding: var(--cdt-space-sm);
        --gc-overflow: visible;  /* Ensure pins and labels not clipped */
        margin: 5px auto;
        width: fit-content;
        min-width: 720px;
        min-height: 600px;  /* Increased for larger packages with labels */
        position: relative;
        background: var(--cdt-bg-gradient);
        border: 1px solid var(--cdt-border-primary);
        border-radius: var(--cdt-radius-lg);
        color: var(--cdt-text-secondary);
        overflow: visible;  /* Fallback for non-GC containers */
        padding-bottom: 40px;  /* Extra space for bottom pin labels */
    }
    /* Fix for GUI Composer ElementWrapper blocking pointer events on pinmux panel */
    /* The gc-widget-container creates internal wrapper divs that can intercept mouse events */
    /* Target both direct children and shadow DOM wrappers */
    .page_module_tile_pinmux > div:not(.pinmux_package_container),
    #page_module_pinmux_tile > div:not(.pinmux_package_container),
    .page_module_tile_pinmux div[id*="ElementWrapper"],
    #page_module_pinmux_tile div[id*="ElementWrapper"],
    .page_module_tile_pinmux > gc-widget-container,
    #page_module_pinmux_tile > gc-widget-container {
        pointer-events: none !important;
    }
    /* Universal fix: Any ElementWrapper div should not block pointer events */
    div[id*="ElementWrapper"] {
        pointer-events: none !important;
    }
    /* Re-enable pointer events on interactive elements within ElementWrappers */
    div[id*="ElementWrapper"] gc-widget-button,
    div[id*="ElementWrapper"] gc-widget-select,
    div[id*="ElementWrapper"] gc-widget-tab-panel,
    div[id*="ElementWrapper"] button,
    div[id*="ElementWrapper"] select,
    div[id*="ElementWrapper"] input,
    gc-widget-button,
    gc-widget-select,
    gc-widget-tab-container,
    gc-widget-tab-panel {
        pointer-events: auto !important;
    }
    /* Re-enable pointer events on the actual pinmux content */
    .pinmux_package_container,
    .pinmux_package_container * {
        pointer-events: auto !important;
    }
    /* Explicitly disable pointer events on labels and other non-interactive elements */
    .pinmux_pin_label,
    .pinmux_pin_bar,
    .pinmux_pin_arrow,
    .pinmux_bga_label,
    .pinmux_bga_row_labels,
    .pinmux_bga_col_labels {
        pointer-events: none !important;
    }
    /* Ensure pins themselves receive pointer events for tooltips */
    .pinmux_pin,
    .pinmux_bga_pin {
        pointer-events: auto !important;
        cursor: pointer;
    }
    .pinmux_package_container {
        position: relative;
        padding: 40px 50px 50px 50px;  /* Increased padding for pin labels */
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: 60px;  /* Increased gap to account for pins extending beyond package */
        overflow: visible;  /* Ensure child elements are not clipped */
    }
    .pinmux_package {
        position: relative;
        border: 2px solid currentColor;
        border-radius: 4px;
        opacity: 0.9;
        padding: 25px;
        margin-right: 40px;  /* Extra margin for right-side pins */
        overflow: visible;  /* Ensure pins and tooltips are not clipped */
    }
    .pinmux_package_inner {
        /* Size dynamically fills the package - padding handled by parent */
        width: 100%;
        height: 100%;
        box-sizing: border-box;
        border-radius: 2px;
        border: 1px solid currentColor;
        opacity: 0.5;
        display: flex;
        justify-content: center;
        align-items: center;
    }
    .pinmux_package_label {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        opacity: 1;
    }
    .pinmux_device_name {
        font-weight: bold;
        font-size: var(--cdt-font-xl);
    }
    .pinmux_package_name {
        font-size: var(--cdt-font-sm);
        opacity: 0.8;
    }
    /* Pin marker for pin 1 */
    .pinmux_pin1_marker {
        position: absolute;
        width: 14px;
        height: 14px;
        border: 2px solid currentColor;
        border-radius: 50%;
        background: transparent;
        bottom: 8px;
        left: 8px;
        opacity: 0.6;
    }
    /* Pin rows on each side */
    .pinmux_pins_top, .pinmux_pins_bottom {
        position: absolute;
        display: flex;
        justify-content: space-between;
        left: 25px;
        right: 25px;
    }
    .pinmux_pins_top {
        top: -16px;
        flex-direction: row-reverse;
    }
    .pinmux_pins_bottom {
        bottom: -16px;
        flex-direction: row;
    }
    .pinmux_pins_left, .pinmux_pins_right {
        position: absolute;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        top: 25px;
        bottom: 25px;
    }
    .pinmux_pins_left {
        left: -16px;
    }
    .pinmux_pins_right {
        right: -16px;
        flex-direction: column-reverse;
    }
    /* Individual pin styling */
    .pinmux_pin {
        width: 12px;
        height: 12px;
        flex-shrink: 0;
        cursor: pointer;
        position: relative;
    }
    .pinmux_pin_bar {
        width: 100%;
        height: 100%;
        pointer-events: none;  /* Allow parent tooltip to show */
    }
    /* Pin number labels - positioned outside the pin bars */
    .pinmux_pin_label {
        position: absolute;
        font-size: var(--cdt-font-xs);
        opacity: 0.7;
        white-space: nowrap;
        pointer-events: none;  /* Allow parent tooltip to show */
    }
    .pinmux_pins_top .pinmux_pin_label {
        bottom: 16px;
        left: 50%;
        transform: translateX(-50%) rotate(-60deg);
        transform-origin: center center;
    }
    .pinmux_pins_bottom .pinmux_pin_label {
        top: 16px;
        left: 50%;
        transform: translateX(-50%) rotate(-60deg);
        transform-origin: center center;
    }
    .pinmux_pins_left .pinmux_pin_label {
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
    }
    .pinmux_pins_right .pinmux_pin_label {
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
    }
    /* Pin type colors - fixed colors that work in both themes */
    .pinmux_pin.available { opacity: 0.4 !important; }  /* Dim unconfigured GPIO pins */
    .pinmux_pin.available .pinmux_pin_bar { background: #909090; }      /* Grey - unassigned GPIO */
    .pinmux_pin.assigned .pinmux_pin_bar { background: #4caf50; }       /* Green - peripheral assigned (legacy) */
    .pinmux_pin.warning .pinmux_pin_bar { background: #ff9800; }        /* Orange - warning */
    .pinmux_pin.power .pinmux_pin_bar { background: #ff1744; }          /* Bright red - power */
    .pinmux_pin.ground .pinmux_pin_bar { background: #212121; }         /* Dark black - ground */
    .pinmux_pin.fixed .pinmux_pin_bar { background: #707070; }          /* Medium grey - fixed function */
    .pinmux_pin.jtag .pinmux_pin_bar { background: #ff9800; }           /* Orange - JTAG debug signals */
    .pinmux_pin.reset .pinmux_pin_bar { background: #ffc107; }          /* Yellow/Gold - Reset pin (XRSn) */
    .pinmux_pin.special .pinmux_pin_bar { background: #00bcd4; }        /* Cyan - Special function (VREGENZ) */
    .pinmux_pin.analog { opacity: 0.4 !important; }  /* Dim unconfigured analog-only pins */
    .pinmux_pin.analog .pinmux_pin_bar { background: var(--cdt-gpio-analog); }
    .pinmux_pin.analog_used { opacity: 1 !important; }
    /* GPIO Input/Output state colors - use CSS variables for consistency */
    .pinmux_pin.input_high .pinmux_pin_bar { background: var(--cdt-gpio-input-high); }
    .pinmux_pin.input_low .pinmux_pin_bar { background: var(--cdt-gpio-input-low); }
    .pinmux_pin.output_high .pinmux_pin_bar { background: var(--cdt-gpio-output-high); }
    .pinmux_pin.output_low .pinmux_pin_bar { background: var(--cdt-gpio-output-low); }
    .pinmux_pin.analog_used .pinmux_pin_bar { background: var(--cdt-gpio-analog); box-shadow: 0 0 4px 2px var(--cdt-gpio-analog); }
    /* Peripheral assigned with HIGH/LOW state */
    .pinmux_pin.periph_high .pinmux_pin_bar { background: #42a5f5; }
    .pinmux_pin.periph_low .pinmux_pin_bar { background: var(--cdt-gpio-periph); }
    /* Bidirectional pins */
    .pinmux_pin.bidir .pinmux_pin_bar { background: #7e57c2; }          /* Purple shade - bidirectional */
    .pinmux_pin.bidir .pinmux_pin_arrow { display: block; }

    /* Pin direction arrows - show data flow direction */
    .pinmux_pin_arrow {
        position: absolute;
        font-size: 8px;
        font-weight: bold;
        color: white;
        text-shadow: 0 0 2px rgba(0,0,0,0.8);
        pointer-events: none;
        z-index: 1;
        display: none;  /* Hidden by default, shown when direction is known */
    }
    /* Position arrows in center of pin box */
    .pinmux_pins_top .pinmux_pin_arrow,
    .pinmux_pins_bottom .pinmux_pin_arrow {
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
    }
    .pinmux_pins_left .pinmux_pin_arrow,
    .pinmux_pins_right .pinmux_pin_arrow {
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
    }
    /* Show arrows for GPIO input/output pins */
    .pinmux_pin.input_high .pinmux_pin_arrow,
    .pinmux_pin.input_low .pinmux_pin_arrow,
    .pinmux_pin.output_high .pinmux_pin_arrow,
    .pinmux_pin.output_low .pinmux_pin_arrow,
    .pinmux_pin.periph_high .pinmux_pin_arrow,
    .pinmux_pin.periph_low .pinmux_pin_arrow {
        display: block;
    }

    /* BGA Package Grid Layout */
    .pinmux_bga_wrapper {
        display: contents;  /* QFP: wrapper is invisible, children flow into parent */
    }
    .pinmux_package_container.bga .pinmux_bga_wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
    }
    .pinmux_package_container.bga .pinmux_package {
        padding: 10px;
        margin-right: 0;
        z-index: 5;  /* Ensure package is above other elements */
    }
    .pinmux_package_container.bga .pinmux_package_inner {
        display: none;  /* Hide inner label area for BGA - label is above */
    }
    .pinmux_package_container.bga .pinmux_pin1_marker {
        display: none;  /* No pin 1 marker for BGA */
    }
    /* BGA title displayed above package */
    .pinmux_bga_title {
        display: none;
        flex-direction: column;
        align-items: center;
        margin-bottom: 10px;
        text-align: center;
        pointer-events: none;  /* Ensure title doesn't block pin hover */
        z-index: 1;  /* Below the package/grid */
    }
    .pinmux_package_container.bga .pinmux_bga_title {
        display: flex;
    }
    .pinmux_bga_title .pinmux_device_name {
        font-weight: bold;
        font-size: var(--cdt-font-xl);
    }
    .pinmux_bga_title .pinmux_package_name {
        font-size: var(--cdt-font-sm);
        opacity: 0.8;
    }
    .pinmux_bga_grid {
        display: none;
    }
    .pinmux_package_container.bga .pinmux_bga_grid {
        display: grid;
        gap: 2px;
        padding: 20px 10px 10px 20px;
        position: relative;  /* Enable z-index */
        z-index: 10;  /* Well above labels for tooltip hover */
        pointer-events: auto;  /* Ensure grid receives pointer events */
        overflow: visible;  /* Ensure tooltips are not clipped */
    }
    .pinmux_package_container.bga .pinmux_pins_top,
    .pinmux_package_container.bga .pinmux_pins_bottom,
    .pinmux_package_container.bga .pinmux_pins_left,
    .pinmux_package_container.bga .pinmux_pins_right {
        display: none;
    }
    .pinmux_bga_pin {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 6px;
        font-weight: bold;
        cursor: pointer;
        position: relative;
        z-index: 5;  /* Ensure pins are above labels */
        pointer-events: auto;  /* Ensure pins receive hover events */
        transition: transform 0.1s, box-shadow 0.1s;
    }
    .pinmux_bga_pin:hover {
        transform: scale(1.3);
        box-shadow: 0 0 6px rgba(0,0,0,0.5);
        z-index: 20;  /* Higher z-index on hover */
    }
    .pinmux_bga_pin.nc {
        background: #616161;
        opacity: 0.3;
    }
    .pinmux_bga_pin.depopulated {
        background: transparent;
        border: 1px dashed #9e9e9e;
        opacity: 0.2;
    }
    .pinmux_bga_pin.depopulated:hover {
        opacity: 0.5;
    }
    .pinmux_bga_pin.power {
        background: #ff1744;
    }
    .pinmux_bga_pin.ground {
        background: #212121;
    }
    .pinmux_bga_pin.gpio {
        background: #757575;
    }
    .pinmux_bga_pin.available {
        background: #757575;
        opacity: 0.4 !important;  /* Dim unconfigured pins */
    }
    .pinmux_bga_pin.analog {
        background: #9c27b0;
        opacity: 0.4 !important;  /* Dim unconfigured analog pins */
    }
    .pinmux_bga_pin.analog_used {
        background: #9c27b0;
        box-shadow: 0 0 4px 2px #9c27b0;  /* Bold glow for configured analog */
        opacity: 1 !important;
    }
    .pinmux_bga_pin.bidir {
        background: #7e57c2;  /* Purple shade - bidirectional */
    }
    .pinmux_bga_pin.fixed {
        background: #ff9800;  /* Orange - general fixed function */
    }
    .pinmux_bga_pin.jtag {
        background: #ff9800;  /* Orange - JTAG debug signals */
    }
    .pinmux_bga_pin.reset { background: #ffc107; }
    .pinmux_bga_pin.special { background: #00bcd4; }
    /* GPIO state colors - use CSS variables for consistency with QFP pins */
    .pinmux_bga_pin.input_high { background: var(--cdt-gpio-input-high); }
    .pinmux_bga_pin.input_low { background: var(--cdt-gpio-input-low); }
    .pinmux_bga_pin.output_high { background: var(--cdt-gpio-output-high); }
    .pinmux_bga_pin.output_low { background: var(--cdt-gpio-output-low); }
    .pinmux_bga_pin.periph_high { background: #42a5f5; }
    .pinmux_bga_pin.periph_low { background: var(--cdt-gpio-periph); }
    /* BGA row/column labels - positioned to align with grid cells */
    /* Package has padding: 10px, grid has padding: 20px top/left */
    /* So grid cells start at 10+20=30px from package edge */
    /* Each cell is 14px with 2px gap between cells */
    .pinmux_bga_row_labels {
        display: none;
        position: absolute;
        left: 2px;  /* Far left, outside grid area */
        top: 30px;  /* 10px (package padding) + 20px (grid padding) = 30px */
        width: 16px;  /* Width for row labels column */
        flex-direction: column;
        gap: 2px;  /* Match grid gap */
        font-size: 9px;
        font-weight: bold;
        opacity: 0.7;
        pointer-events: none;
        z-index: -1;  /* Behind everything */
    }
    .pinmux_bga_col_labels {
        display: none;
        position: absolute;
        left: 30px;  /* 10px (package padding) + 20px (grid padding) = 30px */
        top: 2px;  /* Further up, well above the grid */
        height: 14px;  /* Height for column labels row */
        flex-direction: row;
        gap: 2px;  /* Match grid gap */
        font-size: 9px;
        font-weight: bold;
        opacity: 0.7;
        pointer-events: none;
        z-index: -1;  /* Behind everything */
    }
    .pinmux_package_container.bga .pinmux_bga_row_labels,
    .pinmux_package_container.bga .pinmux_bga_col_labels {
        display: flex;
    }
    .pinmux_bga_label {
        /* Each label matches pin size (14px) - gap is handled by flex container */
        width: 14px;
        height: 14px;
        display: flex;
        align-items: center;
        pointer-events: none;  /* Ensure labels don't block pin hover */
        justify-content: center;
        box-sizing: border-box;
        flex-shrink: 0;
    }

    .pinmux_legend {
        display: flex;
        flex-direction: column;
        gap: 3px;
        padding: var(--cdt-space-sm) var(--cdt-space-md);
        font-size: var(--cdt-font-xs);
        border: 1px solid var(--cdt-border-primary);
        border-radius: var(--cdt-radius-md);
        min-width: 200px;
        max-width: 220px;
        background: var(--cdt-bg-elevated);
        color: var(--cdt-text-secondary);
        align-self: flex-start;
    }
    .pinmux_legend_title {
        font-weight: 600;
        font-size: var(--cdt-font-xs);
        border-bottom: 1px solid var(--cdt-border-primary);
        padding-bottom: 4px;
        margin-bottom: 4px;
        color: var(--cdt-accent-blue);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        text-align: center;
    }
    .pinmux_legend_item {
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .pinmux_legend_color {
        width: 20px;
        height: 10px;
        border: 1px solid currentColor;
        border-radius: 2px;
        flex-shrink: 0;
    }
    .pinmux_legend_color.periph_high { background: #42a5f5; }
    .pinmux_legend_color.periph_low { background: #1565c0; }
    .pinmux_legend_color.input_high { background: #81c784; }
    .pinmux_legend_color.input_low { background: #ef9a9a; }
    .pinmux_legend_color.output_high { background: #2e7d32; }
    .pinmux_legend_color.output_low { background: #c62828; }
    .pinmux_legend_color.analog { background: #9c27b0; }
    .pinmux_legend_color.jtag { background: #ff9800; }
    .pinmux_legend_color.reset { background: #ffc107; }
    .pinmux_legend_color.special { background: #00bcd4; }
    .pinmux_legend_color.power { background: #ff1744; }
    .pinmux_legend_color.ground { background: #212121; }
    .pinmux_gpio_used {
        font-weight: bold;
        gap: 4px;
        border-top: 1px solid currentColor;
        padding-top: 6px;
        margin-top: 4px;
    }
    .pinmux_counts_title {
        font-weight: 600;
        font-size: var(--cdt-font-xs);
        border-top: 1px solid var(--cdt-border-primary);
        padding-top: 6px;
        margin-top: 6px;
        margin-bottom: 4px;
        color: var(--cdt-accent-blue);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        text-align: center;
    }
    .pinmux_counts_row {
        display: grid;
        grid-template-columns: 70px 30px 70px 30px;
        gap: 2px 4px;
        font-size: var(--cdt-font-xs);
        margin-bottom: 2px;
        align-items: center;
    }
    .pinmux_count_label {
        color: var(--cdt-text-muted);
        text-align: right;
    }
    .pinmux_count_value {
        font-weight: 600;
        text-align: left;
        color: var(--cdt-text-primary);
        font-family: var(--cdt-font-mono);
    }

    #container {
        width: 100%;
        background: var(--cdt-bg-primary);
    }

    /* ==========================================================================
     * Connection Panel - Industrial Blueprint
     * ========================================================================== */

    .connection_container {
        height: 90%;
        background: var(--cdt-bg-primary);
    }
    .connection_panel {
        width: 90%;
        background: var(--cdt-bg-gradient);
        border: 1px solid var(--cdt-border-primary);
        border-radius: var(--cdt-radius-lg);
        color: var(--cdt-text-secondary);
    }
    .connection_div {
        margin: var(--cdt-space-md);
    }
    .multiline {
        white-space: pre-wrap;
        font-family: var(--cdt-font-mono);
        color: var(--cdt-text-secondary);
    }
    .connection_led {
        position: absolute;
        right: 0px;
        --gc-on-color: var(--cdt-status-pass);
        --gc-off-color: var(--cdt-bg-tertiary);
    }

    /* ==========================================================================
     * Logger Grid Styles
     * ========================================================================== */

    #cust_logger_grid {
        width: 98%;
        background: var(--cdt-bg-secondary);
    }
    #cust_logger_controls_container {
        height: 45px;
        --gc-overflow: hidden;
        background: var(--cdt-bg-tertiary);
    }
