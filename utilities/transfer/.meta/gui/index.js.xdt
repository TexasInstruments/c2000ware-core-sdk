                regDump += '  GPADIR  = 0x' + (pinmuxState.regs.dirA || 0).toString(16).toUpperCase().padStart(8, '0') + '\n';
                regDump += '  GPADAT  = 0x' + (pinmuxState.regs.datA || 0).toString(16).toUpperCase().padStart(8, '0') + '\n';
                regDump += '  GPAMUX1 = 0x' + (pinmuxState.regs.mux1A || 0).toString(16).toUpperCase().padStart(8, '0') + '\n';
                regDump += '  GPAMUX2 = 0x' + (pinmuxState.regs.mux2A || 0).toString(16).toUpperCase().padStart(8, '0') + '\n';
                regDump += '  GPAAMSEL= 0x' + (pinmuxState.regs.amselA || 0).toString(16).toUpperCase().padStart(8, '0') + '\n';
                regDump += '\nBank B (GPIO 32-63):\n';
                regDump += '  GPBDIR  = 0x' + (pinmuxState.regs.dirB || 0).toString(16).toUpperCase().padStart(8, '0') + '\n';
                regDump += '  GPBDAT  = 0x' + (pinmuxState.regs.datB || 0).toString(16).toUpperCase().padStart(8, '0') + '\n';
