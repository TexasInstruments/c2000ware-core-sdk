// Clock status LED variables
var clocking_mclksts_led;
var clocking_clkfail_led;
var clocking_pllreflost_led;

// Global object to store clocking check results (pass=true, fail=false)
// Used by export functions to get actual check status (LED.on is always true when loaded)
var clockingCheckResults = {};

// Global object to store errata check results (notAffected=true, affected=false)
var errataCheckResults = {};

async function clockingUpdate() {
    cdtDebugLog("[CDT] >>> clockingUpdate() ENTER");
    try {
    // Check if XDS transport is connected
    if (!xdsTransport || xdsTransport.state !== 'connected') {
        cdtWarn("clockingUpdate() skipped - XDS transport not connected");
        debugLog('error', 'clockingUpdate() - XDS transport not connected');
        return;
    }

    // =========================================================================
    // OSCCLK Source Frequency - Runtime Detection
    // =========================================================================
    // CDT determines clock source purely from runtime register reads.
    // No project files or SysConfig data required.
    //
    // Known frequencies:
    // - INTOSC1: 10MHz (fixed internal oscillator)
    // - INTOSC2: 10MHz (fixed internal oscillator)
    // - XTAL: Board-dependent (cannot be read from registers)
    //
    // TI LaunchPad XTAL Frequencies (from device.h):
    // - 20 MHz: F280013x, F280015x, F28002x, F28003x, F28004x, F2807x, F2838x, F28P55x
    // - 10 MHz: F2837xD, F2837xS
    // - 25 MHz: F28P65x
    //
    // Default: 20 MHz (most common across LaunchPads)
    // Users can override via the XTAL input field if their board differs.
    // =========================================================================
    const INTOSC_FREQ = 10000000;  // Internal oscillators are always 10MHz

    // Get user-specified XTAL frequency from GUI input (if available)
    // Default to 20MHz which covers most LaunchPads
    let xtalInput = document.getElementById('xtal_freq_input');
    var xtal = (xtalInput && xtalInput.value) ? parseFloat(xtalInput.value) * 1000000 : 20000000;
    cdtDebugLog("XTAL frequency (user config or default): " + (xtal/1000000) + " MHz");

    //
    // Pre req register reads
    //
    % for (var prereqReg of prereqRegisters) {
        % if (prereqReg.applicable(deviceName)){
    let `prereqReg.name` =  await xdsTransport.readValue('`prereqReg.register`');
    `prereqReg.name` = parseRegValue(`prereqReg.name`);
    debugLog('read', 'Clocking:', '`prereqReg.name`', `prereqReg.name`);
        % }
    % }

    // Update detected clock source display
    // This helps users know if they need to adjust the XTAL frequency input
    {
        let sourceNames = ["INTOSC1 (10 MHz)", "INTOSC2 (10 MHz)", "XTAL (" + (xtal/1000000) + " MHz)", "Reserved"];
        let detectedSource = sourceNames[oscclksrcsel] || "Unknown";
        let sourceLabel = document.getElementById('detected_clk_source');
        if (sourceLabel) {
            sourceLabel.textContent = detectedSource;
            // Highlight in orange if XTAL is detected (user may need to verify frequency)
            sourceLabel.style.color = (oscclksrcsel === 2) ? '#cc6600' : '#333';
        }
        cdtDebugLog("Detected clock source: " + detectedSource);
    }

    //
    // Clock Calculators
    //
    % for (var clockCalc of clockCalculators) {
        % if (clockCalc.applicable(deviceName)){
        % let getFuncString = clockCalc.get.toString();
    let `clockCalc.name` =  (`getFuncString`)`getFuncString.substring(getFuncString.indexOf("("), getFuncString.indexOf(")")+1)`;
        % }
    % }

    //
    // Clocking checks
    //
    % for (var clockCheck of clockingChecks) {
        % if (clockCheck.applicable(deviceName)){
       % let checkFuncString = clockCheck.check.toString();
       % // Get tooltip metadata
       % let tooltipValueCalc = clockCheck.tooltip ? clockCheck.tooltip.valueCalc : null;
       % let tooltipMin = clockCheck.tooltip ? clockCheck.tooltip.min : null;
       % let tooltipMax = clockCheck.tooltip ? clockCheck.tooltip.max : null;
    //
    // `clockCheck.displayName`
    //
    let `clockCheck.name` =  (`checkFuncString`)`checkFuncString.substring(checkFuncString.indexOf("("), checkFuncString.indexOf(")")+1)`;
    // Store check result in global object for export (true=pass, false=fail)
    clockingCheckResults['`clockCheck.name`'] = `clockCheck.name`;
    // Set LED: pass (green) or fail (red)
    setLedPassFail(`clockCheck.name`_led, `clockCheck.name`);
    // Update tooltip with calculated value
    {
        let tooltipValue = `tooltipValueCalc` / 1000000;
        % if (tooltipMax === "maxsysclk") {
        let tooltipMaxVal = (maxsysclk / 1000000).toFixed(1) + " MHz";
        % } else if (tooltipMax === "sysclk") {
        let tooltipMaxVal = (sysclk / 1000000).toFixed(1) + " MHz";
        % } else if (tooltipMax !== null) {
        let tooltipMaxVal = "`(tooltipMax / 1000000).toFixed(1)` MHz";
        % } else {
        let tooltipMaxVal = "N/A";
        % }
        % if (tooltipMin !== null) {
        let tooltipMinVal = "`(tooltipMin / 1000000).toFixed(1)` MHz";
        % } else {
        let tooltipMinVal = "N/A";
        % }
        let tooltipContainer = document.querySelector('#page_module_clocking_`clockCheck.name`_con');
        if (tooltipContainer) {
            tooltipContainer.title = "Max: " + tooltipMaxVal + "\nValue: " + tooltipValue.toFixed(1) + " MHz\nMin: " + tooltipMinVal;
        }
    }
        % }
    % }

    //
    // Clock Status LEDs (error/status flags)
    //
    try {
        // MCDCR.MCLKSTS - Missing Clock Status
        let mclksts_val = parseRegValue(await xdsTransport.readValue('ClkCfgRegs.MCDCR.MCLKSTS'));
        // Store result: false = OK (no missing clock), true = error (clock missing)
        clockingCheckResults['mclksts'] = !mclksts_val;  // Invert: 0=OK(true), 1=Error(false)
        if (clocking_mclksts_led) {
            setLedError(clocking_mclksts_led, mclksts_val);
        }
    } catch (e) {
        // Register doesn't exist on this device - hide the LED container
        let container = document.getElementById('page_clocking_mclksts');
        if (container) container.style.display = 'none';
    }

    try {
        // NMIFLG.CLOCKFAIL - Clock Fail NMI
        let clkfail_val = parseRegValue(await xdsTransport.readValue('NmiIntruptRegs.NMIFLG.CLOCKFAIL'));
        // Store result: false = OK (no clock fail), true = error (clock failed)
        clockingCheckResults['clockfail'] = !clkfail_val;  // Invert: 0=OK(true), 1=Error(false)
        if (clocking_clkfail_led) {
            setLedError(clocking_clkfail_led, clkfail_val);
        }
    } catch (e) {
        // Register doesn't exist on this device - hide the LED container
        let container = document.getElementById('page_clocking_clkfail');
        if (container) container.style.display = 'none';
    }

    try {
        // SYSPLLSTS.REF_LOSTS - PLL Reference Lost
        let pllreflost_val = parseRegValue(await xdsTransport.readValue('ClkCfgRegs.SYSPLLSTS.REF_LOSTS'));
        // Store result: false = OK (no ref lost), true = error (ref lost)
        clockingCheckResults['pllreflost'] = !pllreflost_val;  // Invert: 0=OK(true), 1=Error(false)
        if (clocking_pllreflost_led) {
            setLedError(clocking_pllreflost_led, pllreflost_val);
        }
    } catch (e) {
        // Register doesn't exist on this device - hide the LED container
        let container = document.getElementById('page_clocking_pllreflost');
        if (container) container.style.display = 'none';
    }

    // Store calculated SYSCLK so other panels (CPUTIMER) can use actual frequency
    if (typeof sysclk !== 'undefined' && !isNaN(sysclk) && sysclk > 0) {
        clockingCheckResults.sysclkMHz = sysclk / 1000000;
    }

    cdtDebugLog("[CDT] <<< clockingUpdate() EXIT (success)");
    } catch (error) {
        cdtError("[CDT] clockingUpdate() failed:", error?.message || String(error));
        showToast('Clocking update failed: ' + (error?.message || 'Unknown error'), 'error');
    }
}

function clockingReset() {
    //
    // Reset all clocking check LEDs to off (grey/N/A)
    //
    % for (var clockCheck of clockingChecks) {
        % if (clockCheck.applicable(deviceName)){
    setLedDisabled(`clockCheck.name`_led);
        % }
    % }
    // Reset clock status LEDs
    setLedDisabled(clocking_mclksts_led);
    setLedDisabled(clocking_clkfail_led);
    setLedDisabled(clocking_pllreflost_led);
}

// Peripheral usage flags (determined at code generation time from SysConfig)
% // Helper to check if module is used
% function isModuleUsed(path) {
%     let mod = system.modules[path];
%     return (mod && mod.$instances && mod.$instances.length > 0) ? true : false;
% }
% let adcInUse = isModuleUsed("/driverlib/adc.js");
% let eqepInUse = isModuleUsed("/driverlib/eqep.js");
% let epwmInUse = isModuleUsed("/driverlib/epwm.js");
% let cmpssInUse = isModuleUsed("/driverlib/cmpss.js");
% let sdfmInUse = isModuleUsed("/driverlib/sdfm.js");
% let dccInUse = isModuleUsed("/driverlib/dcc.js");
% let i2cInUse = isModuleUsed("/driverlib/i2c.js");
% let flashInUse = isModuleUsed("/driverlib/flash.js");
const peripheralsInUse = {
    adc: `adcInUse || false`,
    eqep: `eqepInUse || false`,
    epwm: `epwmInUse || false`,
    cmpss: `cmpssInUse || false`,
    sdfm: `sdfmInUse || false`,
    dcc: `dccInUse || false`,
    i2c: `i2cInUse || false`,
    flash: `flashInUse || false`,
    system: true  // System-level checks always apply
};
cdtDebugLog("Peripherals in use:", peripheralsInUse);

async function errataUpdate() {
    cdtDebugLog("[CDT] >>> errataUpdate() ENTER");
    try {
    // Check if XDS transport is connected
    if (!xdsTransport || xdsTransport.state !== 'connected') {
        cdtWarn("errataUpdate() skipped - XDS transport not connected");
        return;
    }

     //Errata

    //Errata Pre Register Reads

    % for (var prereqReg of errataPrereqRegisters) {
        % if (prereqReg.applicable(deviceName)){
    let `prereqReg.name` =  await xdsTransport.readValue('`prereqReg.register`');
    `prereqReg.name` = parseRegValue(`prereqReg.name`);
        % }
    % }

    await xdsTransport.initCore({});
    const core = xdsTransport.activeCoreMap.get('active');
    
    
    //Errata Pre Memory Reads

    % for (var prereqMemory of errataPrereqMemoryLocs) {
        % if (prereqMemory.applicable(deviceName)){
    let `prereqMemory.name` = await core.readMemoryRaw("`prereqMemory.address`", "unsigned int", 1);
    `prereqMemory.name` = parseRegValue(`prereqMemory.name`);
        % }
    % } 

     //
    // Value Calculators
    //
    % for (var valueCalc of memoryValueCalculators) {
        % if (valueCalc.applicable(deviceName)){
        % let getFuncString = valueCalc.get.toString();
    let `valueCalc.name` =  (`getFuncString`)`getFuncString.substring(getFuncString.indexOf("("), getFuncString.indexOf(")")+1)`;
        % }
    % }  

    //Errata checks

    % for (var errataCheck of errataChecks) {
        % if (errataCheck.applicable(deviceName)){
       % let checkFuncString = errataCheck.check.toString();
       % // Get errata info for tooltip
       % let errataLink = errataCheck.referenceLink[deviceName] ? errataCheck.referenceLink[deviceName] : errataCheck.referenceLink["default"];
       % let errataDocId = errataLink.match(/SPRZ\d+\w*/i) ? errataLink.match(/SPRZ\d+\w*/i)[0] : "See Link";
       % let errataDesc = ((typeof errataCheck.description === 'object') ? (errataCheck.description[deviceName] || errataCheck.description["default"]) : (errataCheck.description || "Click link for details")).replace(/\n/g, '\\n');
       % let peripheralType = errataCheck.peripheral || null;
    //
    // `errataCheck.displayName`
    //
    let `errataCheck.name` =  (`checkFuncString`)`checkFuncString.substring(checkFuncString.indexOf("("), checkFuncString.indexOf(")")+1)`;
    // Store errata check result in global object (true=not affected, false=affected)
    errataCheckResults['`errataCheck.name`'] = `errataCheck.name`;
    // Check if associated peripheral is in use
    % if (peripheralType) {
    let `errataCheck.name`_peripheralUsed = peripheralsInUse["`peripheralType`"] || false;
    % } else {
    let `errataCheck.name`_peripheralUsed = true;  // System-level errata, always check
    % }
    // Set LED color based on check result AND peripheral usage
    // Grey = peripheral not used (not applicable)
    // Green = peripheral used AND no errata issue
    // Red = peripheral used AND errata condition detected
    if (`errataCheck.name`_peripheralUsed) {
        setLedPassFail(`errataCheck.name`_led, `errataCheck.name`);
    } else {
        // Peripheral not used - leave LED grey (off)
        setLedDisabled(`errataCheck.name`_led);
    }
    // Update tooltip with status
    {
        let tooltipStatus = !`errataCheck.name`_peripheralUsed ? "N/A - Peripheral not used" :
                           (`errataCheck.name` ? "PASS - No issue detected" : "FAIL - Errata condition present");
        let tooltipContainer = document.querySelector('#page_module_errata_`errataCheck.name`_con');
        if (tooltipContainer) {
            tooltipContainer.title = "Errata Doc: `errataDocId`\n`errataDesc`\nStatus: " + tooltipStatus;
        }
    }
        % }
    % }

    cdtDebugLog("[CDT] <<< errataUpdate() EXIT (success)");
    } catch (error) {
        cdtError("[CDT] errataUpdate() failed:", error?.message);
        showToast('Errata update failed: ' + (error?.message || 'Unknown error'), 'error');
        cdtError("errataUpdate() error:", error);
    }
}

function errataReset() {

    //
    // Reset all errata check LEDs to off (grey/N/A)
    //
    % for (var errataCheck of errataChecks) {
        % if (errataCheck.applicable(deviceName)){
    setLedDisabled(`errataCheck.name`_led);
        % }
    % }

}

//=============================================================================
// System (SYSCTL) Update/Reset Functions
//=============================================================================

// PartID Lookup Tables
// PIN_COUNT mapping is device-specific with full package names (type + code)
// Package types: TQFP, LQFP, BGA, NFBGA
// Package codes from device datasheets: PFB=32-pin TQFP, PM=48-pin LQFP, PN=56/64-pin LQFP,
//   PZ=80-pin LQFP/BGA, PT=100-pin LQFP, PTP=176-pin LQFP, ZWT=337-ball BGA

// Default package info: {pins, type, code}
const PACKAGE_INFO_DEFAULT = {
    0: {pins: 32,  type: "TQFP", code: "PFB"},
    1: {pins: 48,  type: "LQFP", code: "PM"},
    2: {pins: 56,  type: "LQFP", code: "PN"},
    3: {pins: 64,  type: "LQFP", code: "PN"},
    4: {pins: 80,  type: "LQFP", code: "PZ"},
    5: {pins: 100, type: "LQFP", code: "PT"},
    6: {pins: 176, type: "LQFP", code: "PTP"},
    7: {pins: 337, type: "BGA",  code: "ZWT"}
};

// Device-specific overrides (where package type differs from default)
const PACKAGE_INFO_F28P65x = {
    2: {pins: 169, type: "NFBGA", code: "ZWS"},   // LaunchPad package
    3: {pins: 256, type: "BGA",   code: "ZEJ"},   // 256-ball BGA
    5: {pins: 100, type: "LQFP",  code: "PT"},
    6: {pins: 176, type: "LQFP",  code: "PTP"},
    7: {pins: 337, type: "BGA",   code: "ZWT"}
};
const PACKAGE_INFO_F28P55x = {
    2: {pins: 80,  type: "LQFP", code: "PZ"},
    5: {pins: 100, type: "LQFP", code: "PT"}
};
const PACKAGE_INFO_F2838x = {
    5: {pins: 100, type: "LQFP", code: "PT"},
    6: {pins: 176, type: "LQFP", code: "PTP"},
    7: {pins: 337, type: "BGA",  code: "ZWT"}
};

function getPinCountString(pinCount, deviceName) {
    let pkgInfo = null;

    // Check device-specific overrides first
    if (deviceName === "F28P65x" && PACKAGE_INFO_F28P65x[pinCount] !== undefined) {
        pkgInfo = PACKAGE_INFO_F28P65x[pinCount];
    } else if (deviceName === "F28P55x" && PACKAGE_INFO_F28P55x[pinCount] !== undefined) {
        pkgInfo = PACKAGE_INFO_F28P55x[pinCount];
    } else if (deviceName === "F2838x" && PACKAGE_INFO_F2838x[pinCount] !== undefined) {
        pkgInfo = PACKAGE_INFO_F2838x[pinCount];
    } else if (PACKAGE_INFO_DEFAULT[pinCount] !== undefined) {
        pkgInfo = PACKAGE_INFO_DEFAULT[pinCount];
    }

    // Format as "XX-pin TYPE (CODE)" or "XX-ball TYPE (CODE)"
    if (pkgInfo) {
        let suffix = pkgInfo.type.includes("BGA") ? "ball" : "pin";
        return pkgInfo.pins + "-" + suffix + " " + pkgInfo.type + " (" + pkgInfo.code + ")";
    }
    return pinCount + "-pin";
}
// QUAL_MAP defined locally in systemUpdate() with better documentation
// Note: Device Class ID values are silicon-defined and may vary
// Using SysConfig device name for display: `deviceName`
const DEVICE_CLASS_MAP = {
    0x05: "F2837xS", 0x06: "F2837xD", 0x07: "F2807x/F280015x",
    0x08: "F28004x", 0x09: "F28002x", 0x0A: "F2838x", 0x0B: "F28003x",
    0x0C: "F280013x", 0x0E: "F28P65x", 0x0F: "F28P55x"
};

//=============================================================================
// Target Status Update (Enhanced Debugger Status - Option B)
// Updates the target state LED, state text, and PC address display
//=============================================================================
function updateTargetStatus(state, pcValue) {
    cdtDebugLog("[CDT] updateTargetStatus: state=" + state + ", PC=" + (pcValue !== undefined ? "0x" + pcValue.toString(16).toUpperCase() : "N/A"));

    // Update global state tracker
    currentTargetState = state;

    // Update Target State LED and text
    if (target_state_led && target_state_value) {
        if (state === 'halted' || state === 'suspended' || state === 'stopped') {
            // HALTED - Red LED, red text
            target_state_led.on = true;
            target_state_led.classList.remove('clinic_led_valid');
            target_state_led.classList.add('clinic_led_invalid');
            target_state_value.label = 'HALTED';
            target_state_value.classList.remove('target_state_running');
            target_state_value.classList.add('target_state_halted');
        } else if (state === 'running' || state === 'free_running') {
            // RUNNING - Green LED, green text
            target_state_led.on = true;
            target_state_led.classList.remove('clinic_led_invalid');
            target_state_led.classList.add('clinic_led_valid');
            target_state_value.label = 'RUNNING';
            target_state_value.classList.remove('target_state_halted');
            target_state_value.classList.add('target_state_running');
        } else {
            // Unknown state - LED off, grey text
            target_state_led.on = false;
            target_state_led.classList.remove('clinic_led_valid', 'clinic_led_invalid');
            target_state_value.label = state || '--';
            target_state_value.classList.remove('target_state_running', 'target_state_halted');
        }
    }

    // Update PC Address display
    if (target_pc_value) {
        if (pcValue !== undefined && pcValue !== null) {
            target_pc_value.label = '0x' + pcValue.toString(16).toUpperCase().padStart(8, '0');
        } else if (state === 'running' || state === 'free_running') {
            target_pc_value.label = '(running)';
        } else {
            target_pc_value.label = '--';
        }
    }
}

// Read PC register and update target status display
async function refreshTargetStatus() {
    try {
        // Try to read PC register - this only works when target is halted
        let pc = parseRegValue(await xdsTransport.readValue('PC'));
        // If we successfully read PC, target must be halted
        updateTargetStatus('halted', pc);
        return pc;
    } catch (e) {
        // If read fails, target is likely running
        cdtDebugLog("[CDT] PC read failed (target likely running): " + e.message);
        updateTargetStatus('running', null);
        return null;
    }
}

//-----------------------------------------------------------------------------
// Device Information Update - Read PARTID/REVID from actual hardware
// Displays runtime device info that complements (not duplicates) SYSCTL exports
//-----------------------------------------------------------------------------
async function updateDeviceInfo() {
    debugLog('info', 'Reading device identification registers...');

    try {
        // Read PARTID registers via XDS debugger
        let partidl = await xdsTransport.readValue('DevCfgRegs.PARTIDL');
        partidl = parseInt(partidl);

        let partidh = await xdsTransport.readValue('DevCfgRegs.PARTIDH');
        partidh = parseInt(partidh);

        let revid = await xdsTransport.readValue('DevCfgRegs.REVID');
        revid = parseInt(revid);

        debugLog('read', 'DeviceInfo:', 'PARTIDL', '0x' + partidl.toString(16).toUpperCase());
        debugLog('read', 'DeviceInfo:', 'PARTIDH', '0x' + partidh.toString(16).toUpperCase());
        debugLog('read', 'DeviceInfo:', 'REVID', '0x' + revid.toString(16).toUpperCase());

        // Decode PARTIDL fields
        const pinCount = (partidl >> 8) & 0x7;
        const flashSizeFromReg = (partidl >> 16) & 0xFF;

        // Get compile-time device family from SysConfig
        const deviceFamily = '`deviceName`';

        // Determine flash size (from register or fallback)
        let flashKB = 0;
        if (DEVICES_WITH_FLASH_IN_PARTIDL.includes(deviceFamily) && flashSizeFromReg > 0) {
            flashKB = flashSizeFromReg;
        } else {
            // Fallback for F280013x, F280015x, or invalid read
            const fallback = { "F280013x": 32, "F280015x": 64 };
            flashKB = fallback[deviceFamily] || flashSizeFromReg || 0;
        }

        // Get RAM from lookup (not in PARTID)
        const ramKB = RAM_BY_FAMILY_KB[deviceFamily] || 0;

        // Update GUI labels - these show info NOT duplicated in SYSCTL exports
        // Note: Silicon Rev is already shown via SYSCTL exports panel
        if (deviceInfoNameLabel) {
            deviceInfoNameLabel.label = deviceFamily;
        }
        if (deviceInfoFlashLabel) {
            deviceInfoFlashLabel.label = flashKB > 0 ? flashKB + " KB" : "--";
        }
        if (deviceInfoRamLabel) {
            deviceInfoRamLabel.label = ramKB > 0 ? ramKB + " KB" : "--";
        }
        if (deviceInfoPinsLabel) {
            deviceInfoPinsLabel.label = PIN_COUNT_MAP[pinCount] || pinCount + "-pin";
        }

        debugLog('info', 'Device: ' + deviceFamily + ', Flash: ' + flashKB +
                 'KB, RAM: ' + ramKB + 'KB, Pins: ' + (PIN_COUNT_MAP[pinCount] || pinCount));

    } catch (error) {
        debugLog('error', 'Failed to read device info: ' + error.message);
        // Set fallback state using compile-time device family
        if (deviceInfoNameLabel) deviceInfoNameLabel.label = '`deviceName`';
        if (deviceInfoFlashLabel) deviceInfoFlashLabel.label = "--";
        if (deviceInfoRamLabel) deviceInfoRamLabel.label = "--";
        if (deviceInfoPinsLabel) deviceInfoPinsLabel.label = "--";
    }
}

/**
 * Verified DIE_ID register addresses per device family.
 * Source: Device TRMs, "DevCfgRegs – DIEID Registers" section.
 * All addresses are C28x 16-bit word addresses.
 *
 * Two register layouts exist:
 *   32-bit (Uint32): F2807x, F2837x, F28003x, F28002x, F2838x
 *     DIEID0 at base+0x00, DIEID1 at base+0x04, DIEID2 at base+0x08, DIEID3 at base+0x0C
 *     Base address: 0x5D100
 *   16-bit (Uint16): F28P65x, F28P55x
 *     DIEID0 at 0x5D180, DIEID1 at 0x5D182, DIEID2 at 0x5D184, DIEID3 at 0x5D186
 *     Base address: 0x5D180 (within the 0x5D100 block)
 *
 * Devices without DIEID (F28004x, F280013x, F280015x):
 *   F28004x has CJTAGNODEID at 0x5D07E instead.
 *   F280013x/F280015x have no silicon die ID registers.
 */
const DIE_ID_REG_MAP = {
    // ── 32-bit DIEID devices (Uint32, base 0x5D100) ───────────────────────
    "F2807x":  { bits: 32, DIEID0: 0x5D100, DIEID1: 0x5D104, DIEID2: 0x5D108, DIEID3: 0x5D10C, PARTID: 0x5D00A },
    "F2837xD": { bits: 32, DIEID0: 0x5D100, DIEID1: 0x5D104, DIEID2: 0x5D108, DIEID3: 0x5D10C, PARTID: 0x5D00A },
    "F2837xS": { bits: 32, DIEID0: 0x5D100, DIEID1: 0x5D104, DIEID2: 0x5D108, DIEID3: 0x5D10C, PARTID: 0x5D00A },
    "F28003x": { bits: 32, DIEID0: 0x5D100, DIEID1: 0x5D104, DIEID2: 0x5D108, DIEID3: 0x5D10C, PARTID: 0x5D00A },
    "F28002x": { bits: 32, DIEID0: 0x5D100, DIEID1: 0x5D104, DIEID2: 0x5D108, DIEID3: 0x5D10C, PARTID: 0x5D00A },
    "F2838x":  { bits: 32, DIEID0: 0x5D100, DIEID1: 0x5D104, DIEID2: 0x5D108, DIEID3: 0x5D10C, PARTID: 0x5D00A },
    // ── 16-bit DIEID devices (Uint16, base 0x5D180) ───────────────────────
    "F28P65x": { bits: 16, DIEID0: 0x5D180, DIEID1: 0x5D182, DIEID2: 0x5D184, DIEID3: 0x5D186, PARTID: 0x5D00A, UID: 0x703CC },
    "F28P55x": { bits: 16, DIEID0: 0x5D180, DIEID1: 0x5D182, DIEID2: 0x5D184, DIEID3: 0x5D186, PARTID: 0x5D00A },
    // ── No DIEID — CJTAGNODEID only ──────────────────────────────────────
    "F28004x": { bits: null, CJTAGNODEID: 0x5D07E, PARTID: 0x5D00A },
    // ── No identification registers ──────────────────────────────────────
    "F280013x": null,
    "F280015x": null,
};

/**
 * Extract and display DIE_ID, PARTID, and UID register values.
 * Uses direct memory address reads (*0xADDR) via XDS debugger.
 * Handles three device categories:
 *   - null entry (F280013x/F280015x): no identification registers
 *   - bits=null (F28004x): CJTAGNODEID only, no DIEID
 *   - bits=32 or bits=16: standard DIEID with appropriate hex formatting
 */
async function extractDieIdUid() {
    const toHex32 = (v) => '0x' + (v >>> 0).toString(16).toUpperCase().padStart(8, '0');
    const toHex16 = (v) => '0x' + (v & 0xFFFF).toString(16).toUpperCase().padStart(4, '0');
    const setEl   = (id, text) => { const el = document.getElementById(id); if (el) el.textContent = text; };
    const readAddr = (addr) => xdsTransport.readValue('*0x' + addr.toString(16).toUpperCase());
    const ALL_IDS = ['die_id_dieid0_value','die_id_dieid1_value','die_id_dieid2_value',
                     'die_id_dieid3_value','die_id_partid_value','die_id_uid_value','die_id_uid128_value'];

    const entry = DIE_ID_REG_MAP['`deviceName`'];

    // Device has no identification registers at all
    if (entry === null || entry === undefined) {
        ALL_IDS.forEach(id => setEl(id, 'N/A'));
        setEl('die_id_uid128_value', 'No DIEID on `deviceName`');
        debugLog('info', 'extractDieIdUid: `deviceName` has no DIEID registers');
        return;
    }

    const fmt = entry.bits === 16 ? toHex16 : toHex32;

    try {
        // ── F28004x: CJTAGNODEID only, no DIEID ──────────────────────────
        if (entry.bits === null) {
            ['die_id_dieid0_value','die_id_dieid1_value','die_id_dieid2_value','die_id_dieid3_value']
                .forEach(id => setEl(id, 'N/A'));
            try {
                const jtagId = parseInt(await readAddr(entry.CJTAGNODEID)) >>> 0;
                setEl('die_id_uid128_value', 'CJTAGNODEID: ' + toHex32(jtagId));
                debugLog('info', 'CJTAGNODEID=' + toHex32(jtagId));
            } catch(e) {
                setEl('die_id_uid128_value', 'CJTAGNODEID: Error');
            }
            // Still read PARTID
            if (entry.PARTID) {
                try {
                    const p = parseInt(await readAddr(entry.PARTID)) >>> 0;
                    setEl('die_id_partid_value', toHex32(p));
                } catch(e) { setEl('die_id_partid_value', 'Error'); }
            }
            setEl('die_id_uid_value', 'N/A');
            return;
        }

        // ── Read all DIEID + PARTID + UID in parallel ────────────────────
        const reads = [
            readAddr(entry.DIEID0), readAddr(entry.DIEID1),
            readAddr(entry.DIEID2), readAddr(entry.DIEID3),
            entry.PARTID ? readAddr(entry.PARTID) : Promise.resolve(null),
            entry.UID    ? readAddr(entry.UID)    : Promise.resolve(null),
        ];
        const [r0, r1, r2, r3, rPartid, rUid] = await Promise.allSettled(reads);

        const parse = (r) => (r.status === 'fulfilled' && r.value !== null)
                             ? parseInt(r.value) >>> 0 : null;
        const d0     = parse(r0);
        const d1     = parse(r1);
        const d2     = parse(r2);
        const d3     = parse(r3);
        const partid = parse(rPartid);
        const uid    = parse(rUid);

        setEl('die_id_dieid0_value', d0     !== null ? fmt(d0)     : 'Error');
        setEl('die_id_dieid1_value', d1     !== null ? fmt(d1)     : 'Error');
        setEl('die_id_dieid2_value', d2     !== null ? fmt(d2)     : 'Error');
        setEl('die_id_dieid3_value', d3     !== null ? fmt(d3)     : 'Error');
        setEl('die_id_partid_value', partid !== null ? toHex32(partid) : 'N/A');
        setEl('die_id_uid_value',    uid    !== null ? toHex32(uid)    : 'N/A');

        if (d0 !== null && d1 !== null && d2 !== null && d3 !== null) {
            const uid128 = fmt(d3) + '_' + fmt(d2) + '_' + fmt(d1) + '_' + fmt(d0);
            setEl('die_id_uid128_value', uid128);
            debugLog('info', 'DIEID[127:0]=' + uid128 + ' (' + entry.bits + '-bit registers)');
        } else {
            setEl('die_id_uid128_value', 'Error');
        }

    } catch (error) {
        ALL_IDS.forEach(id => setEl(id, 'Error'));
        debugLog('error', 'extractDieIdUid failed: ' + error.message);
    }
}

async function systemUpdate() {
    cdtDebugLog("[CDT] >>> systemUpdate() ENTER");
    try {
        // Check if XDS transport is connected
        if (!xdsTransport || xdsTransport.state !== 'connected') {
            cdtWarn("systemUpdate() skipped - XDS transport not connected");
            debugLog('error', 'systemUpdate() - XDS transport not connected');
            return;
        }

        // Update Device Info Card first (reads PARTID/REVID for flash/RAM/pins)
        await updateDeviceInfo();

        // Update target status card (PC address, running/halted state)
        await refreshTargetStatus();

        //
        // Read specific bitfields directly (like clocking clinic does)
        // This avoids the object reconstruction issues with full register reads
        //

        // RESC register - read individual bits in parallel for performance
        // RESC bits vary by device but common ones: POR, XRSn, WDRSn, NMIWDRSn
        // Using Promise.allSettled for parallel reads - missing bits will resolve to 0
        const rescRegs = [
            'CpuSysRegs.RESC.POR',
            'CpuSysRegs.RESC.XRSn',
            'CpuSysRegs.RESC.WDRSn',
            'CpuSysRegs.RESC.NMIWDRSn',
            'CpuSysRegs.RESC.HWBISTn',
            'CpuSysRegs.RESC.SCCRESETn',
            'CpuSysRegs.RESC.ECAT_RESET_OUT',
            'CpuSysRegs.RESC.SIMRESET_CPU1RSn',
            'CpuSysRegs.RESC.SIMRESET_XRSn'
        ];
        const rescResults = await Promise.allSettled(
            rescRegs.map(reg => xdsTransport.readValue(reg))
        );
        // Extract values (0 for failed reads - device-specific bits may not exist)
        const [resc_por, resc_xrsn, resc_wdrsn, resc_nmiwdrsn, resc_hwbistn,
               resc_sccresetn, resc_ecat, resc_simreset_cpu, resc_simreset_xrs] =
            rescResults.map((r, i) => {
                const val = r.status === 'fulfilled' ? parseRegValue(r.value) : 0;
                debugLog('read', 'System:', rescRegs[i].split('.').pop(), r.status === 'fulfilled' ? val : 'N/A');
                return val;
            });

        cdtDebugLog("RESC bits - POR:" + resc_por + " XRSn:" + resc_xrsn + " WDRSn:" + resc_wdrsn + " NMIWDRSn:" + resc_nmiwdrsn + " HWBISTn:" + resc_hwbistn + " SCCRESETn:" + resc_sccresetn + " ECAT:" + resc_ecat);

        // Build reset source string
        let resetSources = [];
        if (resc_por) resetSources.push("POR");
        if (resc_xrsn) resetSources.push("XRSn");
        if (resc_wdrsn) resetSources.push("WDRSn");
        if (resc_nmiwdrsn) resetSources.push("NMIWDRSn");
        if (resc_hwbistn) resetSources.push("HWBISTn");
        if (resc_sccresetn) resetSources.push("SCCRESETn");
        if (resc_ecat) resetSources.push("ECAT_RESET_OUT");
        if (resc_simreset_cpu) resetSources.push("SIMRESET_CPU");
        if (resc_simreset_xrs) resetSources.push("SIMRESET_XRS");
        // If no bits set, RESC was cleared by boot/init code
        // This is normal when connecting via debugger (XRSn) and boot code clears RESC
        let resetText = resetSources.length > 0 ? resetSources.join(", ") : "XRSn (Debugger)";
        cdtDebugLog("Reset Source: " + resetText);
        if (sysctl_resetSource_value) sysctl_resetSource_value.label = resetText;

        // REVID and PARTIDL - read in parallel for performance
        const [revidResult, pinCountResult] = await Promise.allSettled([
            xdsTransport.readValue('DevCfgRegs.REVID.REVID'),
            xdsTransport.readValue('DevCfgRegs.PARTIDL.PIN_COUNT')
        ]);

        // Process REVID
        if (revidResult.status === 'fulfilled') {
            let revid = parseRegValue(revidResult.value);
            cdtDebugLog("Silicon Rev: " + revid);
            debugLog('read', 'System:', 'REVID', revid);
            if (sysctl_revid_value) sysctl_revid_value.label = "Rev " + revid;
        } else {
            cdtError("REVID read error:", revidResult.reason);
            debugLog('error', 'System:', 'REVID read failed', revidResult.reason?.message);
            if (sysctl_revid_value) sysctl_revid_value.label = "Error";
        }

        // Process PARTIDL.PIN_COUNT
        let pinCount = 0;
        if (pinCountResult.status === 'fulfilled') {
            pinCount = parseRegValue(pinCountResult.value) || 0;
            cdtDebugLog("PARTIDL.PIN_COUNT: " + pinCount);
            debugLog('read', 'System:', 'PARTIDL.PIN_COUNT', pinCount);
        } else {
            cdtDebugLog("PARTIDL.PIN_COUNT read failed:", pinCountResult.reason?.message);
            debugLog('error', 'System:', 'PARTIDL.PIN_COUNT read failed', pinCountResult.reason?.message);
        }
        // Use device memory constants for flash size (more reliable than register on some devices)
        let partidlText = "`deviceMem.flash`KB, " + getPinCountString(pinCount, "`deviceName`");
        cdtDebugLog("Device Info: " + partidlText);
        if (sysctl_partidl_value) sysctl_partidl_value.label = partidlText;

        // Update pinmux package configuration based on PIN_COUNT
        // PIN_COUNT register value maps to actual pin counts via PACKAGE_INFO
        // Use device-specific package info when available
        let pkgInfo = null;
        if ("`deviceName`" === "F28P65x" && PACKAGE_INFO_F28P65x[pinCount] !== undefined) {
            pkgInfo = PACKAGE_INFO_F28P65x[pinCount];
        } else if ("`deviceName`" === "F28P55x" && PACKAGE_INFO_F28P55x[pinCount] !== undefined) {
            pkgInfo = PACKAGE_INFO_F28P55x[pinCount];
        } else if ("`deviceName`" === "F2838x" && PACKAGE_INFO_F2838x[pinCount] !== undefined) {
            pkgInfo = PACKAGE_INFO_F2838x[pinCount];
        } else {
            pkgInfo = PACKAGE_INFO_DEFAULT[pinCount];
        }

        if (pkgInfo && pkgInfo.pins !== pinmuxState.packagePins) {
            cdtDebugLog("Updating pinmux package from " + pinmuxState.packagePins + " to " + pkgInfo.pins + " pins");
            pinmuxState.packagePins = pkgInfo.pins;
            pinmuxState.packageName = pkgInfo.pins + "-pin " + pkgInfo.type + " (" + pkgInfo.code + ")";
            // Reinitialize package view with new pin count
            initPinmuxPackage();
        } else if (pkgInfo) {
            // Update package name even if size didn't change
            pinmuxState.packageName = pkgInfo.pins + "-pin " + pkgInfo.type + " (" + pkgInfo.code + ")";
        }

        // Device Class - use SysConfig device name (more reliable than PARTIDH)
        // PARTIDH.DEVICE_CLASS_ID values vary and may not uniquely identify the device
        cdtDebugLog("Device Class (from SysConfig): `deviceName`");
        if (sysctl_partidh_value) sysctl_partidh_value.label = "`deviceName`";

        // TAP_STATUS.DCON - Debugger connected (bit 31)
        try {
            let dcon = parseRegValue(await xdsTransport.readValue('DevCfgRegs.TAP_STATUS.DCON'));
            cdtDebugLog("Debugger Connected: " + dcon);
            debugLog('read', 'System:', 'TAP_STATUS.DCON', dcon);
            setLedActive(sysctl_tapStatus_led, dcon);
        } catch (e) {
            cdtError("TAP_STATUS read error:", e);
            debugLog('error', 'System:', 'TAP_STATUS.DCON read failed', e.message);
            setLedWarning(sysctl_tapStatus_led, true);
        }

        // Execution Location - Read PC register to determine if running from RAM, FLASH, or Boot ROM
        // Memory Map (device-specific, showing F280015x as example):
        //   0x000000 - 0x0003FF: M0 RAM
        //   0x000400 - 0x0007FF: M1 RAM
        //   0x008000 - 0x00BFFF: LS RAM (LS0-LS7)
        //   0x00C000 - 0x00FFFF: GS RAM (GS0-GS3)
        //   0x080000 - 0x08FFFF: FLASH (Bank 0)
        //   0x3F0000 - 0x3FFFFF: Boot ROM
        try {
            let pc = parseRegValue(await xdsTransport.readValue('PC'));
            let execLocation = 'Unknown';
            let execColor = '#888888';

            if (pc >= 0x080000 && pc < 0x100000) {
                execLocation = 'FLASH (0x' + pc.toString(16).toUpperCase() + ')';
                execColor = '#2e7d32';  // Green - normal production execution
            } else if (pc >= 0x000000 && pc < 0x000400) {
                execLocation = 'M0 RAM (0x' + pc.toString(16).toUpperCase() + ')';
                execColor = '#1565c0';  // Blue - RAM execution
            } else if (pc >= 0x000400 && pc < 0x000800) {
                execLocation = 'M1 RAM (0x' + pc.toString(16).toUpperCase() + ')';
                execColor = '#1565c0';  // Blue
            } else if (pc >= 0x008000 && pc < 0x00C000) {
                execLocation = 'LS RAM (0x' + pc.toString(16).toUpperCase() + ')';
                execColor = '#1565c0';  // Blue
            } else if (pc >= 0x00C000 && pc < 0x010000) {
                execLocation = 'GS RAM (0x' + pc.toString(16).toUpperCase() + ')';
                execColor = '#1565c0';  // Blue
            } else if (pc >= 0x3F0000 && pc < 0x400000) {
                execLocation = 'Boot ROM (0x' + pc.toString(16).toUpperCase() + ')';
                execColor = '#ff9800';  // Orange - boot ROM
            } else {
                execLocation = 'Unknown (0x' + pc.toString(16).toUpperCase() + ')';
                execColor = '#c62828';  // Red - unexpected location
            }

            cdtDebugLog("Execution Location: " + execLocation + " PC=0x" + pc.toString(16).toUpperCase());
            debugLog('read', 'Execution:', 'PC', '0x' + pc.toString(16).toUpperCase());

            if (sysctl_execLocation_value) {
                sysctl_execLocation_value.label = execLocation;
                sysctl_execLocation_value.style.color = execColor;
            }
        } catch (e) {
            cdtError("PC read error:", e);
            if (sysctl_execLocation_value) {
                sysctl_execLocation_value.label = 'N/A';
            }
        }

        //---------------------------------------------------------------------
        // Extended Device Information
        //---------------------------------------------------------------------

        // Qualification Status (PARTIDL.QUAL)
        // TI Silicon Qualification Levels:
        //   0 = XS - Prototype (early engineering samples, not for production)
        //   1 = XM - Experimental (engineering samples, limited testing)
        //   2 = XP - Pre-production (qualification samples, restricted production)
        //   3 = (none) - Production (fully qualified for production use)
        const QUAL_MAP = {
            0: "XS (Prototype)",
            1: "XM (Experimental)",
            2: "XP (Pre-prod)",
            3: "Production"
        };
        try {
            let qual_raw = parseRegValue(await xdsTransport.readValue('DevCfgRegs.PARTIDL.QUAL'));
            let qualText = QUAL_MAP[qual_raw] || ("Unknown (" + qual_raw + ")");
            cdtDebugLog("Qualification Status: " + qualText + " (raw=" + qual_raw + ")");
            debugLog('read', 'System:', 'PARTIDL.QUAL', qual_raw + ' (' + qualText + ')');
            if (sysctl_qualStatus_value) sysctl_qualStatus_value.label = qualText;
        } catch (e) {
            cdtDebugLog("PARTIDL.QUAL read failed:", e.message);
            debugLog('error', 'System:', 'PARTIDL.QUAL read failed', e.message);
            if (sysctl_qualStatus_value) sysctl_qualStatus_value.label = "N/A";
        }

        // Device Family (PARTIDH.FAMILY)
        // Family codes vary by device generation
        const FAMILY_MAP = {
            0: "C2000 Gen2",      // F2802x, F2803x, F2805x, F2806x
            1: "C2000 Gen2",      // F2833x, F2823x
            2: "C2000",
            5: "C2000 Gen3",      // F280013x, F280015x, F28002x
            6: "C2000 Gen3",      // F28003x, F28004x
            7: "C2000 Gen3",      // F2807x
            8: "C2000 Gen3",      // F2837x, F2838x
            14: "C2000 Gen3",     // F28P55x, F28P65x
        };
        try {
            let family_raw = parseRegValue(await xdsTransport.readValue('DevCfgRegs.PARTIDH.FAMILY'));
            let familyText = FAMILY_MAP[family_raw] || ("C2000 (" + family_raw + ")");
            cdtDebugLog("Device Family: " + familyText);
            debugLog('read', 'System:', 'PARTIDH.FAMILY', family_raw + ' (' + familyText + ')');
            if (sysctl_deviceFamily_value) sysctl_deviceFamily_value.label = familyText;
        } catch (e) {
            cdtDebugLog("PARTIDH.FAMILY read failed:", e.message);
            debugLog('error', 'System:', 'PARTIDH.FAMILY read failed', e.message);
            if (sysctl_deviceFamily_value) sysctl_deviceFamily_value.label = "N/A";
        }

        // Part Number (PARTIDH.PARTNO) with full orderable part number
        // Combines DEVICE_CLASS_ID + PARTNO + PIN_COUNT to build complete PN
        // Format: TMS320F2800157SPN where S=temp grade, PN=package
        // Package codes: PT=100-pin LQFP, PN=64-pin LQFP, PM=48-pin LQFP, PZ=100-pin BGA, etc.
        const PARTNO_LOOKUP = {
            // Format: "DEVICE_CLASS_ID:PARTNO" -> "Base Part Number"
            // F280013x family (CLASS_ID=0x0C)
            "12:255": "TMS320F280013", "12:254": "TMS320F280013",
            // F280015x family (CLASS_ID=0x07 shared with F2807x)
            "7:255": "TMS320F2800157", "7:254": "TMS320F2800157",
            "7:240": "TMS320F2800155", "7:241": "TMS320F2800155",
            "7:224": "TMS320F2800137", "7:225": "TMS320F2800137",
            // F2807x family (CLASS_ID=0x07)
            "7:12": "TMS320F28075", "7:8": "TMS320F28074",
            "7:4": "TMS320F28072", "7:0": "TMS320F28070",
            // F28002x family (CLASS_ID=0x09)
            "9:255": "TMS320F280025", "9:254": "TMS320F280025",
            "9:240": "TMS320F280025C", "9:224": "TMS320F280023",
            "9:208": "TMS320F280023C", "9:192": "TMS320F280021",
            // F28003x family (CLASS_ID=0x0B)
            "11:255": "TMS320F280039", "11:254": "TMS320F280039",
            "11:240": "TMS320F280039C", "11:224": "TMS320F280038",
            "11:208": "TMS320F280038", "11:192": "TMS320F280037",
            "11:176": "TMS320F280037", "11:160": "TMS320F280037C",
            "11:144": "TMS320F280036", "11:128": "TMS320F280036",
            "11:112": "TMS320F280033", "11:96": "TMS320F280032",
            // F28004x family (CLASS_ID=0x08)
            "8:255": "TMS320F280049", "8:254": "TMS320F280049",
            "8:240": "TMS320F280049C", "8:224": "TMS320F280048",
            "8:208": "TMS320F280048", "8:192": "TMS320F280048C",
            "8:176": "TMS320F280045", "8:160": "TMS320F280041",
            "8:144": "TMS320F280041", "8:128": "TMS320F280041C",
            "8:112": "TMS320F280040", "8:96": "TMS320F280040",
            // F2837xS family (CLASS_ID=0x05)
            "5:255": "TMS320F28379S", "5:240": "TMS320F28378S",
            "5:224": "TMS320F28377S", "5:208": "TMS320F28376S",
            "5:192": "TMS320F28375S", "5:176": "TMS320F28374S",
            // F2837xD family (CLASS_ID=0x06)
            "6:255": "TMS320F28379D", "6:240": "TMS320F28378D",
            "6:224": "TMS320F28377D", "6:208": "TMS320F28376D",
            "6:192": "TMS320F28375D", "6:176": "TMS320F28374D",
            // F2838x family (CLASS_ID=0x0A)
            "10:255": "TMS320F28388D", "10:240": "TMS320F28386D",
            "10:224": "TMS320F28384D", "10:208": "TMS320F28383D",
            "10:192": "TMS320F28382D", "10:176": "TMS320F28380D",
            // F28P55x family (CLASS_ID=0x0F) - base name without suffix
            "15:255": "TMS320F28P559", "15:254": "TMS320F28P559",
            "15:240": "TMS320F28P558", "15:239": "TMS320F28P558",
            "15:224": "TMS320F28P557", "15:223": "TMS320F28P557",
            "15:208": "TMS320F28P555", "15:207": "TMS320F28P555",
            "15:192": "TMS320F28P554", "15:191": "TMS320F28P554",
            "15:176": "TMS320F28P553", "15:175": "TMS320F28P553",
            // F28P65x family (CLASS_ID=0x0E)
            // F28P65x has dual-core (D) variants - D is part of base name
            // PARTNO values: 255/254=659, 240/239=658, etc. (pairs for same part)
            "14:255": "TMS320F28P659D", "14:254": "TMS320F28P659D",
            "14:253": "TMS320F28P659D", "14:252": "TMS320F28P659D",
            "14:240": "TMS320F28P658D", "14:239": "TMS320F28P658D",
            "14:238": "TMS320F28P658D", "14:237": "TMS320F28P658D",
            "14:224": "TMS320F28P653D", "14:223": "TMS320F28P653D",
            "14:222": "TMS320F28P653D", "14:221": "TMS320F28P653D",
            "14:208": "TMS320F28P652D", "14:207": "TMS320F28P652D",
            "14:206": "TMS320F28P652D", "14:205": "TMS320F28P652D",
            "14:192": "TMS320F28P651D", "14:191": "TMS320F28P651D",
            "14:190": "TMS320F28P651D", "14:189": "TMS320F28P651D",
            "14:176": "TMS320F28P650D", "14:175": "TMS320F28P650D",
            "14:174": "TMS320F28P650D", "14:173": "TMS320F28P650D",
            // Additional F28P65x values observed on LaunchPads
            "14:160": "TMS320F28P650D", "14:159": "TMS320F28P650D",
            "14:144": "TMS320F28P650D", "14:143": "TMS320F28P650D",
        };
        // Package suffix lookup based on PIN_COUNT
        // PIN_COUNT values from PARTIDL.PIN_COUNT field
        const PACKAGE_SUFFIX = {
            0: "PFB",   // 32-pin TQFP
            1: "PM",    // 48-pin LQFP
            2: "PN",    // 56-pin or 64-pin LQFP (or ZWS for F28P65x BGA)
            3: "PN",    // 64-pin LQFP
            4: "PZ",    // 80-pin LQFP/BGA
            5: "PT",    // 100-pin LQFP
            6: "PTP",   // 176-pin LQFP
            7: "K",     // 337-ball BGA (K for F28P65x)
        };
        // F28P65x-specific package suffix (different from other devices)
        const PACKAGE_SUFFIX_F28P65X = {
            2: "ZWS",   // 169-ball NFBGA
            7: "K",     // 337-ball BGA
        };
        // Map SysConfig device name to CLASS_ID (more reliable than reading PARTIDH on pre-prod silicon)
        const DEVICE_NAME_TO_CLASSID = {
            "F280013x": 12,  // 0x0C
            "F280015x": 7,   // 0x07 (shared with F2807x)
            "F28002x": 9,    // 0x09
            "F28003x": 11,   // 0x0B
            "F28004x": 8,    // 0x08
            "F2807x": 7,     // 0x07
            "F2837xS": 5,    // 0x05
            "F2837xD": 6,    // 0x06
            "F2838x": 10,    // 0x0A
            "F28P55x": 15,   // 0x0F
            "F28P65x": 14,   // 0x0E
        };
        // F28P65x uses different package suffix (K for BGA) and no "S" temperature prefix
        const F28P65X_DEVICES = [14]; // CLASS_ID 0x0E = F28P65x
        try {
            let partno_raw = parseRegValue(await xdsTransport.readValue('DevCfgRegs.PARTIDH.PARTNO'));
            let classid_raw = parseRegValue(await xdsTransport.readValue('DevCfgRegs.PARTIDH.DEVICE_CLASS_ID'));
            let pincount_raw = pinCount;  // Already read earlier

            // Use SysConfig device name to determine CLASS_ID (more reliable than register on pre-prod silicon)
            let classid_sysconfig = DEVICE_NAME_TO_CLASSID["`deviceName`"] || null;
            let classid_effective = classid_sysconfig !== null ? classid_sysconfig : classid_raw;
            if (classid_sysconfig !== null && classid_sysconfig !== classid_raw) {
                cdtWarn("CLASS_ID mismatch: register=" + classid_raw + ", SysConfig=" + classid_sysconfig + " (using SysConfig)");
            }

            let lookupKey = classid_effective + ":" + partno_raw;
            let basePart = PARTNO_LOOKUP[lookupKey];

            // Get package suffix (F28P65x has different suffixes)
            let packageSuffix;
            if (F28P65X_DEVICES.includes(classid_effective)) {
                packageSuffix = PACKAGE_SUFFIX_F28P65X[pincount_raw] || PACKAGE_SUFFIX[pincount_raw] || "";
            } else {
                packageSuffix = PACKAGE_SUFFIX[pincount_raw] || "";
            }

            // Build full part number based on device family
            let fullPartNo = null;
            if (basePart) {
                if (F28P65X_DEVICES.includes(classid_effective)) {
                    // F28P65x: BasePart + Package (e.g., TMS320F28P650DK or TMS320F28P650DZWS)
                    fullPartNo = basePart + packageSuffix;
                } else {
                    // Other devices: BasePart + S (commercial temp) + Package
                    fullPartNo = basePart + "S" + packageSuffix;
                }
            }
            let partnoText = fullPartNo ? fullPartNo : ("Class:" + classid_effective + " PN:" + partno_raw + " (0x" + partno_raw.toString(16).toUpperCase() + ")");
            cdtDebugLog("Part Number: " + partnoText + " (RegClass:" + classid_raw + ", EffClass:" + classid_effective + ", PartNo:" + partno_raw + ", PinCount:" + pincount_raw + ")");
            debugLog('read', 'System:', 'PARTIDH.DEVICE_CLASS_ID (register)', classid_raw);
            debugLog('info', 'System:', 'DEVICE_CLASS_ID (effective)', classid_effective);
            debugLog('read', 'System:', 'PARTIDH.PARTNO', partno_raw);
            debugLog('info', 'System:', 'Lookup Key', lookupKey);
            debugLog('info', 'System:', 'Full Part Number', partnoText);
            if (sysctl_partNumber_value) sysctl_partNumber_value.label = partnoText;
        } catch (e) {
            cdtDebugLog("PARTIDH.PARTNO read failed:", e.message);
            debugLog('error', 'System:', 'PARTIDH.PARTNO read failed', e.message);
            if (sysctl_partNumber_value) sysctl_partNumber_value.label = "N/A";
        }

        // Other system status LEDs (PIE Vector Error, feature flags, etc.)
        % for (var exportInfo of sysctlExports.exportsInfo) {
            % if (exportInfo.type === 'led' && exportInfo.applicable(null) && exportInfo.name !== 'tapStatus'){
                % let isFeatureLed = exportInfo.ledType === 'feature';
                % // Handle dynamic register paths for device features
                % let xdsPath = null;
                % if (exportInfo.getRegister) {
                    % // Dynamic register path based on device
                    % xdsPath = exportInfo.getRegister(deviceName);
                % } else if (exportInfo.register) {
                    % // Static register path
                    % let bitfieldRegsName = sysctlExports.bitfieldInstanceNames[exportInfo.bitfieldInstance]("");
                    % xdsPath = bitfieldRegsName + "." + exportInfo.register;
                % }
                % if (xdsPath) {
        // `exportInfo.displayName` - register: `xdsPath`
        try {
            let `exportInfo.name`_val = parseRegValue(await xdsTransport.readValue('`xdsPath`'));
            cdtDebugLog("`exportInfo.displayName`: " + `exportInfo.name`_val);
            if (sysctl_`exportInfo.name`_led) {
                    % if (isFeatureLed) {
                // Feature LED: green when present, grey when not
                setLedActive(sysctl_`exportInfo.name`_led, `exportInfo.name`_val);
                    % } else {
                // Error/status LED: red when active (error), green when inactive (ok)
                setLedError(sysctl_`exportInfo.name`_led, `exportInfo.name`_val);
                    % }
            }
        } catch (e) {
            // Register read failed - hide the LED container
            let container = document.getElementById('sysctl_`exportInfo.name`');
            if (container) container.style.display = 'none';
        }
                % } else if (isFeatureLed) {
        // `exportInfo.displayName` - no register for this device, show as hardware feature
        // Feature is present based on device feature matrix (no runtime register to check)
        cdtDebugLog("`exportInfo.displayName`: Hardware feature present (no runtime register)");
        setLedActive(sysctl_`exportInfo.name`_led, true);
                % }
            % }
        % }

        // Extract and display raw DIE_ID / UID register values
        await extractDieIdUid();

        cdtDebugLog("[CDT] <<< systemUpdate() EXIT (success)");
    } catch (error) {
        cdtError("[CDT] systemUpdate() failed:", error?.message || String(error));
        showToast('System update failed: ' + (error?.message || 'Unknown error'), 'error');
    }
}

function systemReset() {

    % // Reset text type entries
    % for (var exportInfo of sysctlExports.exportsInfo) {
        % if (exportInfo.type === 'text' && exportInfo.applicable(null)){
    if (sysctl_`exportInfo.name`_value) sysctl_`exportInfo.name`_value.label = "--";
        % }
    % }
    % // Reset LED type entries
    % for (var exportInfo of sysctlExports.exportsInfo) {
        % if (exportInfo.type === 'led' && exportInfo.applicable(null)){
    setLedDisabled(sysctl_`exportInfo.name`_led);
        % }
    % }

    // Reset DIE ID / UID expandable section
    ['die_id_dieid0_value', 'die_id_dieid1_value', 'die_id_dieid2_value',
     'die_id_dieid3_value', 'die_id_partid_value', 'die_id_uid_value',
     'die_id_uid128_value'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = '--';
    });
    const copyBtn = document.getElementById('die_uid_copy_btn');
    if (copyBtn) { copyBtn.textContent = 'copy'; copyBtn.classList.remove('copied'); }

}

//=============================================================================
// Interrupt Panel Update/Reset Functions
//=============================================================================
% let interruptExports = system.getScript(transferCommon.getTransferPath() + "export/mods/export_mod_interrupt.js");

// Interrupt LED variables
% for (var exportInfo of interruptExports.exportsInfo) {
    % if (exportInfo.type === 'led' && exportInfo.applicable(null)){
var interrupt_`exportInfo.name`_led;
    % }
% }

// PIE register data cache
let pieData = {
    ier: new Array(13).fill(0),  // PIEIER1-12 (index 1-12)
    ifr: new Array(13).fill(0),  // PIEIFR1-12 (index 1-12)
    ack: 0
};

// PIE interrupt name mapping for display
const PIE_VECTOR_TABLE = {
    1: { 1: "ADCA1", 2: "ADCB1", 3: "ADCC1", 4: "XINT1", 5: "XINT2", 6: "ADCD1", 7: "TMR0", 8: "WAKE" },
    2: { 1: "TZ1", 2: "TZ2", 3: "TZ3", 4: "TZ4", 5: "TZ5", 6: "TZ6", 7: "TZ7", 8: "TZ8" },
    3: { 1: "PWM1", 2: "PWM2", 3: "PWM3", 4: "PWM4", 5: "PWM5", 6: "PWM6", 7: "PWM7", 8: "PWM8" },
    4: { 1: "CAP1", 2: "CAP2", 3: "CAP3", 4: "CAP4", 5: "CAP5", 6: "CAP6", 7: "CAP7" },
    5: { 1: "QEP1", 2: "QEP2", 3: "QEP3", 5: "CLB1", 6: "CLB2", 7: "CLB3", 8: "CLB4" },
    6: { 1: "SPIRXA", 2: "SPITXA", 3: "SPIRXB", 4: "SPITXB", 5: "SPIRXC", 6: "SPITXC" },
    7: { 1: "DMA1", 2: "DMA2", 3: "DMA3", 4: "DMA4", 5: "DMA5", 6: "DMA6" },
    8: { 1: "I2CA", 2: "I2CAF", 3: "I2CB", 4: "I2CBF", 5: "LINA0", 6: "LINA1", 7: "LINB0", 8: "LINB1" },
    9: { 1: "SCIRXA", 2: "SCITXA", 3: "SCIRXB", 4: "SCITXB", 5: "CANA0", 6: "CANA1", 7: "CANB0", 8: "CANB1" },
    10: { 1: "ADCAEV", 2: "ADCA2", 3: "ADCA3", 4: "ADCA4", 5: "ADCBEV", 6: "ADCB2", 7: "ADCB3", 8: "ADCB4" },
    11: { 1: "CLA1", 2: "CLA2", 3: "CLA3", 4: "CLA4", 5: "CLA5", 6: "CLA6", 7: "CLA7", 8: "CLA8" },
    12: { 1: "XINT3", 2: "XINT4", 3: "XINT5", 5: "FMC", 7: "FPUOVF", 8: "FPUUNF" }
};

function getPieIntName(group, channel) {
    const groupMap = PIE_VECTOR_TABLE[group];
    if (groupMap && groupMap[channel]) {
        return groupMap[channel];
    }
    return "INT" + group + "." + channel;
}

function countBits(value) {
    let count = 0;
    value = value & 0xFFFF;
    while (value) {
        count += value & 1;
        value >>>= 1;
    }
    return count;
}

async function interruptUpdate() {
    cdtDebugLog("[CDT] >>> interruptUpdate() ENTER");
    try {
        // Check if XDS transport is connected
        if (!xdsTransport || xdsTransport.state !== 'connected') {
            cdtWarn("interruptUpdate() skipped - XDS transport not connected");
            return;
        }

        // Helper to wrap XDS reads with timeout to prevent hanging
        const readWithTimeout = (regPath, timeoutMs = 2000) => {
            return new Promise((resolve, reject) => {
                const timer = setTimeout(() => {
                    reject(new Error('Timeout'));
                }, timeoutMs);

                xdsTransport.readValue(regPath)
                    .then(val => { clearTimeout(timer); resolve(val); })
                    .catch(e => { clearTimeout(timer); reject(e); });
            });
        };

        // Read NMI status registers with timeout protection
        % for (var exportInfo of interruptExports.exportsInfo) {
            % if (exportInfo.type === 'led' && exportInfo.applicable(null)){
                % let regPath = interruptExports.bitfieldInstanceNames[exportInfo.bitfieldInstance]("") + "." + exportInfo.register;
        try {
            let `exportInfo.name`_raw = await readWithTimeout('`regPath`');
            let `exportInfo.name`_value = parseRegValue(`exportInfo.name`_raw);
            % if (exportInfo.name === 'pieEnable') {
            // PIE Enabled: Green when enabled (1), Grey when disabled (0)
            let `exportInfo.name` = (`exportInfo.name`_value & `exportInfo.bitMask`) !== 0;
            setLedActive(interrupt_`exportInfo.name`_led, `exportInfo.name`);
            // Also update the overview LED
            let overviewLed = document.getElementById('pie_overview_enabled_led');
            if (overviewLed) setLedActive(overviewLed, `exportInfo.name`);
            % } else if (exportInfo.name === 'pieack') {
            // PIE ACK: Store for later use
            pieData.ack = `exportInfo.name`_value & `exportInfo.bitMask`;
            % } else if (exportInfo.ledColor === 'warning') {
            // Warning LEDs (like NMI Watchdog Active): Orange when active, Gray when inactive
            let `exportInfo.name` = (`exportInfo.name`_value & `exportInfo.bitMask`) !== 0;
            setLedPending(interrupt_`exportInfo.name`_led, `exportInfo.name`);
            % } else {
            // Error flags: Green when clear (0), Red when set (1)
            let `exportInfo.name` = (`exportInfo.name`_value & `exportInfo.bitMask`) !== 0;
            setLedError(interrupt_`exportInfo.name`_led, `exportInfo.name`);
            % }
        } catch (e) {
            // Register read failed or timed out - hide the LED container
            let container = document.getElementById('interrupt_`exportInfo.name`');
            if (container) container.style.display = 'none';
        }
            % }
        % }

        // Read PIE IER and IFR registers for all 12 groups
        for (let g = 1; g <= 12; g++) {
            try {
                const ierVal = await readWithTimeout('PieCtrlRegs.PIEIER' + g);
                pieData.ier[g] = parseRegValue(ierVal);
            } catch (e) {
                pieData.ier[g] = 0;
            }

            try {
                const ifrVal = await readWithTimeout('PieCtrlRegs.PIEIFR' + g);
                pieData.ifr[g] = parseRegValue(ifrVal);
            } catch (e) {
                pieData.ifr[g] = 0;
            }
        }

        // Update PIE group summaries
        updatePieGroupSummaries();

        // Update active interrupts list
        updateActiveInterruptsList();

        cdtDebugLog("[CDT] <<< interruptUpdate() EXIT (success)");
    } catch (error) {
        cdtError("[CDT] interruptUpdate() failed:", error?.message || String(error));
        showToast('Interrupt update failed: ' + (error?.message || 'Unknown error'), 'error');
    }
}

function updatePieGroupSummaries() {
    let totalEnabled = 0;
    let totalPending = 0;

    for (let g = 1; g <= 12; g++) {
        const ier = pieData.ier[g] || 0;
        const ifr = pieData.ifr[g] || 0;
        const enabledCount = countBits(ier);
        const pendingCount = countBits(ifr & ier);  // Only count if both enabled AND pending

        totalEnabled += enabledCount;
        totalPending += pendingCount;

        // Update group card UI
        const enabledSpan = document.getElementById('pie_group_' + g + '_enabled');
        const pendingSpan = document.getElementById('pie_group_' + g + '_pending');
        const groupCard = document.getElementById('pie_group_' + g + '_card');
        const groupLed = document.getElementById('pie_group_' + g + '_led');

        if (enabledSpan) enabledSpan.textContent = enabledCount;
        if (pendingSpan) pendingSpan.textContent = pendingCount;

        // Highlight card if any pending
        if (groupCard) {
            if (pendingCount > 0) {
                groupCard.classList.add('has_pending');
            } else {
                groupCard.classList.remove('has_pending');
            }
        }

        // Set LED: Yellow=pending, Green=enabled, Gray=none
        if (groupLed) {
            if (pendingCount > 0) {
                setLedWarning(groupLed, true);
            } else if (enabledCount > 0) {
                setLedActive(groupLed, true);
            } else {
                setLedDisabled(groupLed);
            }
        }
    }

    // Update total counts
    const totalEnabledSpan = document.getElementById('pie_total_enabled');
    const totalPendingSpan = document.getElementById('pie_total_pending');
    if (totalEnabledSpan) totalEnabledSpan.textContent = totalEnabled;
    if (totalPendingSpan) totalPendingSpan.textContent = totalPending;
}

function updateActiveInterruptsList() {
    const listContainer = document.getElementById('pie_active_list');
    const emptyMessage = document.getElementById('pie_active_empty');
    if (!listContainer) return;

    // Clear existing badges
    while (listContainer.firstChild) {
        listContainer.removeChild(listContainer.firstChild);
    }

    const activeInterrupts = [];

    // Find all pending and enabled interrupts
    for (let g = 1; g <= 12; g++) {
        const ier = pieData.ier[g] || 0;
        const ifr = pieData.ifr[g] || 0;
        const pending = ifr & ier;  // Only show if both pending AND enabled

        for (let ch = 1; ch <= 16; ch++) {
            if (pending & (1 << (ch - 1))) {
                activeInterrupts.push({
                    group: g,
                    channel: ch,
                    name: getPieIntName(g, ch)
                });
            }
        }
    }

    // Show/hide empty message
    if (emptyMessage) {
        emptyMessage.style.display = activeInterrupts.length === 0 ? 'block' : 'none';
    }

    // Create badges for active interrupts
    activeInterrupts.forEach(int => {
        const badge = document.createElement('div');
        badge.className = 'pie_active_badge';
        badge.title = int.name + ' (Group ' + int.group + ', Channel ' + int.channel + ')';

        const nameSpan = document.createElement('span');
        nameSpan.textContent = int.name;
        badge.appendChild(nameSpan);

        const locSpan = document.createElement('span');
        locSpan.className = 'pie_int_loc';
        locSpan.textContent = '(' + int.group + '.' + int.channel + ')';
        badge.appendChild(locSpan);

        listContainer.appendChild(badge);
    });
}

function interruptReset() {

    % for (var exportInfo of interruptExports.exportsInfo) {
        % if (exportInfo.type === 'led' && exportInfo.applicable(null)){
    setLedDisabled(interrupt_`exportInfo.name`_led);
        % }
    % }

    // Reset PIE overview LED
    let overviewLed = document.getElementById('pie_overview_enabled_led');
    if (overviewLed) setLedDisabled(overviewLed);

    // Reset PIE group cards
    for (let g = 1; g <= 12; g++) {
        let enabledSpan = document.getElementById('pie_group_' + g + '_enabled');
        let pendingSpan = document.getElementById('pie_group_' + g + '_pending');
        let groupCard = document.getElementById('pie_group_' + g + '_card');
        let groupLed = document.getElementById('pie_group_' + g + '_led');

        if (enabledSpan) enabledSpan.textContent = '0';
        if (pendingSpan) pendingSpan.textContent = '0';
        if (groupCard) groupCard.classList.remove('has_pending');
        if (groupLed) setLedDisabled(groupLed);
    }

    // Reset total counts
    let totalEnabledSpan = document.getElementById('pie_total_enabled');
    let totalPendingSpan = document.getElementById('pie_total_pending');
    if (totalEnabledSpan) totalEnabledSpan.textContent = '--';
    if (totalPendingSpan) totalPendingSpan.textContent = '--';

    // Clear active interrupts list
    let listContainer = document.getElementById('pie_active_list');
    let emptyMessage = document.getElementById('pie_active_empty');
    if (listContainer) {
        while (listContainer.firstChild) {
            listContainer.removeChild(listContainer.firstChild);
        }
    }
    if (emptyMessage) emptyMessage.style.display = 'block';


}

//=============================================================================
// Memory Panel Update/Reset Functions
//=============================================================================
// Note: memoryExports and deviceMem are defined earlier in the template

async function memoryUpdate() {
    cdtDebugLog("[CDT] >>> memoryUpdate() ENTER");
    try {
        // Check if XDS transport is connected
        if (!xdsTransport || xdsTransport.state !== 'connected') {
            cdtWarn("memoryUpdate() skipped - XDS transport not connected");
            return;
        }
        // Memory capacity bars are populated statically from template
        // Flash: `deviceMem.flash` KB, RAM: `deviceMem.ram` KB
        cdtDebugLog("Memory capacity - Flash: `deviceMem.flash` KB, RAM: `deviceMem.ram` KB");

        // Read memory error flags
        % for (var exportInfo of memoryExports.exportsInfo) {
            % if (exportInfo.type === 'led' && exportInfo.applicable(null)){
                % let bitfieldRegsName = memoryExports.bitfieldInstanceNames[exportInfo.bitfieldInstance]("");
                % let xdsPath = bitfieldRegsName + "." + exportInfo.register;
        try {
            let `exportInfo.name`_val = parseRegValue(await xdsTransport.readValue('`xdsPath`'));
            cdtDebugLog("`exportInfo.displayName`: " + `exportInfo.name`_val);
            if (memory_`exportInfo.name`_led) {
                // Red if error flag set, green if clear
                setLedError(memory_`exportInfo.name`_led, `exportInfo.name`_val);
            }
        } catch (e) {
            // Register read failed - hide the LED container
            let container = document.getElementById('memory_`exportInfo.name`');
            if (container) container.style.display = 'none';
        }
            % }
        % }
        cdtDebugLog("[CDT] <<< memoryUpdate() EXIT (success)");
    } catch (error) {
        cdtError("[CDT] memoryUpdate() failed:", error?.message || String(error));
        showToast('Memory update failed: ' + (error?.message || 'Unknown error'), 'error');
    }
}

function memoryReset() {

    // Reset memory error flag LEDs
    % for (var exportInfo of memoryExports.exportsInfo) {
        % if (exportInfo.type === 'led' && exportInfo.applicable(null)){
    setLedDisabled(memory_`exportInfo.name`_led);
        % }
    % }
    // Reset memory bars to default state
    resetMemoryBars();

}

//=============================================================================
// Memory Map File Parsing and Display
//=============================================================================

// Device memory totals (from template)
const DEVICE_FLASH_KB = `deviceMem.flash`;
const DEVICE_RAM_KB = `deviceMem.ram`;

// Parsed map file data storage
var mapFileData = null;

/**
 * Parse C2000 linker .map file content
 * @param {string} content - Raw .map file text
 * @returns {object} Parsed memory regions and section data
 */
function parseMapFile(content) {
    const result = {
        memoryRegions: [],
        sections: {},
        flashUsed: 0,
        ramUsed: 0,
        flashSections: { text: 0, const: 0, other: 0 },
        ramSections: { data: 0, bss: 0, stack: 0, other: 0 }
    };

    const lines = content.split('\n');
    let inMemoryConfig = false;
    let inSectionAlloc = false;

    for (let i = 0; i < lines.length; i++) {
        const line = lines[i];
        const trimmed = line.trim();

        // Detect section headers
        if (trimmed === 'MEMORY CONFIGURATION') {
            inMemoryConfig = true;
            inSectionAlloc = false;
            continue;
        }
        if (trimmed === 'SECTION ALLOCATION MAP') {
            inMemoryConfig = false;
            inSectionAlloc = true;
            continue;
        }
        if (trimmed === 'MODULE SUMMARY' || trimmed.startsWith('GLOBAL SYMBOLS')) {
            inMemoryConfig = false;
            inSectionAlloc = false;
            continue;
        }

        // Parse MEMORY CONFIGURATION lines
        // Format: name origin length used unused attr [fill]
        if (inMemoryConfig && trimmed.length > 0 && !trimmed.startsWith('name') && !trimmed.startsWith('-')) {
            const match = trimmed.match(/^(\S+)\s+([0-9a-fA-F]+)\s+([0-9a-fA-F]+)\s+([0-9a-fA-F]+)\s+([0-9a-fA-F]+)\s+(\S+)/);
            if (match) {
                const region = {
                    name: match[1],
                    origin: parseInt(match[2], 16),
                    length: parseInt(match[3], 16),
                    used: parseInt(match[4], 16),
                    unused: parseInt(match[5], 16),
                    attr: match[6]
                };
                result.memoryRegions.push(region);

                // Classify as Flash or RAM based on region name and address
                const nameUpper = region.name.toUpperCase();
                if (nameUpper.includes('FLASH') || nameUpper.includes('BEGIN') ||
                    (region.origin >= 0x80000 && !nameUpper.includes('RAM'))) {
                    result.flashUsed += region.used;
                } else if (nameUpper.includes('RAM') || nameUpper.includes('STACK') ||
                           nameUpper.includes('BSS') || region.origin < 0x20000) {
                    result.ramUsed += region.used;
                }
            }
        }

        // Parse SECTION ALLOCATION MAP lines
        // Look for section entries like: .text 0 00080000 00020000
        if (inSectionAlloc && trimmed.length > 0) {
            const sectionMatch = trimmed.match(/^\.(\S+)\s+(\d)\s+([0-9a-fA-F]+)\s+([0-9a-fA-F]+)/);
            if (sectionMatch) {
                const sectionName = sectionMatch[1];
                const page = parseInt(sectionMatch[2]);
                const origin = parseInt(sectionMatch[3], 16);
                const length = parseInt(sectionMatch[4], 16);

                // Get base section name (handle .text.1, .text.2, etc.)
                const baseName = sectionName.split('.')[0];

                // Accumulate section sizes
                if (!result.sections[baseName]) {
                    result.sections[baseName] = 0;
                }
                result.sections[baseName] += length;

                // Categorize for display based on section name
                if (baseName === 'text' || baseName.startsWith('text')) {
                    result.flashSections.text += length;
                } else if (baseName === 'const' || baseName === 'cinit' || baseName === 'switch') {
                    result.flashSections.const += length;
                } else if (baseName === 'data' || baseName === 'init') {
                    result.ramSections.data += length;
                } else if (baseName === 'bss' || baseName === 'ebss') {
                    result.ramSections.bss += length;
                } else if (baseName === 'stack' || baseName === 'sysmem') {
                    result.ramSections.stack += length;
                } else if (page === 0 || origin >= 0x80000) {
                    // Page 0 or high address = Flash
                    result.flashSections.other += length;
                } else {
                    // Page 1 or low address = RAM
                    result.ramSections.other += length;
                }
            }
        }
    }

    return result;
}

/**
 * Handle .map file selection
 * @param {HTMLInputElement} input - File input element
 */
window.cdtLoadMapFile = function(input) {
    const file = input.files[0];
    if (!file) return;

    cdtDebugLog("[CDT] Loading .map file:", file.name);

    const reader = new FileReader();
    reader.onload = function(e) {
        try {
            const content = e.target.result;
            mapFileData = parseMapFile(content);
            mapFileData.filename = file.name;
            mapFileData.timestamp = Date.now();

            // Save to localStorage for persistence
            try {
                localStorage.setItem('cdtMapFileData', JSON.stringify(mapFileData));
            } catch (storageErr) {
                console.warn("[CDT] Could not save to localStorage:", storageErr);
            }

            // Update UI
            updateMemoryBarsFromMap(mapFileData);

            // Update file label
            const fileLabel = document.getElementById('memory_file_label');
            const clearBtn = document.getElementById('memory_clear_btn');
            if (fileLabel) {
                fileLabel.textContent = file.name;
                fileLabel.title = file.name;
            }
            if (clearBtn) {
                clearBtn.style.display = 'inline-block';
            }

            cdtDebugLog("[CDT] Map file loaded successfully:", mapFileData);
        } catch (err) {
            console.error("[CDT] Error parsing .map file:", err);
            alert('Error parsing .map file: ' + err.message);
        }
    };
    reader.onerror = function() {
        console.error("[CDT] Error reading file");
        alert('Error reading file');
    };
    reader.readAsText(file);

    // Reset input so same file can be loaded again
    input.value = '';
};

/**
 * Clear loaded .map file data
 */
window.cdtClearMapFile = function() {
    cdtDebugLog("[CDT] Clear Map File button clicked");
    mapFileData = null;
    try {
        localStorage.removeItem('cdtMapFileData');
    } catch (e) {
        cdtWarn("Could not clear localStorage: " + (e ? e.message : "unknown error"));
    }

    // Reset to default display
    resetMemoryBars();

    // Update UI
    const fileLabel = document.getElementById('memory_file_label');
    const clearBtn = document.getElementById('memory_clear_btn');
    if (fileLabel) {
        fileLabel.textContent = 'No file loaded';
        fileLabel.title = 'No file loaded';
    }
    if (clearBtn) {
        clearBtn.style.display = 'none';
    }

    cdtDebugLog("[CDT] Map file cleared");
};

/**
 * Update memory bars based on parsed .map data
 * @param {object} mapData - Parsed map file data
 */
function updateMemoryBarsFromMap(mapData) {
    const flashTotal = DEVICE_FLASH_KB * 1024; // Convert KB to bytes
    const ramTotal = DEVICE_RAM_KB * 1024;

    // Calculate Flash usage
    const flashTextBytes = mapData.flashSections.text || 0;
    const flashConstBytes = mapData.flashSections.const || 0;
    const flashOtherBytes = mapData.flashSections.other || 0;
    const flashUsedBytes = flashTextBytes + flashConstBytes + flashOtherBytes;

    // Calculate percentages for Flash (cap at 100%)
    const flashTextPct = Math.min((flashTextBytes / flashTotal) * 100, 100);
    const flashConstPct = Math.min((flashConstBytes / flashTotal) * 100, 100 - flashTextPct);
    const flashOtherPct = Math.min((flashOtherBytes / flashTotal) * 100, 100 - flashTextPct - flashConstPct);

    // Update Flash bar segments
    const flashTextSeg = document.getElementById('flash_seg_text');
    const flashConstSeg = document.getElementById('flash_seg_const');
    const flashOtherSeg = document.getElementById('flash_seg_other');
    if (flashTextSeg) flashTextSeg.style.width = flashTextPct + '%';
    if (flashConstSeg) flashConstSeg.style.width = flashConstPct + '%';
    if (flashOtherSeg) flashOtherSeg.style.width = flashOtherPct + '%';

    // Update Flash size label
    const flashUsedKB = (flashUsedBytes / 1024).toFixed(1);
    const flashSizeLabel = document.getElementById('page_memory_flash_size');
    if (flashSizeLabel) {
        flashSizeLabel.textContent = flashUsedKB + ' / ' + DEVICE_FLASH_KB + ' KB';
    }

    // Update Flash breakdown values (exact + friendly format)
    const flashTextSize = document.getElementById('flash_text_size');
    const flashConstSize = document.getElementById('flash_const_size');
    const flashBreakdown = document.getElementById('flash_breakdown');
    if (flashTextSize) flashTextSize.textContent = formatMemoryBytesDetailed(flashTextBytes);
    if (flashConstSize) flashConstSize.textContent = formatMemoryBytesDetailed(flashConstBytes);
    if (flashBreakdown) flashBreakdown.style.display = 'block';

    // Update Flash tooltip with exact + friendly values
    const flashWrapper = document.getElementById('page_memory_flash_wrapper');
    if (flashWrapper) {
        const flashUsedPct = ((flashUsedBytes / flashTotal) * 100).toFixed(1);
        flashWrapper.title = 'Flash: ' + flashUsedBytes.toLocaleString() + ' bytes (' + flashUsedKB + ' KB) of ' + DEVICE_FLASH_KB + ' KB (' + flashUsedPct + '%)';
    }

    // Calculate RAM usage
    const ramDataBytes = mapData.ramSections.data || 0;
    const ramBssBytes = mapData.ramSections.bss || 0;
    const ramStackBytes = mapData.ramSections.stack || 0;
    const ramOtherBytes = mapData.ramSections.other || 0;
    const ramUsedBytes = ramDataBytes + ramBssBytes + ramStackBytes + ramOtherBytes;

    // Calculate percentages for RAM (cap at 100%)
    const ramDataPct = Math.min((ramDataBytes / ramTotal) * 100, 100);
    const ramBssPct = Math.min((ramBssBytes / ramTotal) * 100, 100 - ramDataPct);
    const ramStackPct = Math.min((ramStackBytes / ramTotal) * 100, 100 - ramDataPct - ramBssPct);
    const ramOtherPct = Math.min((ramOtherBytes / ramTotal) * 100, 100 - ramDataPct - ramBssPct - ramStackPct);

    // Update RAM bar segments
    const ramDataSeg = document.getElementById('ram_seg_data');
    const ramBssSeg = document.getElementById('ram_seg_bss');
    const ramStackSeg = document.getElementById('ram_seg_stack');
    const ramOtherSeg = document.getElementById('ram_seg_other');
    if (ramDataSeg) ramDataSeg.style.width = ramDataPct + '%';
    if (ramBssSeg) ramBssSeg.style.width = ramBssPct + '%';
    if (ramStackSeg) ramStackSeg.style.width = ramStackPct + '%';
    if (ramOtherSeg) ramOtherSeg.style.width = ramOtherPct + '%';

    // Update RAM size label
    const ramUsedKB = (ramUsedBytes / 1024).toFixed(1);
    const ramSizeLabel = document.getElementById('page_memory_ram_size');
    if (ramSizeLabel) {
        ramSizeLabel.textContent = ramUsedKB + ' / ' + DEVICE_RAM_KB + ' KB';
    }

    // Update RAM breakdown values (exact + friendly format)
    const ramDataSize = document.getElementById('ram_data_size');
    const ramBssSize = document.getElementById('ram_bss_size');
    const ramStackSize = document.getElementById('ram_stack_size');
    const ramBreakdown = document.getElementById('ram_breakdown');
    if (ramDataSize) ramDataSize.textContent = formatMemoryBytesDetailed(ramDataBytes);
    if (ramBssSize) ramBssSize.textContent = formatMemoryBytesDetailed(ramBssBytes);
    if (ramStackSize) ramStackSize.textContent = formatMemoryBytesDetailed(ramStackBytes);
    if (ramBreakdown) ramBreakdown.style.display = 'block';

    // Update RAM tooltip with exact + friendly values
    const ramWrapper = document.getElementById('page_memory_ram_wrapper');
    if (ramWrapper) {
        const ramUsedPct = ((ramUsedBytes / ramTotal) * 100).toFixed(1);
        ramWrapper.title = 'RAM: ' + ramUsedBytes.toLocaleString() + ' bytes (' + ramUsedKB + ' KB) of ' + DEVICE_RAM_KB + ' KB (' + ramUsedPct + '%)';
    }

    // === EXPANDED BARS ===
    // Show the used portion at 100% width for better visibility when usage is small

    // Flash expanded bar - percentages relative to USED portion (not total)
    if (flashUsedBytes > 0) {
        const flashExpTextPct = (flashTextBytes / flashUsedBytes) * 100;
        const flashExpConstPct = (flashConstBytes / flashUsedBytes) * 100;
        const flashExpOtherPct = (flashOtherBytes / flashUsedBytes) * 100;

        const flashExpText = document.getElementById('flash_exp_text');
        const flashExpConst = document.getElementById('flash_exp_const');
        const flashExpOther = document.getElementById('flash_exp_other');
        if (flashExpText) flashExpText.style.width = flashExpTextPct + '%';
        if (flashExpConst) flashExpConst.style.width = flashExpConstPct + '%';
        if (flashExpOther) flashExpOther.style.width = flashExpOtherPct + '%';

        const flashExpTotal = document.getElementById('flash_expanded_total');
        if (flashExpTotal) flashExpTotal.textContent = formatMemoryBytesDetailed(flashUsedBytes) + ' Used';

        const flashExpSection = document.getElementById('flash_expanded_section');
        if (flashExpSection) flashExpSection.style.display = 'block';
    }

    // RAM expanded bar - percentages relative to USED portion (not total)
    if (ramUsedBytes > 0) {
        const ramExpDataPct = (ramDataBytes / ramUsedBytes) * 100;
        const ramExpBssPct = (ramBssBytes / ramUsedBytes) * 100;
        const ramExpStackPct = (ramStackBytes / ramUsedBytes) * 100;
        const ramExpOtherPct = (ramOtherBytes / ramUsedBytes) * 100;

        const ramExpData = document.getElementById('ram_exp_data');
        const ramExpBss = document.getElementById('ram_exp_bss');
        const ramExpStack = document.getElementById('ram_exp_stack');
        const ramExpOther = document.getElementById('ram_exp_other');
        if (ramExpData) ramExpData.style.width = ramExpDataPct + '%';
        if (ramExpBss) ramExpBss.style.width = ramExpBssPct + '%';
        if (ramExpStack) ramExpStack.style.width = ramExpStackPct + '%';
        if (ramExpOther) ramExpOther.style.width = ramExpOtherPct + '%';

        const ramExpTotal = document.getElementById('ram_expanded_total');
        if (ramExpTotal) ramExpTotal.textContent = formatMemoryBytesDetailed(ramUsedBytes) + ' Used';

        const ramExpSection = document.getElementById('ram_expanded_section');
        if (ramExpSection) ramExpSection.style.display = 'block';
    }
}

/**
 * Reset memory bars to default state (no .map loaded)
 */
function resetMemoryBars() {
    // Reset Flash segments to 0
    const flashSegs = ['flash_seg_text', 'flash_seg_const', 'flash_seg_other'];
    flashSegs.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.width = '0%';
    });

    // Reset RAM segments to 0
    const ramSegs = ['ram_seg_data', 'ram_seg_bss', 'ram_seg_stack', 'ram_seg_other'];
    ramSegs.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.width = '0%';
    });

    // Reset labels to device total
    const flashSizeLabel = document.getElementById('page_memory_flash_size');
    const ramSizeLabel = document.getElementById('page_memory_ram_size');
    if (flashSizeLabel) flashSizeLabel.textContent = DEVICE_FLASH_KB + ' KB';
    if (ramSizeLabel) ramSizeLabel.textContent = DEVICE_RAM_KB + ' KB';

    // Hide breakdowns
    const flashBreakdown = document.getElementById('flash_breakdown');
    const ramBreakdown = document.getElementById('ram_breakdown');
    if (flashBreakdown) flashBreakdown.style.display = 'none';
    if (ramBreakdown) ramBreakdown.style.display = 'none';

    // Hide and reset expanded bars
    const flashExpSection = document.getElementById('flash_expanded_section');
    const ramExpSection = document.getElementById('ram_expanded_section');
    if (flashExpSection) flashExpSection.style.display = 'none';
    if (ramExpSection) ramExpSection.style.display = 'none';

    // Reset expanded total labels
    const flashExpTotal = document.getElementById('flash_expanded_total');
    const ramExpTotal = document.getElementById('ram_expanded_total');
    if (flashExpTotal) flashExpTotal.textContent = formatMemoryBytes(0) + ' Used';
    if (ramExpTotal) ramExpTotal.textContent = formatMemoryBytes(0) + ' Used';

    // Reset expanded bar segments
    const flashExpSegs = ['flash_exp_text', 'flash_exp_const', 'flash_exp_other'];
    flashExpSegs.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.width = '0%';
    });
    const ramExpSegs = ['ram_exp_data', 'ram_exp_bss', 'ram_exp_stack', 'ram_exp_other'];
    ramExpSegs.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.width = '0%';
    });

    // Reset tooltips
    const flashWrapper = document.getElementById('page_memory_flash_wrapper');
    const ramWrapper = document.getElementById('page_memory_ram_wrapper');
    if (flashWrapper) {
        flashWrapper.title = 'Flash Memory: ' + DEVICE_FLASH_KB + ' KB total\n\nLoad a .map file to see usage breakdown.';
    }
    if (ramWrapper) {
        ramWrapper.title = 'RAM Memory: ' + DEVICE_RAM_KB + ' KB total\n\nLoad a .map file to see usage breakdown.';
    }
}

/**
 * Format bytes to human-readable string
 * @param {number} bytes - Size in bytes
 * @returns {string} Formatted size (e.g., "12.3 KB")
 */
function formatMemoryBytes(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
}

/**
 * Format memory bytes with both exact and friendly versions
 * @param {number} bytes - Number of bytes
 * @returns {string} - Format: "exact bytes (friendly)" e.g., "45,678 bytes (44.61 KB)"
 */
function formatMemoryBytesDetailed(bytes) {
    const exactStr = bytes.toLocaleString() + ' bytes';
    const friendlyStr = formatMemoryBytes(bytes);
    // If friendly is just bytes, don't duplicate
    if (bytes < 1024) return exactStr;
    return exactStr + ' (' + friendlyStr + ')';
}

/**
 * Restore .map file data from localStorage on page load
 */
function restoreMapFileData() {
    try {
        const saved = localStorage.getItem('cdtMapFileData');
        if (saved) {
            mapFileData = JSON.parse(saved);
            cdtDebugLog("[CDT] Restored .map file data:", mapFileData.filename);

            // Update UI with restored data
            updateMemoryBarsFromMap(mapFileData);

            const fileLabel = document.getElementById('memory_file_label');
            const clearBtn = document.getElementById('memory_clear_btn');
            if (fileLabel) {
                fileLabel.textContent = mapFileData.filename;
                fileLabel.title = mapFileData.filename;
            }
            if (clearBtn) {
                clearBtn.style.display = 'inline-block';
            }
        }
    } catch (e) {
        console.warn("[CDT] Error restoring .map file data:", e);
        try {
            localStorage.removeItem('cdtMapFileData');
        } catch (e2) { cdtWarn("[CDT] localStorage cleanup failed:", e2); }
    }
}


//=============================================================================
// Package pin configurations - inlined from package_configs.js.xdt
//=============================================================================
% let packageConfigsTemplate = system.getTemplate(transferCommon.getTransferPath() + "gui/package_configs.js.xdt");
`packageConfigsTemplate()`

// Default package configurations (fallback)
const PACKAGE_CONFIGS = DEVICE_PACKAGE_CONFIGS['`deviceName`'] || DEVICE_PACKAGE_CONFIGS['F280015x'];

// GPIO pins that are fixed-function (switching regulator) when AMSEL=1, not analog ADC
// These pins show as "Fixed" instead of "Analog" when their AMSEL bit is set
// Only F28004x has DC-DC regulator on GPIO22 (VFBSW) and GPIO23 (VSW)
const FIXED_FUNCTION_AMSEL_GPIOS = '`deviceName`' === 'F28004x' ? [22, 23] : [];

// Pinmux state storage - holds live register data
let pinmuxState = {
    packagePins: 0,  // 0 = not yet detected (will be set from PARTIDL register)
    packageName: '',
    gpioUsed: 0,
    gpioTotal: 52,
    debuggerConnected: false,  // DCON status from TAP_STATUS register
    // Detailed pin counts by category
    counts: {
        gpioInput: 0,      // GPIO mode, DIR=0 (input)
        gpioOutput: 0,     // GPIO mode, DIR=1 (output)
        periphInput: 0,    // Peripheral mode, DAT reflects input state
        periphOutput: 0,   // Peripheral mode (peripheral controls direction)
        jtag: 0,           // JTAG pins (TDI, TDO, TMS, TCK)
        power: 0,          // Power supply pins (VDD, VDDA, etc)
        ground: 0,         // Ground pins (VSS, VSSA)
        analog: 0,         // Analog pins currently in analog mode (AMSEL=1)
        analogAvail: 0     // Analog-capable pins not in analog mode
    },
    // Raw register values from device - ALL banks initialized
    regs: {
        // Bank A (GPIO 0-31)
        dirA: 0, datA: 0, mux1A: 0, mux2A: 0, gmux1A: 0, gmux2A: 0, amselA: 0,
        // Bank B (GPIO 32-63)
        dirB: 0, datB: 0, mux1B: 0, mux2B: 0, gmux1B: 0, gmux2B: 0,
        // Bank C (GPIO 64-95)
        dirC: 0, datC: 0, mux1C: 0, mux2C: 0, gmux1C: 0, gmux2C: 0,
        // Bank D (GPIO 96-127)
        dirD: 0, datD: 0, mux1D: 0, mux2D: 0, gmux1D: 0, gmux2D: 0,
        // Bank E (GPIO 128-159)
        dirE: 0, datE: 0, mux1E: 0, mux2E: 0, gmux1E: 0, gmux2E: 0,
        // Bank F (GPIO 160-191)
        dirF: 0, datF: 0, mux1F: 0, mux2F: 0, gmux1F: 0, gmux2F: 0,
        // Bank G (GPIO 192-223)
        dirG: 0, datG: 0, mux1G: 0, mux2G: 0, gmux1G: 0, gmux2G: 0,
        // Bank H (GPIO 224-255)
        dirH: 0, datH: 0, mux1H: 0, mux2H: 0, gmux1H: 0, gmux2H: 0, amselH: 0
    }
};

//=============================================================================
// Peripheral Function Lookup Table
//=============================================================================
// Maps GPIO numbers to their peripheral mux options for tooltip display.
// Format: GPIO_PERIPH_FUNCTIONS[gpioNum] = { muxVal: 'PeripheralName', ... }
//
// MUX value calculation: fullMux = (GMUX << 2) | MUX  (4-bit value, 0-15)
// - MUX register provides bits [1:0]
// - GMUX register provides bits [3:2]
//
// Source: F280015x/F28003x GPIO Mux tables from device Technical Reference Manual
// Note: This table covers common peripherals. Device-specific variations may exist.
//       Extend this table as needed for additional devices or GPIO pins.
//=============================================================================
const GPIO_PERIPH_FUNCTIONS = {
    // GPIO0-3 (EPWM1/2, SCIA)
    0: { 1: 'EPWM1A', 2: 'SCITXDA', 5: 'SCITXDB', 6: 'I2CA_SDA' },
    1: { 1: 'EPWM1B', 2: 'SCIRXDA', 5: 'SCIRXDB', 6: 'I2CA_SCL', 7: 'FSIRXD0A' },
    2: { 1: 'EPWM2A', 2: 'OUTPUTXBAR1', 6: 'SCITXDB' },
    3: { 1: 'EPWM2B', 2: 'OUTPUTXBAR2', 5: 'MCAN_TX', 6: 'SCIRXDB' },
    // GPIO4-7 (EPWM3/4, CANA)
    4: { 1: 'EPWM3A', 5: 'MCAN_RX', 6: 'SCITXDA' },
    5: { 1: 'EPWM3B', 3: 'OUTPUTXBAR3', 5: 'ECAP1_OUT', 6: 'SCIRXDA' },
    6: { 1: 'EPWM4A', 2: 'OUTPUTXBAR4', 5: 'ECAP2_OUT', 6: 'SYNCOUT' },
    7: { 1: 'EPWM4B', 2: 'OUTPUTXBAR5', 5: 'ECAP3_OUT', 6: 'EQEP2A' },
    // GPIO8-11 (EPWM5/6, SPIA)
    8: { 1: 'EPWM5A', 2: 'ADCSOCAO', 5: 'SPIA_SIMO', 6: 'FSITXA_D0', 9: 'SCITXDB' },
    9: { 1: 'EPWM5B', 3: 'OUTPUTXBAR6', 5: 'SPIA_CLK', 6: 'FSITXA_D1', 9: 'SCIRXDB' },
    10: { 1: 'EPWM6A', 2: 'ADCSOCBO', 5: 'SPIA_SOMI', 6: 'FSITXA_CLK' },
    11: { 1: 'EPWM6B', 2: 'OUTPUTXBAR7', 5: 'SPIA_STE', 6: 'FSIRXA_D0' },
    // GPIO12-15 (EPWM7, FSI)
    12: { 1: 'EPWM7A', 2: 'OUTPUTXBAR8', 5: 'MCAN_TX', 6: 'FSIRXA_D1' },
    13: { 1: 'EPWM7B', 2: 'EQEP1A', 5: 'MCAN_RX', 6: 'FSIRXA_CLK' },
    14: { 1: 'EPWM8A', 2: 'EQEP1B', 5: 'SCITXDB', 6: 'OUTPUTXBAR3' },
    15: { 1: 'EPWM8B', 2: 'EQEP1S', 5: 'SCIRXDB', 6: 'OUTPUTXBAR4' },
    // GPIO16-19 (SPI, EPWM)
    16: { 1: 'SPIA_SIMO', 2: 'OUTPUTXBAR7', 5: 'EPWM5A', 6: 'EQEP1S' },
    17: { 1: 'SPIA_SOMI', 2: 'OUTPUTXBAR8', 5: 'EPWM5B', 6: 'EQEP1I' },
    18: { 1: 'SPIA_CLK', 2: 'SCITXDB', 5: 'CANA_TX', 6: 'EPWM6A' },
    19: { 1: 'SPIA_STE', 2: 'SCIRXDB', 5: 'CANA_RX', 6: 'EPWM6B' },
    // GPIO22-23 (EQEP, SCI)
    22: { 1: 'EQEP1S', 2: 'SCITXDB', 5: 'SPIA_CLK', 6: 'LINA_TX' },
    23: { 1: 'EQEP1I', 2: 'SCIRXDB', 5: 'SPIA_STE', 6: 'LINA_RX' },
    // GPIO24-27 (SPIB, CAN, EPWM)
    24: { 1: 'OUTPUTXBAR1', 2: 'EQEP2A', 5: 'SPIB_SIMO', 6: 'EPWM8A' },
    25: { 1: 'OUTPUTXBAR2', 2: 'EQEP2B', 5: 'SPIB_SOMI', 6: 'EPWM8B' },
    26: { 1: 'OUTPUTXBAR3', 2: 'EQEP2S', 5: 'SPIB_CLK', 6: 'I2CA_SDA' },
    27: { 1: 'OUTPUTXBAR4', 2: 'EQEP2I', 5: 'SPIB_STE', 6: 'I2CA_SCL' },
    // GPIO28-31 (SCIA, SCIB)
    28: { 1: 'SCIRXDA', 5: 'EPWM7A', 6: 'OUTPUTXBAR5' },
    29: { 1: 'SCITXDA', 5: 'EPWM7B', 6: 'OUTPUTXBAR6' },
    30: { 1: 'CANA_RX', 2: 'SPIB_SIMO', 5: 'EQEP1A' },
    31: { 1: 'CANA_TX', 2: 'SPIB_SOMI', 5: 'EQEP1B' },
    // GPIO32-35 (I2CA, SDAA, SPIB)
    32: { 1: 'I2CA_SDA', 2: 'SPIB_CLK', 5: 'EPWM8A', 6: 'CANA_TX' },
    33: { 1: 'I2CA_SCL', 2: 'SPIB_STE', 5: 'EPWM8B', 6: 'CANA_RX' },
    34: { 1: 'OUTPUTXBAR1', 2: 'EQEP2A', 5: 'SCITXDA', 6: 'MCAN_TX' },
    35: { 1: 'SCIRXDA', 5: 'I2CA_SDA', 6: 'SPIA_STE', 9: 'EPWM4A', 15: 'TDI' },
    // GPIO37 (TDO/GPIO)
    37: { 1: 'SCITXDA', 5: 'I2CA_SCL', 6: 'SPIA_CLK', 15: 'TDO' },
    // GPIO39-42
    39: { 2: 'CANA_RX', 5: 'SCIRXDB', 6: 'MCAN_RX' },
    40: { 1: 'EPWM2A', 5: 'SCITXDA', 6: 'EQEP1A' },
    41: { 1: 'EPWM2B', 5: 'SCIRXDA', 6: 'EQEP1B', 9: 'MCAN_TX' },
    // GPIO56-59 (SPIA on some devices)
    56: { 1: 'SPIA_CLK', 5: 'EPWM7A', 6: 'EQEP2A' },
    57: { 1: 'SPIA_STE', 5: 'EPWM7B', 6: 'EQEP2B' },
    58: { 1: 'SPIA_SIMO', 5: 'MCAN_TX', 6: 'OUTPUTXBAR1' },
    59: { 1: 'SPIA_SOMI', 5: 'MCAN_RX', 6: 'OUTPUTXBAR2' },
    // GPIO222-223 (TDI/TDO on F28P65x)
    222: { 15: 'TDI' },
    223: { 15: 'TDO' }
};

/**
 * Get peripheral function name for a GPIO at a given mux value.
 * Used for tooltip display to show human-readable peripheral names.
 * @param {number} gpioNum - GPIO number (0-63 for most devices)
 * @param {number} muxVal - Combined MUX value: (GMUX << 2) | MUX
 * @returns {string} Peripheral name (e.g., 'I2CA_SDA') or fallback text
 */
function getPeripheralName(gpioNum, muxVal) {
    if (muxVal === 0) return 'GPIO';
    let gpioPeriphs = GPIO_PERIPH_FUNCTIONS[gpioNum];
    if (gpioPeriphs && gpioPeriphs[muxVal]) {
        return gpioPeriphs[muxVal];
    }
    return 'Peripheral MUX=' + muxVal;
}

// GPIO bank configuration for register reads
const GPIO_BANKS = {
    'A': { start: 0,  count: 32,
           dirReg: 'GpioCtrlRegs.GPADIR', datReg: 'GpioDataRegs.GPADAT',
           mux1Reg: 'GpioCtrlRegs.GPAMUX1', mux2Reg: 'GpioCtrlRegs.GPAMUX2',
           gmux1Reg: 'GpioCtrlRegs.GPAGMUX1', gmux2Reg: 'GpioCtrlRegs.GPAGMUX2' },
    'B': { start: 32, count: 32,
           dirReg: 'GpioCtrlRegs.GPBDIR', datReg: 'GpioDataRegs.GPBDAT',
           mux1Reg: 'GpioCtrlRegs.GPBMUX1', mux2Reg: 'GpioCtrlRegs.GPBMUX2',
           gmux1Reg: 'GpioCtrlRegs.GPBGMUX1', gmux2Reg: 'GpioCtrlRegs.GPBGMUX2' },
    'H': { start: 224, count: 32,
           dirReg: 'GpioCtrlRegs.GPHDIR', datReg: 'GpioDataRegs.GPHDAT',
           mux1Reg: 'GpioCtrlRegs.GPHMUX1', mux2Reg: 'GpioCtrlRegs.GPHMUX2',
           gmux1Reg: 'GpioCtrlRegs.GPHGMUX1', gmux2Reg: 'GpioCtrlRegs.GPHGMUX2' }
};

// Get GPIO configuration from stored register values
// Returns: {mux: 0-15, dir: 0/1, dat: 0/1, isPeripheral: bool, isAnalog: bool}
function getGpioConfig(gpioNum) {
    let bank, bankOffset;

    if (gpioNum >= 0 && gpioNum < 32) {
        bank = 'A';
        bankOffset = gpioNum;
    } else if (gpioNum >= 32 && gpioNum < 64) {
        bank = 'B';
        bankOffset = gpioNum - 32;
    } else if (gpioNum >= 64 && gpioNum < 96) {
        bank = 'C';
        bankOffset = gpioNum - 64;
    } else if (gpioNum >= 96 && gpioNum < 128) {
        bank = 'D';
        bankOffset = gpioNum - 96;
    } else if (gpioNum >= 128 && gpioNum < 160) {
        bank = 'E';
        bankOffset = gpioNum - 128;
    } else if (gpioNum >= 160 && gpioNum < 192) {
        bank = 'F';
        bankOffset = gpioNum - 160;
    } else if (gpioNum >= 192 && gpioNum < 224) {
        bank = 'G';
        bankOffset = gpioNum - 192;
    } else if (gpioNum >= 224 && gpioNum < 256) {
        bank = 'H';
        bankOffset = gpioNum - 224;
    } else {
        return null;  // Invalid GPIO number
    }

    // Get register values for this bank
    let dir = pinmuxState.regs['dir' + bank];
    let dat = pinmuxState.regs['dat' + bank];
    let mux1 = pinmuxState.regs['mux1' + bank];
    let mux2 = pinmuxState.regs['mux2' + bank];
    let gmux1 = pinmuxState.regs['gmux1' + bank];
    let gmux2 = pinmuxState.regs['gmux2' + bank];

    // Determine which MUX register to use (0-15 use MUX1, 16-31 use MUX2)
    let muxReg = bankOffset < 16 ? mux1 : mux2;
    let gmuxReg = bankOffset < 16 ? gmux1 : gmux2;
    let bitPos = (bankOffset % 16) * 2;

    // Extract 2-bit MUX value and 2-bit GMUX value -> 4-bit full mux
    let muxVal = (muxReg >> bitPos) & 0x3;
    let gmuxVal = (gmuxReg >> bitPos) & 0x3;
    let fullMux = (gmuxVal << 2) | muxVal;

    // Extract direction and data bits
    let dirBit = (dir >> bankOffset) & 0x1;
    let datBit = (dat >> bankOffset) & 0x1;

    // Check analog mode (AMSEL register) - only banks A and H have AMSEL
    let isAnalog = false;
    if (bank === 'A' || bank === 'H') {
        let amsel = pinmuxState.regs['amsel' + bank] || 0;
        isAnalog = ((amsel >> bankOffset) & 0x1) === 1;
    }

    return {
        mux: fullMux,
        dir: dirBit,
        dat: datBit,
        isPeripheral: fullMux !== 0,
        isAnalog: isAnalog
    };
}

// Get human-readable description for a GPIO's current configuration
function getGpioStatusText(gpioNum, config) {
    if (!config) return 'N/A';

    // DAT register reflects actual pin state regardless of mux setting
    let datText = config.dat ? 'HIGH' : 'LOW';

    if (config.isAnalog) {
        return 'Analog Mode (' + datText + ')';
    } else if (config.isPeripheral) {
        // DAT register still readable even when muxed to peripheral
        return 'Peripheral MUX=' + config.mux + ' (' + datText + ')';
    } else {
        let dirText = config.dir ? 'Output' : 'Input';
        return 'GPIO ' + dirText + ' ' + datText;
    }
}

// Generate detailed tooltip for a pin showing full configuration
function getDetailedPinTooltip(pinNum, pinInfo, config) {
    let lines = [];

    // Line 1: Pin identification
    lines.push('Pin ' + pinNum + ': ' + (pinInfo ? pinInfo.name : 'Unknown'));

    if (!pinInfo) {
        lines.push('Type: Undefined');
        return lines.join('\n');
    }

    // Line 2: Pin type
    let typeDesc = '';
    switch (pinInfo.type) {
        case 'power': typeDesc = 'Power Supply'; break;
        case 'ground': typeDesc = 'Ground'; break;
        case 'gpio': typeDesc = 'GPIO-capable'; break;
        case 'analog': typeDesc = 'Analog Only (no GPIO)'; break;
        case 'fixed': typeDesc = 'Fixed Function'; break;
        default: typeDesc = pinInfo.type;
    }
    lines.push('Type: ' + typeDesc);

    // For GPIO-capable pins, show detailed register configuration
    if (pinInfo.type === 'gpio' && pinInfo.gpioNum >= 0) {
        lines.push('---');
        lines.push('GPIO' + pinInfo.gpioNum);

        if (config) {
            // Direction
            let dirText = config.dir ? 'Output (DIR=1)' : 'Input (DIR=0)';
            lines.push('Direction: ' + dirText);

            // Current pin state
            let stateText = config.dat ? 'HIGH (DAT=1)' : 'LOW (DAT=0)';
            lines.push('Pin State: ' + stateText);

            // MUX configuration
            let muxText = '';
            if (config.isAnalog) {
                muxText = 'Analog Mode (AMSEL=1)';
            } else if (config.mux === 0) {
                muxText = 'GPIO Mode (MUX=0)';
            } else {
                // Look up the specific peripheral function
                let periphName = getPeripheralName(pinInfo.gpioNum, config.mux);
                muxText = periphName + ' (MUX=' + config.mux + ')';
                // Add JTAG indicator for TDI/TDO pins (device-specific)
                if (isTdiTdoPin(pinInfo.gpioNum) && (config.mux === 15 || pinmuxState.debuggerConnected)) {
                    muxText += ' [JTAG Active]';
                }
            }
            lines.push('Function: ' + muxText);

            // Show raw MUX/GMUX values for debugging
            let muxLow = config.mux & 0x3;
            let gmuxHigh = (config.mux >> 2) & 0x3;
            lines.push('Registers: MUX=' + muxLow + ', GMUX=' + gmuxHigh);
        } else {
            lines.push('(Register data not available)');
            lines.push('Connect to target for live status');
        }

    } else if (pinInfo.type === 'analog') {
        lines.push('---');
        lines.push('Dedicated analog input');
        lines.push('No GPIO capability');

    } else if (pinInfo.type === 'fixed') {
        lines.push('---');
        if (['TDI', 'TDO', 'TMS', 'TCK'].includes(pinInfo.name)) {
            lines.push('JTAG Debug Interface');
        } else if (pinInfo.name === 'XRSn' || pinInfo.name.includes('XRS') || pinInfo.name.includes('RESET')) {
            lines.push('External Reset (active low)');
            lines.push('Pull-up required for normal operation');
        } else if (pinInfo.name === 'VREGENZ') {
            lines.push('Voltage Regulator Enable');
            lines.push('Low = Use internal LDO');
            lines.push('High = Use external supply');
        } else if (pinInfo.name === 'ERRORSTS' || (pinInfo.name && pinInfo.name.includes('ERRORSTS'))) {
            lines.push('Error Status Output');
            lines.push('Active low when error detected');
        } else if (pinInfo.name === 'FLT1' || pinInfo.name === 'FLT2') {
            lines.push('Fault Output Pin');
            lines.push('External fault signaling');
        } else {
            lines.push('Fixed function pin');
        }

    } else if (pinInfo.type === 'power') {
        lines.push('---');
        if (pinInfo.name.includes('VDD')) {
            lines.push('Core/IO power supply');
        } else if (pinInfo.name.includes('VREF')) {
            lines.push('ADC reference voltage');
        }

    } else if (pinInfo.type === 'ground') {
        lines.push('---');
        if (pinInfo.name.includes('VSSA')) {
            lines.push('Analog ground reference');
        } else {
            lines.push('Digital ground');
        }
    }

    return lines.join('\n');
}

// Get CSS class for GPIO pin based on configuration
// Device-specific TDI/TDO pin detection
// F28P65x/F28P55x use GPIO222/223 for TDI/TDO
// Device-specific TDI/TDO JTAG pin mapping
// F28P65x/F28P55x: GPIO222 (TDI), GPIO223 (TDO)
// All other devices: GPIO35 (TDI), GPIO37 (TDO)
const DEVICES_WITH_GPIO222_JTAG = ['F28P65x', 'F28P55x'];

/**
 * Check if a GPIO pin is a TDI/TDO JTAG pin for the current device.
 * @param {number} gpioNum - GPIO number to check
 * @returns {boolean} True if this GPIO is a TDI or TDO pin on the current device
 */
function isTdiTdoPin(gpioNum) {
    const deviceHasGpio222Jtag = DEVICES_WITH_GPIO222_JTAG.includes('`deviceName`');
    if (deviceHasGpio222Jtag) {
        return (gpioNum === 222 || gpioNum === 223);
    } else {
        return (gpioNum === 35 || gpioNum === 37);
    }
}

/**
 * Get CSS class for a GPIO pin based on its configuration.
 * @param {object} config - GPIO configuration {mux, dir, dat, isPeripheral, isAnalog}
 * @param {number} gpioNum - GPIO number (used to detect TDI/TDO JTAG pins)
 * @returns {string} CSS class name for pin coloring
 */
function getGpioPinClass(config, gpioNum) {
    if (!config) return 'available';

    // Check for TDI/TDO JTAG function - device dependent GPIO pins
    // GPIO35/37 (most devices): TDI/TDO at MUX=15
    // GPIO222/223 (F28P65x/F28P55x): TDI/TDO at MUX=15
    // When debugger is connected (DCON=1), these pins are ALWAYS used for JTAG
    // regardless of the MUX register setting (hardware override)
    if (isTdiTdoPin(gpioNum)) {
        // Show as JTAG if: MUX=15 (software config) OR debugger connected (hardware override)
        if (config.mux === 15 || pinmuxState.debuggerConnected) {
            return 'jtag';  // Orange - JTAG function active
        }
    }

    if (config.isAnalog) {
        return 'analog_used';  // Purple - pin in analog mode
    } else if (config.isPeripheral) {
        // Show peripheral with HIGH/LOW indication via color shade
        return config.dat ? 'periph_high' : 'periph_low';
    } else {
        // GPIO mode - color based on direction and data
        if (config.dir === 0) {
            // Input
            return config.dat ? 'input_high' : 'input_low';
        } else {
            // Output
            return config.dat ? 'output_high' : 'output_low';
        }
    }
}

// Get arrow character for a pin based on its side and direction
// Input arrows point towards package (data flowing IN)
// Output arrows point away from package (data flowing OUT)
// Bidirectional arrows show both directions
// Returns the arrow character or empty string if no arrow
function getPinArrow(pinNum, pinsPerSide, isOutput, isBidirectional) {
    // Determine which side the pin is on
    let side;
    if (pinNum <= pinsPerSide) {
        side = 'bottom';
    } else if (pinNum <= 2 * pinsPerSide) {
        side = 'right';
    } else if (pinNum <= 3 * pinsPerSide) {
        side = 'top';
    } else {
        side = 'left';
    }

    // Arrow directions: toward package = input, away from package = output
    // Unicode arrows: ↑ ↓ ← → ↔ (horizontal bidir) ↕ (vertical bidir)
    if (isBidirectional) {
        // Bidirectional: double-headed arrow based on orientation
        switch (side) {
            case 'bottom':
            case 'top':
                return '↕';  // Vertical bidirectional
            case 'left':
            case 'right':
                return '↔';  // Horizontal bidirectional
        }
    } else if (isOutput) {
        // Output: arrow points away from package
        switch (side) {
            case 'bottom': return '↓';
            case 'top':    return '↑';
            case 'left':   return '←';
            case 'right':  return '→';
        }
    } else {
        // Input: arrow points towards package
        switch (side) {
            case 'bottom': return '↑';
            case 'top':    return '↓';
            case 'left':   return '→';
            case 'right':  return '←';
        }
    }
    return '';
}

// Create a single pin element
function createPinElement(pinNum, pkgConfig) {
    let pinInfo = pkgConfig.pins[pinNum];
    let pinClass = 'available';
    let gpioNumAttr = '';

    if (pinInfo) {
        pinClass = pinInfo.type;
        if (pinInfo.gpioNum !== undefined && pinInfo.gpioNum >= 0) {
            gpioNumAttr = ' data-gpio="' + pinInfo.gpioNum + '"';
        }
    } else {
        cdtWarn("No pinInfo for pin " + pinNum);
    }

    // Generate initial detailed tooltip
    let tooltip = getDetailedPinTooltip(pinNum, pinInfo, null);
    if (!tooltip || tooltip.length === 0) {
        tooltip = 'Pin ' + pinNum + ': No data';
        cdtWarn("Empty tooltip for pin " + pinNum);
    }
    // Escape for HTML attribute (replace newlines with &#10; for tooltip display)
    let tooltipEscaped = tooltip.replace(/\n/g, '&#10;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');

    return '<div class="pinmux_pin ' + pinClass + '" data-pin="' + pinNum + '"' + gpioNumAttr + ' title="' + tooltipEscaped + '">' +
           '<div class="pinmux_pin_bar"></div>' +
           '<span class="pinmux_pin_arrow"></span>' +
           '<span class="pinmux_pin_label">' + pinNum + '</span>' +
           '</div>';
}

// Create a BGA pin element
function createBgaPinElement(pinId, pkgConfig) {
    let pinInfo = pkgConfig.pins[pinId];
    let gpioNumAttr = '';
    let tooltip, pinClass;

    if (pinInfo) {
        // Ball exists at this position
        pinClass = pinInfo.type;
        if (pinInfo.gpioNum !== undefined && pinInfo.gpioNum >= 0) {
            gpioNumAttr = ' data-gpio="' + pinInfo.gpioNum + '"';
        }
        tooltip = getDetailedPinTooltip(pinId, pinInfo, null);
    } else {
        // No ball at this position (depopulated BGA position)
        // Debug: log first few missing pins to help identify config issues
        if (!createBgaPinElement.missingCount) createBgaPinElement.missingCount = 0;
        if (createBgaPinElement.missingCount < 20) {
            cdtWarn("Pin " + pinId + " not found in config (missing #" + (createBgaPinElement.missingCount + 1) + ")");
            createBgaPinElement.missingCount++;
        }
        pinClass = 'depopulated';
        tooltip = 'Position ' + pinId + ': No ball (depopulated)';
    }

    let tooltipEscaped = tooltip.replace(/\n/g, '&#10;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');

    return '<div class="pinmux_bga_pin ' + pinClass + '" data-pin="' + pinId + '"' + gpioNumAttr + ' title="' + tooltipEscaped + '"></div>';
}

// Create a BGA pin element using DOM methods (for security - avoids innerHTML)
function createBgaPinElementDOM(pinId, pkgConfig, ballSize) {
    let pinInfo = pkgConfig.pins[pinId];
    let tooltip, pinClass;

    if (pinInfo) {
        pinClass = pinInfo.type;
        tooltip = getDetailedPinTooltip(pinId, pinInfo, null);
    } else {
        if (!createBgaPinElementDOM.missingCount) createBgaPinElementDOM.missingCount = 0;
        if (createBgaPinElementDOM.missingCount < 20) {
            cdtWarn("Pin " + pinId + " not found in config");
            createBgaPinElementDOM.missingCount++;
        }
        pinClass = 'depopulated';
        tooltip = 'Position ' + pinId + ': No ball (depopulated)';
    }

    let pinEl = document.createElement('div');
    pinEl.className = 'pinmux_bga_pin ' + pinClass;
    pinEl.dataset.pin = pinId;
    if (pinInfo && pinInfo.gpioNum !== undefined && pinInfo.gpioNum >= 0) {
        pinEl.dataset.gpio = pinInfo.gpioNum;
    }
    pinEl.title = tooltip;
    if (ballSize) {
        pinEl.style.width = ballSize + 'px';
        pinEl.style.height = ballSize + 'px';
    }
    return pinEl;
}

// Initialize BGA package grid
function initBgaPackage(pkgConfig) {
    let container = document.querySelector('.pinmux_package_container');
    if (container) {
        container.classList.add('bga');
    }

    // Update BGA title elements
    let bgaDeviceNameEl = document.getElementById('pinmux_bga_device_name');
    let bgaPkgNameEl = document.getElementById('pinmux_bga_package_name');
    if (bgaPkgNameEl && pinmuxState.packageName) {
        bgaPkgNameEl.textContent = pinmuxState.packageName;
    }

    let rows = pkgConfig.rows;
    let cols = pkgConfig.cols;

    cdtDebugLog("initBgaPackage: rows=" + rows.length + ", cols=" + cols);

    // Dynamic ball sizing based on grid size
    // Smaller balls for larger BGA packages to fit in panel
    let ballSize = 14;
    let maxDimension = Math.max(rows.length, cols);
    if (maxDimension > 18) {
        ballSize = 12;
    }
    if (maxDimension > 22) {
        ballSize = 10;
    }
    cdtDebugLog("BGA ball size: " + ballSize + "px for " + maxDimension + " max dimension");

    // Generate row labels (top to bottom) using DOM methods
    let rowLabelsEl = document.getElementById('pinmux_bga_row_labels');
    if (rowLabelsEl) {
        rowLabelsEl.textContent = '';
        for (let r of rows) {
            let label = document.createElement('div');
            label.className = 'pinmux_bga_label';
            label.style.width = ballSize + 'px';
            label.style.height = ballSize + 'px';
            label.textContent = r;
            rowLabelsEl.appendChild(label);
        }
    }

    // Generate column labels (left to right) using DOM methods
    let colLabelsEl = document.getElementById('pinmux_bga_col_labels');
    if (colLabelsEl) {
        colLabelsEl.textContent = '';
        for (let c = 1; c <= cols; c++) {
            let label = document.createElement('div');
            label.className = 'pinmux_bga_label';
            label.style.width = ballSize + 'px';
            label.style.height = ballSize + 'px';
            label.textContent = c;
            colLabelsEl.appendChild(label);
        }
    }

    // Generate BGA grid using DOM methods
    let gridEl = document.getElementById('pinmux_bga_grid');
    if (gridEl) {
        gridEl.style.gridTemplateColumns = 'repeat(' + cols + ', ' + ballSize + 'px)';
        gridEl.style.gridTemplateRows = 'repeat(' + rows.length + ', ' + ballSize + 'px)';
        gridEl.textContent = '';

        for (let row of rows) {
            for (let col = 1; col <= cols; col++) {
                let pinId = row + col;
                let pinEl = createBgaPinElementDOM(pinId, pkgConfig, ballSize);
                gridEl.appendChild(pinEl);
            }
        }
        cdtDebugLog("initBgaPackage: generated " + (rows.length * cols) + " ball positions");
    }
}

// Initialize QFP package (perimeter layout)
function initQfpPackage(pkgConfig) {
    let container = document.querySelector('.pinmux_package_container');
    if (container) {
        container.classList.remove('bga');
    }

    let pinsPerSide = pkgConfig.pinsPerSide;

    // Dynamic sizing based on pins per side
    // Each pin is 12px, with minimum spacing of 4px between pins
    // Add padding for labels (40px on each side for large packages)
    let pinSize = 12;
    let minPinGap = 4;
    let packageSize = pinsPerSide * (pinSize + minPinGap) + 50;  // 50px extra for padding

    // Set minimum size for small packages, scale up for larger ones
    let minSize = 200;
    let maxSize = 600;
    packageSize = Math.max(minSize, Math.min(maxSize, packageSize));

    let packageEl = document.getElementById('pinmux_package');
    if (packageEl) {
        packageEl.style.width = packageSize + 'px';
        packageEl.style.height = packageSize + 'px';
        cdtDebugLog("QFP package sized to " + packageSize + "px for " + pinsPerSide + " pins per side");
    }

    // Generate pins for each side
    // Bottom: pins 1 to pinsPerSide (left to right)
    let bottomHtml = '';
    for (let i = 1; i <= pinsPerSide; i++) {
        bottomHtml += createPinElement(i, pkgConfig);
    }

    // Right: pins (pinsPerSide+1) to (2*pinsPerSide) (bottom to top)
    let rightHtml = '';
    for (let i = pinsPerSide + 1; i <= 2 * pinsPerSide; i++) {
        rightHtml += createPinElement(i, pkgConfig);
    }

    // Top: pins (2*pinsPerSide+1) to (3*pinsPerSide) (right to left in physical layout)
    let topHtml = '';
    for (let i = 2 * pinsPerSide + 1; i <= 3 * pinsPerSide; i++) {
        topHtml += createPinElement(i, pkgConfig);
    }

    // Left: pins (3*pinsPerSide+1) to (4*pinsPerSide) (top to bottom)
    let leftHtml = '';
    for (let i = 3 * pinsPerSide + 1; i <= 4 * pinsPerSide; i++) {
        leftHtml += createPinElement(i, pkgConfig);
    }

    // Update DOM
    let bottomEl = document.getElementById('pinmux_pins_bottom');
    let rightEl = document.getElementById('pinmux_pins_right');
    let topEl = document.getElementById('pinmux_pins_top');
    let leftEl = document.getElementById('pinmux_pins_left');

    if (bottomEl) bottomEl.innerHTML = bottomHtml;
    if (rightEl) rightEl.innerHTML = rightHtml;
    if (topEl) topEl.innerHTML = topHtml;
    if (leftEl) leftEl.innerHTML = leftHtml;

    // Clear BGA grid
    let gridEl = document.getElementById('pinmux_bga_grid');
    if (gridEl) gridEl.innerHTML = '';
    let rowLabelsEl = document.getElementById('pinmux_bga_row_labels');
    if (rowLabelsEl) rowLabelsEl.innerHTML = '';
    let colLabelsEl = document.getElementById('pinmux_bga_col_labels');
    if (colLabelsEl) colLabelsEl.innerHTML = '';
}

// Initialize the package view
function initPinmuxPackage() {
    // Skip initialization if package not yet detected from PARTIDL register
    if (pinmuxState.packagePins === 0) {
        cdtDebugLog("initPinmuxPackage: packagePins not yet detected, skipping");
        return;
    }

    let pkgConfig = PACKAGE_CONFIGS[pinmuxState.packagePins];
    if (!pkgConfig) {
        cdtWarn("Unknown package size:", pinmuxState.packagePins, "- using fallback");
        // Get first available package config for this device
        let availablePins = Object.keys(PACKAGE_CONFIGS).map(function(k) { return parseInt(k); }).sort(function(a, b) { return b - a; });
        pkgConfig = PACKAGE_CONFIGS[availablePins[0]];  // Default to largest available
    }

    pinmuxState.gpioTotal = pkgConfig.totalGPIO;

    // Update package name display
    let pkgNameEl = document.getElementById('pinmux_package_name');
    if (pkgNameEl) {
        // Use stored package name if available, otherwise generate from PACKAGE_INFO
        if (pinmuxState.packageName) {
            pkgNameEl.textContent = pinmuxState.packageName;
        } else {
            let pkgInfo = PACKAGE_INFO_DEFAULT[3]; // Default to 64-pin
            if (pinmuxState.packagePins === 80) pkgInfo = PACKAGE_INFO_DEFAULT[4];
            else if (pinmuxState.packagePins === 48) pkgInfo = PACKAGE_INFO_DEFAULT[1];
            else if (pinmuxState.packagePins === 32) pkgInfo = PACKAGE_INFO_DEFAULT[0];
            if (pkgInfo) {
                pkgNameEl.textContent = pkgInfo.pins + "-pin " + pkgInfo.type + " (" + pkgInfo.code + ")";
            } else {
                pkgNameEl.textContent = pinmuxState.packagePins + "-pin";
            }
        }
    }

    // Check if this is a BGA package
    if (pkgConfig.isBGA) {
        initBgaPackage(pkgConfig);
    } else {
        initQfpPackage(pkgConfig);
    }

    // Update pin counts display
    updatePinCounts();

}

/**
 * Update the pin counts display in the Pinmux panel legend.
 * Shows categorized counts: GPIO In/Out, Peripheral, JTAG, Power/Ground, Analog.
 * Called after updatePinColors() has counted all pins by category.
 */
function updatePinCounts() {
    let c = pinmuxState.counts;
    // Update each counter element in the legend
    let el;
    el = document.getElementById('pinmux_count_gpio_in');
    if (el) el.textContent = c.gpioInput;
    el = document.getElementById('pinmux_count_gpio_out');
    if (el) el.textContent = c.gpioOutput;
    el = document.getElementById('pinmux_count_periph');
    if (el) el.textContent = (c.periphInput + c.periphOutput);
    el = document.getElementById('pinmux_count_jtag');
    if (el) el.textContent = c.jtag;
    el = document.getElementById('pinmux_count_power');
    if (el) el.textContent = c.power;
    el = document.getElementById('pinmux_count_ground');
    if (el) el.textContent = c.ground;
    el = document.getElementById('pinmux_count_analog');
    if (el) el.textContent = c.analog + '/' + c.analogAvail;
    el = document.getElementById('pinmux_count_reset');
    if (el) el.textContent = c.reset || 0;
    // Legacy counter for backwards compatibility
    let counterEl = document.getElementById('pinmux_gpio_used_count');
    if (counterEl) {
        counterEl.textContent = pinmuxState.gpioUsed + '/' + pinmuxState.gpioTotal;
    }
}

/**
 * Update pin colors and tooltips based on live GPIO register data.
 * Reads from pinmuxState.regs and determines each pin's current state:
 * - GPIO mode (MUX=0): Shows input/output and HIGH/LOW state
 * - Peripheral mode (MUX≠0): Shows peripheral function with HIGH/LOW indication
 * - Analog mode (AMSEL=1): Shows analog indicator
 * Also counts pins by category for the legend display.
 */
function updatePinColors() {
    cdtDebugLog("[CDT PINMUX TRACE] updatePinColors() ENTRY");
    let availablePins = Object.keys(PACKAGE_CONFIGS).map(function(k) { return parseInt(k); }).sort(function(a, b) { return b - a; });
    cdtDebugLog("[CDT PINMUX TRACE] Available package sizes: " + JSON.stringify(availablePins));
    cdtDebugLog("[CDT PINMUX TRACE] pinmuxState.packagePins: " + pinmuxState.packagePins);
    let pkgConfig = PACKAGE_CONFIGS[pinmuxState.packagePins] || PACKAGE_CONFIGS[availablePins[0]];
    cdtDebugLog("[CDT PINMUX TRACE] pkgConfig found: " + (!!pkgConfig) + ", isBGA: " + (pkgConfig ? pkgConfig.isBGA : "N/A"));

    // Reset all counts
    let counts = {
        gpioInput: 0,
        gpioOutput: 0,
        periphInput: 0,
        periphOutput: 0,
        jtag: 0,
        power: 0,
        ground: 0,
        analog: 0,
        analogAvail: 0
    };

    // Update each pin based on its GPIO mux status
    // Handle both QFP (.pinmux_pin) and BGA (.pinmux_bga_pin) packages
    let pinSelector = pkgConfig.isBGA ? '.pinmux_bga_pin' : '.pinmux_pin';
    let pinElements = document.querySelectorAll(pinSelector);
    cdtDebugLog("[CDT PINMUX TRACE] Pin selector: " + pinSelector + ", Found elements: " + pinElements.length);
    cdtDebugLog("[CDT PINMUX TRACE] Register values - dirA:0x" + pinmuxState.regs.dirA.toString(16) + " datA:0x" + pinmuxState.regs.datA.toString(16));
    // Debug: log first 5 pin configs to verify structure
    let debugPinCount = 0;
    for (let pn = 1; pn <= 5; pn++) {
        let pi = pkgConfig.pins[pn];
        cdtDebugLog("[CDT PINMUX TRACE] pkgConfig.pins[" + pn + "] = " + JSON.stringify(pi));
    }
    pinElements.forEach(pinEl => {
        let pinId = pinEl.dataset.pin;  // String for BGA (e.g., "A1"), number for QFP
        let pinNum = pkgConfig.isBGA ? pinId : parseInt(pinId);
        let pinInfo = pkgConfig.pins[pinNum];
        let config = null;

        // Get GPIO config if this is a GPIO-capable pin
        if (pinInfo && pinInfo.gpioNum !== undefined && pinInfo.gpioNum >= 0) {
            config = getGpioConfig(pinInfo.gpioNum);
            // Debug: trace specific GPIOs that should be input_high
            if ([20, 21, 24, 28].includes(pinInfo.gpioNum)) {
                cdtDebugLog("[CDT PIN TRACE] Pin " + pinNum + " -> GPIO" + pinInfo.gpioNum +
                    " config: dir=" + (config ? config.dir : "null") +
                    " dat=" + (config ? config.dat : "null") +
                    " mux=" + (config ? config.mux : "null") +
                    " class will be: " + (config ? getGpioPinClass(config, pinInfo.gpioNum) : "none"));
            }
        }

        // Debug: log first 20 unknown pins
        if (!pinInfo) {
            if (!updatePinColors.unknownCount) updatePinColors.unknownCount = 0;
            if (updatePinColors.unknownCount < 20) {
                cdtDebugLog("updatePinColors: Pin " + pinNum + " not found in config");
                updatePinColors.unknownCount++;
            }
        }

        // Handle static pin types that don't change based on registers
        if (pinInfo) {
            // Power pins
            if (pinInfo.type === 'power') {
                pinEl.title = getDetailedPinTooltip(pinNum, pinInfo, null);
                counts.power++;
                return;
            }

            // Ground pins
            if (pinInfo.type === 'ground') {
                pinEl.title = getDetailedPinTooltip(pinNum, pinInfo, null);
                counts.ground++;
                return;
            }

            // Analog-only pins (no GPIO capability) - keep purple color
            if (pinInfo.type === 'analog') {
                pinEl.className = (pkgConfig.isBGA ? 'pinmux_bga_pin' : 'pinmux_pin') + ' analog';
                pinEl.title = getDetailedPinTooltip(pinNum, pinInfo, null);
                counts.analogAvail++;  // Analog-only pins counted as available analog
                return;
            }

            // JTAG pins (TDI, TDO, TMS, TCK) - use jtag color
            if (pinInfo.type === 'fixed' && ['TDI', 'TDO', 'TMS', 'TCK'].includes(pinInfo.name)) {
                pinEl.className = (pkgConfig.isBGA ? 'pinmux_bga_pin' : 'pinmux_pin') + ' jtag';
                pinEl.title = getDetailedPinTooltip(pinNum, pinInfo, null);
                counts.jtag++;
                return;
            }

            // Reset pin (XRSn) - pink color
            if (pinInfo.type === 'fixed' && (pinInfo.name === 'XRSn' || pinInfo.name.includes('XRS') || pinInfo.name.includes('RESET'))) {
                pinEl.className = (pkgConfig.isBGA ? 'pinmux_bga_pin' : 'pinmux_pin') + ' reset';
                pinEl.title = getDetailedPinTooltip(pinNum, pinInfo, null);
                counts.reset = (counts.reset || 0) + 1;
                return;
            }

            // Special function pins (VREGENZ, ERRORSTS, FLT1, FLT2) - cyan color
            let specialNames = ['VREGENZ', 'ERRORSTS', 'FLT1', 'FLT2'];
            let isSpecialFixed = pinInfo.type === 'fixed' && specialNames.includes(pinInfo.name);
            let isSpecialGpio = pinInfo.type === 'gpio' && pinInfo.name && pinInfo.name.includes('ERRORSTS');
            if (isSpecialFixed || isSpecialGpio) {
                pinEl.className = (pkgConfig.isBGA ? 'pinmux_bga_pin' : 'pinmux_pin') + ' special';
                pinEl.title = getDetailedPinTooltip(pinNum, pinInfo, null);
                counts.special = (counts.special || 0) + 1;
                return;
            }

            // Other fixed pins - keep fixed color
            if (pinInfo.type === 'fixed') {
                pinEl.className = (pkgConfig.isBGA ? 'pinmux_bga_pin' : 'pinmux_pin') + ' fixed';
                pinEl.title = getDetailedPinTooltip(pinNum, pinInfo, null);
                return;
            }
        }

        // Get GPIO number from pin info for GPIO-capable pins
        if (pinInfo && pinInfo.gpioNum !== undefined && pinInfo.gpioNum >= 0) {
            if (config) {
                // Get the CSS class based on pin configuration
                let pinClass = getGpioPinClass(config, pinInfo.gpioNum);
                pinEl.className = (pkgConfig.isBGA ? 'pinmux_bga_pin' : 'pinmux_pin') + ' ' + pinClass;

                // Update tooltip with detailed configuration info
                pinEl.title = getDetailedPinTooltip(pinNum, pinInfo, config);

                // Update direction arrow (QFP packages only - BGA doesn't use arrows)
                // On C2000, DIR register controls pad direction even for peripheral-muxed pins
                // DIR=0: Input (arrow pointing into package)
                // DIR=1: Output (arrow pointing out of package)
                // Some peripherals (I2C, SPI) are bidirectional - show double arrow
                if (!pkgConfig.isBGA) {
                    let arrowEl = pinEl.querySelector('.pinmux_pin_arrow');
                    if (arrowEl) {
                        // Only show arrow for GPIO and peripheral modes (not analog)
                        if (!config.isAnalog) {
                            // Check if this is a bidirectional peripheral (I2C SDA/SCL, etc.)
                            let periphName = config.isPeripheral ? getPeripheralName(pinInfo.gpioNum, config.mux) : '';
                            let isBidirectional = periphName.includes('I2C') ||
                                                  periphName.includes('SDA') ||
                                                  periphName.includes('SCL') ||
                                                  periphName.includes('SIMO') ||  // SPI bidirectional modes
                                                  periphName.includes('SOMI');
                            // Use DIR register for both GPIO and peripheral modes
                            let isOutput = config.dir === 1;
                            arrowEl.textContent = getPinArrow(pinNum, pkgConfig.pinsPerSide, isOutput, isBidirectional);
                        } else {
                            arrowEl.textContent = '';
                        }
                    }
                }

                // Count by category
                // Check for TDI/TDO JTAG function first (device-specific)
                // GPIO35/37 (most devices) or GPIO222/223 (F28P65x/F28P55x)
                // Count as JTAG when: MUX=15 OR debugger connected (hardware override)
                if (isTdiTdoPin(pinInfo.gpioNum) && (config.mux === 15 || pinmuxState.debuggerConnected)) {
                    counts.jtag++;  // Count as JTAG when in TDI/TDO mode or debugger connected
                } else if (config.isAnalog) {
                    counts.analog++;  // GPIO pin in analog mode
                } else if (config.isPeripheral) {
                    // Peripheral mode - count based on DAT (reflects actual state)
                    // Note: For peripherals, direction is controlled by the peripheral
                    counts.periphOutput++;  // All peripherals counted as "output" (peripheral-controlled)
                } else {
                    // GPIO mode
                    if (config.dir === 0) {
                        counts.gpioInput++;
                    } else {
                        counts.gpioOutput++;
                    }
                }
            } else {
                // No config available, mark as available
                pinEl.className = (pkgConfig.isBGA ? 'pinmux_bga_pin' : 'pinmux_pin') + ' available';
                pinEl.title = getDetailedPinTooltip(pinNum, pinInfo, null);
            }
        } else if (pinInfo) {
            // Pin has info but no valid GPIO number - set tooltip anyway
            pinEl.title = getDetailedPinTooltip(pinNum, pinInfo, null);
        } else {
            // Pin has no info at all
            if (pkgConfig.isBGA && pinEl.classList.contains('depopulated')) {
                // BGA depopulated position - leave unchanged (already set in createBgaPinElement)
                return;
            }
            // QFP or BGA with missing pin info - mark as available
            pinEl.className = (pkgConfig.isBGA ? 'pinmux_bga_pin' : 'pinmux_pin') + ' available';
            pinEl.title = 'Pin ' + pinNum + ': Unknown\nNo pin information available';
        }
    });

    // Update pinmuxState with counts
    pinmuxState.counts = counts;
    pinmuxState.gpioUsed = counts.periphOutput + counts.periphInput;
    updatePinCounts();
}

/**
 * Parse register values from XDS transport responses.
 * Handles both decimal and hexadecimal string formats, and converts
 * signed values to unsigned 32-bit (XDS may return signed integers).
 * @param {string|number} val - Raw value from XDS transport
 * @returns {number} Unsigned 32-bit integer value
 */
function parseRegValue(val) {
    if (val === undefined || val === null || val === '') return 0;

    // Handle object responses from XDS transport (e.g., {value: 123} or {data: 123})
    if (typeof val === 'object' && val !== null) {
        let keys = Object.keys(val);

        // Check if this is a per-GPIO-bit object (e.g., {GPIO0: "0x0", GPIO1: "0x1", ...})
        // XDS transport returns GPIO registers as objects with per-bit fields
        let isGpioBitObject = keys.length > 0 && keys.some(k => /^GPIO\d+$/.test(k));
        if (isGpioBitObject) {
            // Combine all GPIO bit values into a single 32-bit register value
            let combinedValue = 0;
            for (let key of keys) {
                let match = key.match(/^GPIO(\d+)$/);
                if (match) {
                    let bitNum = parseInt(match[1], 10);
                    let bitVal = val[key];
                    // Parse the bit value (could be "0x0", "0x1", 0, 1, etc.)
                    let bitSet = 0;
                    if (typeof bitVal === 'string') {
                        bitSet = (parseInt(bitVal, 16) || parseInt(bitVal, 10)) ? 1 : 0;
                    } else {
                        bitSet = bitVal ? 1 : 0;
                    }
                    if (bitSet && bitNum >= 0 && bitNum < 32) {
                        combinedValue |= (1 << bitNum);
                    }
                }
            }
            cdtDebugLog("[CDT parseRegValue] GPIO bit object combined: 0x" + combinedValue.toString(16));
            return combinedValue >>> 0;  // Ensure unsigned
        }

        // Try common property names for the actual value
        if (val.value !== undefined) val = val.value;
        else if (val.data !== undefined) val = val.data;
        else if (val.result !== undefined) val = val.result;
        else if (val.content !== undefined) val = val.content;
        else if (val.val !== undefined) val = val.val;
        else {
            // Try to get first numeric property
            for (let key of keys) {
                if (typeof val[key] === 'number' || typeof val[key] === 'string') {
                    cdtDebugLog("parseRegValue: Using property '" + key + "' = " + val[key]);
                    val = val[key];
                    break;
                }
            }
        }
    }

    // Handle numeric values directly
    if (typeof val === 'number') {
        if (val < 0) {
            return val >>> 0;  // Convert signed to unsigned 32-bit
        }
        return val;
    }

    let str = String(val).trim();
    let num;
    // Handle hex strings (0x prefix or just hex digits)
    if (str.startsWith('0x') || str.startsWith('0X')) {
        num = parseInt(str, 16) || 0;
    } else {
        // Try parsing as decimal first, then as hex if it looks like hex
        num = parseInt(str, 10);
        if (isNaN(num) && /^[0-9a-fA-F]+$/.test(str)) {
            num = parseInt(str, 16);
        }
    }
    // Convert signed to unsigned 32-bit (handles negative values from XDS)
    // Example: -28673 becomes 0xFFFF8FFF when treated as unsigned
    if (num < 0) {
        num = num >>> 0;  // Zero-fill right shift converts to unsigned
    }
    return num || 0;
}

async function pinmuxUpdate() {
    cdtDebugLog("[CDT PINMUX TRACE] pinmuxUpdate() ENTRY");
    cdtDebugLog("pinmuxUpdate() started");
    debugLog('info', 'pinmuxUpdate() started');
    try {
        // Check if XDS transport is connected
        if (!xdsTransport || xdsTransport.state !== 'connected') {
            cdtDebugLog("[CDT PINMUX TRACE] XDS transport not connected, skipping");
            cdtWarn("pinmuxUpdate() skipped - XDS transport not connected");
            debugLog('error', 'pinmuxUpdate() - XDS transport not connected');
            return;
        }
        cdtDebugLog("[CDT PINMUX TRACE] XDS transport connected, reading registers...");

        // Read DCON (debugger connected) status for JTAG pin detection
        // TDI/TDO pins are used for JTAG when debugger is connected, regardless of MUX setting
        // Since CDT runs via JTAG debugger, we can assume debugger is ALWAYS connected
        // But we'll still try to read TAP_STATUS to confirm
        try {
            // Read full TAP_STATUS register and extract DCON bit (bit 31)
            let tapStatus = await xdsTransport.readValue('DevCfgRegs.TAP_STATUS');
            let tapVal = parseRegValue(tapStatus);
            let dcon = (tapVal >> 31) & 1;  // DCON is bit 31
            pinmuxState.debuggerConnected = (dcon === 1);
            cdtDebugLog("TAP_STATUS=0x" + tapVal.toString(16) + ", DCON=" + dcon + ", debuggerConnected=" + pinmuxState.debuggerConnected);
            // If DCON read returns 0 but we're clearly running via debugger, force true
            if (!pinmuxState.debuggerConnected) {
                cdtWarn("DCON=0 but CDT is running via debugger, forcing debuggerConnected=true");
                pinmuxState.debuggerConnected = true;
            }
        } catch (e) {
            // If we can read GPIO registers via XDS, debugger MUST be connected
            pinmuxState.debuggerConnected = true;
            cdtDebugLog("TAP_STATUS read failed (" + e.message + "), assuming debugger connected");
        }

        // Read all GPIO registers for banks A through H in PARALLEL
        // This batches ~50 register reads into a single parallel operation
        // Dramatically improves performance vs sequential reads
        const gpioRegs = [
            // Bank A (GPIO 0-31)
            'GpioCtrlRegs.GPADIR', 'GpioDataRegs.GPADAT', 'GpioCtrlRegs.GPAMUX1',
            'GpioCtrlRegs.GPAMUX2', 'GpioCtrlRegs.GPAGMUX1', 'GpioCtrlRegs.GPAGMUX2',
            'GpioCtrlRegs.GPAAMSEL',
            // Bank B (GPIO 32-63)
            'GpioCtrlRegs.GPBDIR', 'GpioDataRegs.GPBDAT', 'GpioCtrlRegs.GPBMUX1',
            'GpioCtrlRegs.GPBMUX2', 'GpioCtrlRegs.GPBGMUX1', 'GpioCtrlRegs.GPBGMUX2',
            // Bank C (GPIO 64-95)
            'GpioCtrlRegs.GPCDIR', 'GpioDataRegs.GPCDAT', 'GpioCtrlRegs.GPCMUX1',
            'GpioCtrlRegs.GPCMUX2', 'GpioCtrlRegs.GPCGMUX1', 'GpioCtrlRegs.GPCGMUX2',
            // Bank D (GPIO 96-127)
            'GpioCtrlRegs.GPDDIR', 'GpioDataRegs.GPDDAT', 'GpioCtrlRegs.GPDMUX1',
            'GpioCtrlRegs.GPDMUX2', 'GpioCtrlRegs.GPDGMUX1', 'GpioCtrlRegs.GPDGMUX2',
            // Bank E (GPIO 128-159)
            'GpioCtrlRegs.GPEDIR', 'GpioDataRegs.GPEDAT', 'GpioCtrlRegs.GPEMUX1',
            'GpioCtrlRegs.GPEMUX2', 'GpioCtrlRegs.GPEGMUX1', 'GpioCtrlRegs.GPEGMUX2',
            // Bank F (GPIO 160-191)
            'GpioCtrlRegs.GPFDIR', 'GpioDataRegs.GPFDAT', 'GpioCtrlRegs.GPFMUX1',
            'GpioCtrlRegs.GPFMUX2', 'GpioCtrlRegs.GPFGMUX1', 'GpioCtrlRegs.GPFGMUX2',
            // Bank G (GPIO 192-223)
            'GpioCtrlRegs.GPGDIR', 'GpioDataRegs.GPGDAT', 'GpioCtrlRegs.GPGMUX1',
            'GpioCtrlRegs.GPGMUX2', 'GpioCtrlRegs.GPGGMUX1', 'GpioCtrlRegs.GPGGMUX2',
            // Bank H (GPIO 224-255)
            'GpioCtrlRegs.GPHDIR', 'GpioDataRegs.GPHDAT', 'GpioCtrlRegs.GPHMUX1',
            'GpioCtrlRegs.GPHMUX2', 'GpioCtrlRegs.GPHGMUX1', 'GpioCtrlRegs.GPHGMUX2',
            'GpioCtrlRegs.GPHAMSEL'
        ];

        // Batch read all GPIO registers in parallel
        const gpioResults = await Promise.allSettled(
            gpioRegs.map(reg => xdsTransport.readValue(reg))
        );

        // Helper to extract value (0 for failed reads - bank may not exist on device)
        const getVal = (idx) => gpioResults[idx].status === 'fulfilled' ? parseRegValue(gpioResults[idx].value) : 0;

        // Bank A (indices 0-6)
        pinmuxState.regs.dirA = getVal(0);
        pinmuxState.regs.datA = getVal(1);
        pinmuxState.regs.mux1A = getVal(2);
        pinmuxState.regs.mux2A = getVal(3);
        pinmuxState.regs.gmux1A = getVal(4);
        pinmuxState.regs.gmux2A = getVal(5);
        pinmuxState.regs.amselA = getVal(6);
        // Bank B (indices 7-12)
        pinmuxState.regs.dirB = getVal(7);
        pinmuxState.regs.datB = getVal(8);
        pinmuxState.regs.mux1B = getVal(9);
        pinmuxState.regs.mux2B = getVal(10);
        pinmuxState.regs.gmux1B = getVal(11);
        pinmuxState.regs.gmux2B = getVal(12);
        // Bank C (indices 13-18)
        pinmuxState.regs.dirC = getVal(13);
        pinmuxState.regs.datC = getVal(14);
        pinmuxState.regs.mux1C = getVal(15);
        pinmuxState.regs.mux2C = getVal(16);
        pinmuxState.regs.gmux1C = getVal(17);
        pinmuxState.regs.gmux2C = getVal(18);
        // Bank D (indices 19-24)
        pinmuxState.regs.dirD = getVal(19);
        pinmuxState.regs.datD = getVal(20);
        pinmuxState.regs.mux1D = getVal(21);
        pinmuxState.regs.mux2D = getVal(22);
        pinmuxState.regs.gmux1D = getVal(23);
        pinmuxState.regs.gmux2D = getVal(24);
        // Bank E (indices 25-30)
        pinmuxState.regs.dirE = getVal(25);
        pinmuxState.regs.datE = getVal(26);
        pinmuxState.regs.mux1E = getVal(27);
        pinmuxState.regs.mux2E = getVal(28);
        pinmuxState.regs.gmux1E = getVal(29);
        pinmuxState.regs.gmux2E = getVal(30);
        // Bank F (indices 31-36)
        pinmuxState.regs.dirF = getVal(31);
        pinmuxState.regs.datF = getVal(32);
        pinmuxState.regs.mux1F = getVal(33);
        pinmuxState.regs.mux2F = getVal(34);
        pinmuxState.regs.gmux1F = getVal(35);
        pinmuxState.regs.gmux2F = getVal(36);
        // Bank G (indices 37-42)
        pinmuxState.regs.dirG = getVal(37);
        pinmuxState.regs.datG = getVal(38);
        pinmuxState.regs.mux1G = getVal(39);
        pinmuxState.regs.mux2G = getVal(40);
        pinmuxState.regs.gmux1G = getVal(41);
        pinmuxState.regs.gmux2G = getVal(42);
        // Bank H (indices 43-49)
        pinmuxState.regs.dirH = getVal(43);
        pinmuxState.regs.datH = getVal(44);
        pinmuxState.regs.mux1H = getVal(45);
        pinmuxState.regs.mux2H = getVal(46);
        pinmuxState.regs.gmux1H = getVal(47);
        pinmuxState.regs.gmux2H = getVal(48);
        pinmuxState.regs.amselH = getVal(49);

        cdtDebugLog("[CDT XDS READ] GPIO registers batch read complete (" + gpioRegs.length + " registers)")

        // Log parsed GPIO registers to debug panel - only for ports that exist on this device
        // Bank A (GPIO 0-31) - All devices have Port A
        debugLog('read', 'GPIO Bank A (0-31):', 'GPADIR', '0x' + pinmuxState.regs.dirA.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank A (0-31):', 'GPADAT', '0x' + pinmuxState.regs.datA.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank A (0-31):', 'GPAMUX1', '0x' + pinmuxState.regs.mux1A.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank A (0-31):', 'GPAMUX2', '0x' + pinmuxState.regs.mux2A.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank A (0-31):', 'GPAGMUX1', '0x' + pinmuxState.regs.gmux1A.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank A (0-31):', 'GPAGMUX2', '0x' + pinmuxState.regs.gmux2A.toString(16).toUpperCase().padStart(8, '0'));
        // Bank B (GPIO 32-63) - All devices have Port B
        debugLog('read', 'GPIO Bank B (32-63):', 'GPBDIR', '0x' + pinmuxState.regs.dirB.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank B (32-63):', 'GPBDAT', '0x' + pinmuxState.regs.datB.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank B (32-63):', 'GPBMUX1', '0x' + pinmuxState.regs.mux1B.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank B (32-63):', 'GPBMUX2', '0x' + pinmuxState.regs.mux2B.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank B (32-63):', 'GPBGMUX1', '0x' + pinmuxState.regs.gmux1B.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank B (32-63):', 'GPBGMUX2', '0x' + pinmuxState.regs.gmux2B.toString(16).toUpperCase().padStart(8, '0'));
% if (deviceConstants.DEVICES_WITH_GPIO_PORTC.includes(deviceName)) {
        // Bank C (GPIO 64-95)
        debugLog('read', 'GPIO Bank C (64-95):', 'GPCDIR', '0x' + pinmuxState.regs.dirC.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank C (64-95):', 'GPCDAT', '0x' + pinmuxState.regs.datC.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank C (64-95):', 'GPCMUX1', '0x' + pinmuxState.regs.mux1C.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank C (64-95):', 'GPCMUX2', '0x' + pinmuxState.regs.mux2C.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank C (64-95):', 'GPCGMUX1', '0x' + pinmuxState.regs.gmux1C.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank C (64-95):', 'GPCGMUX2', '0x' + pinmuxState.regs.gmux2C.toString(16).toUpperCase().padStart(8, '0'));
% }
% if (deviceConstants.DEVICES_WITH_GPIO_PORTD.includes(deviceName)) {
        // Bank D (GPIO 96-127)
        debugLog('read', 'GPIO Bank D (96-127):', 'GPDDIR', '0x' + pinmuxState.regs.dirD.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank D (96-127):', 'GPDDAT', '0x' + pinmuxState.regs.datD.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank D (96-127):', 'GPDMUX1', '0x' + pinmuxState.regs.mux1D.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank D (96-127):', 'GPDMUX2', '0x' + pinmuxState.regs.mux2D.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank D (96-127):', 'GPDGMUX1', '0x' + pinmuxState.regs.gmux1D.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank D (96-127):', 'GPDGMUX2', '0x' + pinmuxState.regs.gmux2D.toString(16).toUpperCase().padStart(8, '0'));
% }
% if (deviceConstants.DEVICES_WITH_GPIO_PORTE.includes(deviceName)) {
        // Bank E (GPIO 128-159)
        debugLog('read', 'GPIO Bank E (128-159):', 'GPEDIR', '0x' + pinmuxState.regs.dirE.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank E (128-159):', 'GPEDAT', '0x' + pinmuxState.regs.datE.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank E (128-159):', 'GPEMUX1', '0x' + pinmuxState.regs.mux1E.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank E (128-159):', 'GPEMUX2', '0x' + pinmuxState.regs.mux2E.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank E (128-159):', 'GPEGMUX1', '0x' + pinmuxState.regs.gmux1E.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank E (128-159):', 'GPEGMUX2', '0x' + pinmuxState.regs.gmux2E.toString(16).toUpperCase().padStart(8, '0'));
% }
% if (deviceConstants.DEVICES_WITH_GPIO_PORTF.includes(deviceName)) {
        // Bank F (GPIO 160-191)
        debugLog('read', 'GPIO Bank F (160-191):', 'GPFDIR', '0x' + pinmuxState.regs.dirF.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank F (160-191):', 'GPFDAT', '0x' + pinmuxState.regs.datF.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank F (160-191):', 'GPFMUX1', '0x' + pinmuxState.regs.mux1F.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank F (160-191):', 'GPFMUX2', '0x' + pinmuxState.regs.mux2F.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank F (160-191):', 'GPFGMUX1', '0x' + pinmuxState.regs.gmux1F.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank F (160-191):', 'GPFGMUX2', '0x' + pinmuxState.regs.gmux2F.toString(16).toUpperCase().padStart(8, '0'));
% }
% if (deviceConstants.DEVICES_WITH_GPIO_PORTG.includes(deviceName)) {
        // Bank G (GPIO 192-223)
        debugLog('read', 'GPIO Bank G (192-223):', 'GPGDIR', '0x' + pinmuxState.regs.dirG.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank G (192-223):', 'GPGDAT', '0x' + pinmuxState.regs.datG.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank G (192-223):', 'GPGMUX1', '0x' + pinmuxState.regs.mux1G.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank G (192-223):', 'GPGMUX2', '0x' + pinmuxState.regs.mux2G.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank G (192-223):', 'GPGGMUX1', '0x' + pinmuxState.regs.gmux1G.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank G (192-223):', 'GPGGMUX2', '0x' + pinmuxState.regs.gmux2G.toString(16).toUpperCase().padStart(8, '0'));
% }
% if (deviceConstants.DEVICES_WITH_GPIO_PORTH.includes(deviceName)) {
        // Bank H (GPIO 224-255)
        debugLog('read', 'GPIO Bank H (224-255):', 'GPHDIR', '0x' + pinmuxState.regs.dirH.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank H (224-255):', 'GPHDAT', '0x' + pinmuxState.regs.datH.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank H (224-255):', 'GPHMUX1', '0x' + pinmuxState.regs.mux1H.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank H (224-255):', 'GPHMUX2', '0x' + pinmuxState.regs.mux2H.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank H (224-255):', 'GPHGMUX1', '0x' + pinmuxState.regs.gmux1H.toString(16).toUpperCase().padStart(8, '0'));
        debugLog('read', 'GPIO Bank H (224-255):', 'GPHGMUX2', '0x' + pinmuxState.regs.gmux2H.toString(16).toUpperCase().padStart(8, '0'));
% }

        // Update pin colors based on mux status
        cdtDebugLog("[CDT PINMUX TRACE] Calling updatePinColors() with regs: dirA=0x" + pinmuxState.regs.dirA.toString(16) + " datA=0x" + pinmuxState.regs.datA.toString(16));
        updatePinColors();
        cdtDebugLog("[CDT PINMUX TRACE] updatePinColors() returned");

        // Also update GPIO diagnostics panel if present
        gpioUpdate();
        cdtDebugLog("[CDT PINMUX TRACE] gpioUpdate() returned");

        debugLog('info', 'pinmuxUpdate() completed');
        cdtDebugLog("pinmuxUpdate() completed");
        cdtDebugLog("[CDT PINMUX TRACE] pinmuxUpdate() COMPLETED SUCCESSFULLY");
    } catch (error) {
        // Enhanced error logging for pinmuxUpdate
        let errorMsg = error?.message || String(error) || "Unknown error";
        let errorName = error?.name || "Error";
        cdtDebugLog("[CDT PINMUXUPDATE ERROR] " + errorName + ": " + errorMsg);
        cdtError("pinmuxUpdate() error:", error);
        debugLog('error', 'pinmuxUpdate() exception:', '', error.message);
    }
}

function pinmuxReset() {

    pinmuxState.gpioUsed = 0;

    // Reset all counts
    pinmuxState.counts = {
        gpioInput: 0, gpioOutput: 0,
        periphInput: 0, periphOutput: 0,
        jtag: 0, power: 0, ground: 0,
        analog: 0, analogAvail: 0
    };

    // Reset all register values (all GPIO banks A through H)
    pinmuxState.regs = {
        // Bank A (GPIO 0-31)
        dirA: 0, datA: 0, mux1A: 0, mux2A: 0, gmux1A: 0, gmux2A: 0, amselA: 0,
        // Bank B (GPIO 32-63)
        dirB: 0, datB: 0, mux1B: 0, mux2B: 0, gmux1B: 0, gmux2B: 0,
        // Bank C (GPIO 64-95)
        dirC: 0, datC: 0, mux1C: 0, mux2C: 0, gmux1C: 0, gmux2C: 0,
        // Bank D (GPIO 96-127)
        dirD: 0, datD: 0, mux1D: 0, mux2D: 0, gmux1D: 0, gmux2D: 0,
        // Bank E (GPIO 128-159)
        dirE: 0, datE: 0, mux1E: 0, mux2E: 0, gmux1E: 0, gmux2E: 0,
        // Bank F (GPIO 160-191)
        dirF: 0, datF: 0, mux1F: 0, mux2F: 0, gmux1F: 0, gmux2F: 0,
        // Bank G (GPIO 192-223)
        dirG: 0, datG: 0, mux1G: 0, mux2G: 0, gmux1G: 0, gmux2G: 0,
        // Bank H (GPIO 224-255)
        dirH: 0, datH: 0, mux1H: 0, mux2H: 0, gmux1H: 0, gmux2H: 0, amselH: 0
    };

    // Reset all GPIO pins to available state
    let availablePinsReset = Object.keys(PACKAGE_CONFIGS).map(function(k) { return parseInt(k); }).sort(function(a, b) { return b - a; });
    document.querySelectorAll('.pinmux_pin').forEach(pinEl => {
        let pkgConfig = PACKAGE_CONFIGS[pinmuxState.packagePins] || PACKAGE_CONFIGS[availablePinsReset[0]];
        let pinNum = parseInt(pinEl.dataset.pin);
        let pinInfo = pkgConfig.pins[pinNum];

        // Keep power/ground/fixed pins as-is
        if (pinInfo && (pinInfo.type === 'power' || pinInfo.type === 'ground' || pinInfo.type === 'fixed')) {
            return;
        }

        // Set class based on package type (QFP vs BGA)
        pinEl.className = (pkgConfig.isBGA ? 'pinmux_bga_pin' : 'pinmux_pin') + ' available';
        // Clear direction arrow
        let arrowEl = pinEl.querySelector('.pinmux_pin_arrow');
        if (arrowEl) arrowEl.textContent = '';
        // Reset tooltip to basic pin info
        if (pinInfo && pinInfo.gpioNum !== undefined && pinInfo.gpioNum >= 0) {
            pinEl.title = 'Pin ' + pinNum + ': GPIO' + pinInfo.gpioNum;
        }
    });

    updatePinCounts();

}

//=============================================================================
// GPIO Diagnostics Panel - Update Functions
//=============================================================================

/**
 * Update the GPIO diagnostics panel based on current pinmuxState register values.
 * This function updates pin grid cells, port summary cards, and diagnostic indicators.
 * Supports all GPIO ports A-H (up to GPIO 255 on devices like F28P65x).
 */
function gpioUpdate() {
    cdtDebugLog("gpioUpdate() started");
    debugLog('info', 'gpioUpdate() started');

    try {
        // Port configuration: defines each port's registers and pin ranges
        const portConfigs = [
            { name: 'A', start: 0,   end: 32,  dirKey: 'dirA', datKey: 'datA', mux1Key: 'mux1A', mux2Key: 'mux2A', amselKey: 'amselA' },
            { name: 'B', start: 32,  end: 64,  dirKey: 'dirB', datKey: 'datB', mux1Key: 'mux1B', mux2Key: 'mux2B', amselKey: null },
            { name: 'C', start: 64,  end: 96,  dirKey: 'dirC', datKey: 'datC', mux1Key: 'mux1C', mux2Key: 'mux2C', amselKey: null },
            { name: 'D', start: 96,  end: 128, dirKey: 'dirD', datKey: 'datD', mux1Key: 'mux1D', mux2Key: 'mux2D', amselKey: null },
            { name: 'E', start: 128, end: 160, dirKey: 'dirE', datKey: 'datE', mux1Key: 'mux1E', mux2Key: 'mux2E', amselKey: null },
            { name: 'F', start: 160, end: 192, dirKey: 'dirF', datKey: 'datF', mux1Key: 'mux1F', mux2Key: 'mux2F', amselKey: null },
            { name: 'G', start: 192, end: 224, dirKey: 'dirG', datKey: 'datG', mux1Key: 'mux1G', mux2Key: 'mux2G', amselKey: null },
            { name: 'H', start: 224, end: 256, dirKey: 'dirH', datKey: 'datH', mux1Key: 'mux1H', mux2Key: 'mux2H', amselKey: 'amselH' }
        ];

        // Port statistics counters for all ports
        const portStats = {};
        portConfigs.forEach(p => {
            portStats[p.name] = { inputs: 0, outputs: 0, high: 0, low: 0 };
        });

        // Process each port
        portConfigs.forEach(portCfg => {
            const dir = pinmuxState.regs[portCfg.dirKey] || 0;
            const dat = pinmuxState.regs[portCfg.datKey] || 0;
            const mux1 = pinmuxState.regs[portCfg.mux1Key] || 0;
            const mux2 = pinmuxState.regs[portCfg.mux2Key] || 0;
            const amsel = portCfg.amselKey ? (pinmuxState.regs[portCfg.amselKey] || 0) : 0;
            const stats = portStats[portCfg.name];

            // Update pins for this port
            for (let pin = portCfg.start; pin < portCfg.end; pin++) {
                let pinEl = getCachedElement('gpio_pin_' + pin);
                if (!pinEl) continue;

                let pinOffset = pin - portCfg.start;
                let pinDir = (dir >> pinOffset) & 1;
                let pinDat = (dat >> pinOffset) & 1;
                let mux = (pinOffset < 16) ? ((mux1 >> (pinOffset * 2)) & 3) : ((mux2 >> ((pinOffset - 16) * 2)) & 3);
                let isAnalog = (amsel >> pinOffset) & 1;

                let stateClass = 'unavailable';
                let dirText = '--';

                if (isAnalog) {
                    if (FIXED_FUNCTION_AMSEL_GPIOS.includes(pin)) {
                        stateClass = 'special';
                        dirText = 'FIXED';
                    } else {
                        stateClass = 'analog';
                        dirText = 'ANA';
                    }
                } else if (mux !== 0) {
                    stateClass = 'peripheral';
                    dirText = 'PERIPH';
                } else if (pinDir === 0) {
                    stateClass = pinDat ? 'input_high' : 'input_low';
                    dirText = 'IN';
                    stats.inputs++;
                    if (pinDat) stats.high++; else stats.low++;
                } else {
                    stateClass = pinDat ? 'output_high' : 'output_low';
                    dirText = 'OUT';
                    stats.outputs++;
                    if (pinDat) stats.high++; else stats.low++;
                }

                pinEl.className = 'gpio_pin_cell ' + stateClass;
                let dirEl = pinEl.querySelector('.gpio_pin_dir');
                if (dirEl) dirEl.textContent = dirText;

                let modeStr = '';
                if (isAnalog) {
                    modeStr = FIXED_FUNCTION_AMSEL_GPIOS.includes(pin) ? ' (Fixed Function)' : ' (Analog)';
                }
                pinEl.title = 'GPIO' + pin + '\nDirection: ' + (pinDir ? 'Output' : 'Input') +
                             '\nState: ' + (pinDat ? 'HIGH' : 'LOW') +
                             '\nMux: ' + mux + modeStr;
            }
        });

        // Update all port summary cards
        portConfigs.forEach(portCfg => {
            const stats = portStats[portCfg.name];
            const portLower = portCfg.name.toLowerCase();
            setCachedElementText('gpio_port' + portLower + '_inputs', stats.inputs);
            setCachedElementText('gpio_port' + portLower + '_outputs', stats.outputs);
            setCachedElementText('gpio_port' + portLower + '_high', stats.high);
            setCachedElementText('gpio_port' + portLower + '_low', stats.low);
        });

        // Update diagnostic indicators
        let floatingLed = gcWidgetCache.get('gpio_floating_warning_led');
        if (floatingLed) {
            // Check for inputs across all ports
            let hasInputs = Object.values(portStats).some(s => s.inputs > 0);
            setLedPassFail(floatingLed, !hasInputs);
        }

        // Configuration stats - sum across all ports
        let totalInputs = Object.values(portStats).reduce((sum, s) => sum + s.inputs, 0);
        let totalOutputs = Object.values(portStats).reduce((sum, s) => sum + s.outputs, 0);
        setCachedElementText('gpio_pullup_count', '--');
        setCachedElementText('gpio_opendrain_count', '--');
        setCachedElementText('gpio_locked_count', '--');

        debugLog('info', 'gpioUpdate() completed - Total: ' + totalInputs + ' in/' + totalOutputs + ' out');
        cdtDebugLog("gpioUpdate() completed - PortA: " + portStats.A.inputs + " in/" + portStats.A.outputs + " out, Total: " + totalInputs + " in/" + totalOutputs + " out");
    } catch (error) {
        cdtError("gpioUpdate() error:", error);
        debugLog('error', 'gpioUpdate() exception:', '', error.message);
    }
}

/**
 * GPIO panel update that also reads register values (standalone update)
 */
async function gpioFullUpdate() {
  try {
    cdtDebugLog("gpioFullUpdate() - calling pinmuxUpdate then gpioUpdate");
    // First update pinmux state (which reads all GPIO registers)
    await pinmuxUpdate();
    // Then update GPIO panel from the pinmuxState data
    gpioUpdate();

    // Read XINT status registers and update LEDs
    try {
        // XINT1 Enable status - Register: XINT1CR.ENABLE (bit 0)
        let xint1cr_raw = await xdsTransport.readValue('XintRegs.XINT1CR');
        let xint1cr = parseRegValue(xint1cr_raw);
        let xint1Enabled = (xint1cr & 0x1) === 1;
        // Use gcWidgetCache for gc-widget-led elements (pre-populated during init)
        let xint1Led = gcWidgetCache.get('gpio_xint1_led');
        if (xint1Led) {
            setLedPassFail(xint1Led, xint1Enabled);  // Green if enabled, red if disabled
        }
        debugLog('read', 'GPIO XINT:', 'XINT1CR', '0x' + xint1cr.toString(16) + ' (Enable=' + (xint1Enabled ? 'YES' : 'NO') + ')');

        // XINT2 Enable status - Register: XINT2CR.ENABLE (bit 0)
        let xint2cr_raw = await xdsTransport.readValue('XintRegs.XINT2CR');
        let xint2cr = parseRegValue(xint2cr_raw);
        let xint2Enabled = (xint2cr & 0x1) === 1;
        // Use gcWidgetCache for gc-widget-led elements (pre-populated during init)
        let xint2Led = gcWidgetCache.get('gpio_xint2_led');
        if (xint2Led) {
            setLedPassFail(xint2Led, xint2Enabled);  // Green if enabled, red if disabled
        }
        debugLog('read', 'GPIO XINT:', 'XINT2CR', '0x' + xint2cr.toString(16) + ' (Enable=' + (xint2Enabled ? 'YES' : 'NO') + ')');

        cdtDebugLog("XINT status: XINT1=" + (xint1Enabled ? 'Enabled' : 'Disabled') + ", XINT2=" + (xint2Enabled ? 'Enabled' : 'Disabled'));
    } catch (error) {
        cdtWarn("XINT read error (device may not have XINT): " + error.message);
        // XINT registers not available on this device - hide the containers
        let xint1Container = document.getElementById('gpio_diag_xint1');
        let xint2Container = document.getElementById('gpio_diag_xint2');
        if (xint1Container) xint1Container.style.display = 'none';
        if (xint2Container) xint2Container.style.display = 'none';
    }
  } catch (error) {
    cdtError("[CDT] gpioFullUpdate() failed:", error?.message);
    showToast('GPIO update failed: ' + (error?.message || 'Unknown error'), 'error');
  }
}

// GPIO port configuration table for toggle operations
// Uses symbolic names (preferred) with fallback addresses for robustness
const GPIO_PORT_CONFIG = {
    A: { start: 0,   setReg: 'GpioDataRegs.GPASET', clearReg: 'GpioDataRegs.GPACLEAR',
         datReg: 'GpioDataRegs.GPADAT', dirReg: 'GpioCtrlRegs.GPADIR',
         setAddr: '*0x00007F02', clearAddr: '*0x00007F04', dirKey: 'dirA', datKey: 'datA' },
    B: { start: 32,  setReg: 'GpioDataRegs.GPBSET', clearReg: 'GpioDataRegs.GPBCLEAR',
         datReg: 'GpioDataRegs.GPBDAT', dirReg: 'GpioCtrlRegs.GPBDIR',
         setAddr: '*0x00007F0A', clearAddr: '*0x00007F0C', dirKey: 'dirB', datKey: 'datB' },
    C: { start: 64,  setReg: 'GpioDataRegs.GPCSET', clearReg: 'GpioDataRegs.GPCCLEAR',
         datReg: 'GpioDataRegs.GPCDAT', dirReg: 'GpioCtrlRegs.GPCDIR',
         setAddr: '*0x00007F12', clearAddr: '*0x00007F14', dirKey: 'dirC', datKey: 'datC' },
    D: { start: 96,  setReg: 'GpioDataRegs.GPDSET', clearReg: 'GpioDataRegs.GPDCLEAR',
         datReg: 'GpioDataRegs.GPDDAT', dirReg: 'GpioCtrlRegs.GPDDIR',
         setAddr: '*0x00007F1A', clearAddr: '*0x00007F1C', dirKey: 'dirD', datKey: 'datD' },
    E: { start: 128, setReg: 'GpioDataRegs.GPESET', clearReg: 'GpioDataRegs.GPECLEAR',
         datReg: 'GpioDataRegs.GPEDAT', dirReg: 'GpioCtrlRegs.GPEDIR',
         setAddr: '*0x00007F22', clearAddr: '*0x00007F24', dirKey: 'dirE', datKey: 'datE' },
    F: { start: 160, setReg: 'GpioDataRegs.GPFSET', clearReg: 'GpioDataRegs.GPFCLEAR',
         datReg: 'GpioDataRegs.GPFDAT', dirReg: 'GpioCtrlRegs.GPFDIR',
         setAddr: '*0x00007F2A', clearAddr: '*0x00007F2C', dirKey: 'dirF', datKey: 'datF' },
    G: { start: 192, setReg: 'GpioDataRegs.GPGSET', clearReg: 'GpioDataRegs.GPGCLEAR',
         datReg: 'GpioDataRegs.GPGDAT', dirReg: 'GpioCtrlRegs.GPGDIR',
         setAddr: '*0x00007F32', clearAddr: '*0x00007F34', dirKey: 'dirG', datKey: 'datG' },
    H: { start: 224, setReg: 'GpioDataRegs.GPHSET', clearReg: 'GpioDataRegs.GPHCLEAR',
         datReg: 'GpioDataRegs.GPHDAT', dirReg: 'GpioCtrlRegs.GPHDIR',
         setAddr: '*0x00007F3A', clearAddr: '*0x00007F3C', dirKey: 'dirH', datKey: 'datH' }
};


//=============================================================================
// CPUTIMER Diagnostics Panel - Update Functions
//=============================================================================

// CPUTIMER register base addresses
const CPUTIMER_BASES = {
    0: 0x00000C00,  // CpuTimer0Regs
    1: 0x00000C08,  // CpuTimer1Regs
    2: 0x00000C10   // CpuTimer2Regs
};

// CPUTIMER register offsets
const CPUTIMER_O_TIM = 0x00;   // Timer counter (32-bit, low word at offset 0)
const CPUTIMER_O_PRD = 0x02;   // Timer period (32-bit, low word at offset 2)
const CPUTIMER_O_TCR = 0x04;   // Timer control register
const CPUTIMER_O_TPR = 0x06;   // Timer prescale low
const CPUTIMER_O_TPRH = 0x07;  // Timer prescale high

// TCR bit masks
const CPUTIMER_TCR_TSS = 0x0010;   // Timer Stop Status (1=stopped, 0=running)
const CPUTIMER_TCR_TRB = 0x0020;   // Timer Reload Bit
const CPUTIMER_TCR_SOFT = 0x0400;  // Soft emulation mode
const CPUTIMER_TCR_FREE = 0x0800;  // Free run mode
const CPUTIMER_TCR_TIE = 0x4000;   // Timer Interrupt Enable
const CPUTIMER_TCR_TIF = 0x8000;   // Timer Interrupt Flag

// CPUTIMER state storage
let cputimerState = {
    timer: [
        { prd: 0, tim: 0, tcr: 0, prescale: 0 },
        { prd: 0, tim: 0, tcr: 0, prescale: 0 },
        { prd: 0, tim: 0, tcr: 0, prescale: 0 }
    ],
    sysclkMHz: 120  // Default, will be read from clocking panel
};

/**
 * Format a frequency value in Hz to appropriate unit (Hz, kHz, MHz)
 */
function formatFrequency(freqHz) {
    if (freqHz >= 1000000) {
        return (freqHz / 1000000).toFixed(3) + ' MHz';
    } else if (freqHz >= 1000) {
        return (freqHz / 1000).toFixed(3) + ' kHz';
    } else {
        return freqHz.toFixed(3) + ' Hz';
    }
}

/**
 * Update a single CPUTIMER card UI based on timer state
 */
function updateCputimerCard(timerNum) {
    cdtDebugLog("updateCputimerCard(" + timerNum + ") called");
    let t = cputimerState.timer[timerNum];
    let prefix = 'cputimer' + timerNum;
    cdtDebugLog("  State: TIM=" + t.tim + ", PRD=" + t.prd + ", TCR=0x" + t.tcr.toString(16) + ", PS=" + t.prescale);

    // Determine running status
    let isRunning = (t.tcr & CPUTIMER_TCR_TSS) === 0;
    cdtDebugLog("  isRunning=" + isRunning + " (TSS bit=" + ((t.tcr & CPUTIMER_TCR_TSS) ? 1 : 0) + ")");
    let intEnabled = (t.tcr & CPUTIMER_TCR_TIE) !== 0;
    let intFlag = (t.tcr & CPUTIMER_TCR_TIF) !== 0;
    let freeRun = (t.tcr & CPUTIMER_TCR_FREE) !== 0;

    // Update card class
    let card = getCachedElement(prefix + '_card');
    if (card) {
        card.className = 'cputimer_card ' + (isRunning ? 'running' : 'stopped');
    }

    // Update status badge
    let statusEl = getCachedElement(prefix + '_status');
    if (statusEl) {
        statusEl.textContent = isRunning ? 'RUNNING' : 'STOPPED';
        statusEl.className = 'cputimer_card_status ' + (isRunning ? 'running' : 'stopped');
    }

    // Update running LED (use gcWidgetCache for gc-widget-led elements)
    let runningLed = gcWidgetCache.get(prefix + '_running_led');
    if (runningLed) {
        setLedPassFail(runningLed, isRunning);
    }

    // Update progress bar - shows counter value as percentage of period
    // 100% = counter full (TIM = PRD, just reloaded)
    // 0% = counter empty (TIM = 0, about to fire interrupt)
    let progress = 0;
    if (t.prd > 0) {
        progress = (t.tim / t.prd) * 100;
    }
    let progressEl = getCachedElement(prefix + '_progress');
    if (progressEl) {
        progressEl.style.width = progress.toFixed(1) + '%';
    }
    let percentEl = getCachedElement(prefix + '_percent');
    if (percentEl) {
        percentEl.textContent = progress.toFixed(1) + '%';
    }

    // Update stat values
    let prdEl = getCachedElement(prefix + '_prd');
    if (prdEl) prdEl.textContent = t.prd.toLocaleString();

    let timEl = getCachedElement(prefix + '_tim');
    if (timEl) timEl.textContent = t.tim.toLocaleString();

    let prescaleEl = getCachedElement(prefix + '_prescale');
    if (prescaleEl) prescaleEl.textContent = t.prescale.toString();

    // Calculate and display Counter Frequency (rate at which counter increments)
    // Counter Freq = SYSCLK / (prescale + 1)
    let counterFreqEl = getCachedElement(prefix + '_counter_freq');
    if (counterFreqEl) {
        if (cputimerState.sysclkMHz > 0) {
            let counterFreqHz = (cputimerState.sysclkMHz * 1000000) / (t.prescale + 1);
            counterFreqEl.textContent = formatFrequency(counterFreqHz);
        } else {
            counterFreqEl.textContent = '--';
        }
    }

    // Calculate and display Interrupt Frequency (rate at which timer fires interrupt/restarts)
    // Interrupt Freq = Counter Freq / (PRD + 1) = SYSCLK / ((PRD + 1) * (prescale + 1))
    let intFreqEl = getCachedElement(prefix + '_int_freq');
    if (intFreqEl) {
        if (t.prd > 0 && cputimerState.sysclkMHz > 0) {
            let intFreqHz = (cputimerState.sysclkMHz * 1000000) / ((t.prd + 1) * (t.prescale + 1));
            intFreqEl.textContent = formatFrequency(intFreqHz);
        } else {
            intFreqEl.textContent = '--';
        }
    }

    // Update flag LEDs (use gcWidgetCache for gc-widget-led elements)
    let intLed = gcWidgetCache.get(prefix + '_int_led');
    if (intLed) setLedPassFail(intLed, intEnabled);

    let tifLed = gcWidgetCache.get(prefix + '_tif_led');
    if (tifLed) {
        // TIF=1 (interrupt pending) shown as warning/orange
        if (tifLed.on !== undefined) {
            tifLed.on = intFlag;
            tifLed.onColor = intFlag ? LED_COLOR.ORANGE : LED_COLOR.GRAY;
        }
    }

    let freeLed = gcWidgetCache.get(prefix + '_free_led');
    if (freeLed) setLedPassFail(freeLed, freeRun);

}

/**
 * Parse a 32-bit timer register object with MSW/LSW fields
 * @param {object} obj - Object with MSW and LSW properties
 * @returns {number} Combined 32-bit value
 */
function parseTimer32BitReg(obj) {
    if (typeof obj !== 'object' || obj === null) {
        return parseRegValue(obj);
    }
    // XDS returns object with MSW (high 16-bit) and LSW (low 16-bit)
    let msw = 0, lsw = 0;
    if (obj.MSW !== undefined) {
        msw = parseRegValue(obj.MSW);
    }
    if (obj.LSW !== undefined) {
        lsw = parseRegValue(obj.LSW);
    }
    let combined = ((msw & 0xFFFF) << 16) | (lsw & 0xFFFF);
    cdtDebugLog("  parseTimer32BitReg: MSW=0x" + msw.toString(16) + ", LSW=0x" + lsw.toString(16) + " => 0x" + combined.toString(16) + " (" + combined + ")");
    return combined >>> 0;  // Ensure unsigned
}

/**
 * Parse TCR (Timer Control Register) object with bitfields
 * @param {object} obj - Object with TCR bitfields (TSS, TIE, TIF, FREE, SOFT, TRB)
 * @returns {number} Reconstructed 16-bit TCR value
 */
function parseTimerTCR(obj) {
    if (typeof obj !== 'object' || obj === null) {
        return parseRegValue(obj);
    }
    // Reconstruct TCR from individual bitfields
    let tcr = 0;
    if (obj.TSS !== undefined) tcr |= (parseRegValue(obj.TSS) & 1) << 4;   // Bit 4
    if (obj.TRB !== undefined) tcr |= (parseRegValue(obj.TRB) & 1) << 5;   // Bit 5
    if (obj.SOFT !== undefined) tcr |= (parseRegValue(obj.SOFT) & 1) << 10; // Bit 10
    if (obj.FREE !== undefined) tcr |= (parseRegValue(obj.FREE) & 1) << 11; // Bit 11
    if (obj.TIE !== undefined) tcr |= (parseRegValue(obj.TIE) & 1) << 14;  // Bit 14
    if (obj.TIF !== undefined) tcr |= (parseRegValue(obj.TIF) & 1) << 15;  // Bit 15
    cdtDebugLog("  parseTimerTCR: Reconstructed TCR=0x" + tcr.toString(16));
    return tcr;
}

/**
 * Read CPUTIMER registers from target and update panel
 */
async function cputimerUpdate() {
    cdtDebugLog("cputimerUpdate() started");
    debugLog('info', 'cputimerUpdate() started');

    try {
        if (!xdsTransport || xdsTransport.state !== 'connected') {
            cdtDebugLog("cputimerUpdate() skipped - XDS not connected");
            debugLog('error', 'cputimerUpdate() - XDS not connected');
            return;
        }

        // Try to get SYSCLK from the clocking results (if available)
        // This uses the calculated SYSCLK from the clocking panel
        if (typeof clockingCheckResults !== 'undefined' && clockingCheckResults.sysclkMHz) {
            cputimerState.sysclkMHz = clockingCheckResults.sysclkMHz;
        }

        // Read each timer's registers
        for (let i = 0; i < 3; i++) {
            let base = CPUTIMER_BASES[i];
            let t = cputimerState.timer[i];

            try {
                // Read TIM (32-bit counter) - use symbolic name
                let timReg = 'CpuTimer' + i + 'Regs.TIM';

                let timVal = await xdsTransport.readValue(timReg);
                cdtDebugLog("  Raw TIM value: " + timVal + " (type: " + typeof timVal + ")");
                t.tim = parseTimer32BitReg(timVal);
                cdtDebugLog("  Parsed TIM: " + t.tim);
            } catch (e) {
                cdtDebugLog("  TIM symbolic read failed: " + e.message);
                // Fallback to direct address
                try {
                    let addr = '*0x' + (base + CPUTIMER_O_TIM).toString(16).padStart(8, '0');
                    cdtDebugLog("  Fallback to direct address: " + addr);
                    let timVal = await xdsTransport.readValue(addr);
                    cdtDebugLog("  Raw TIM value (direct): " + timVal);
                    t.tim = parseRegValue(timVal);
                } catch (e2) {
                    cdtDebugLog("  TIM direct read also failed: " + e2.message);
                    t.tim = 0;
                }
            }

            try {
                // Read PRD (32-bit period)
                let prdReg = 'CpuTimer' + i + 'Regs.PRD';

                let prdVal = await xdsTransport.readValue(prdReg);
                cdtDebugLog("  Raw PRD value: " + prdVal);
                t.prd = parseTimer32BitReg(prdVal);
                cdtDebugLog("  Parsed PRD: " + t.prd);
            } catch (e) {
                cdtDebugLog("  PRD symbolic read failed: " + e.message);
                try {
                    let addr = '*0x' + (base + CPUTIMER_O_PRD).toString(16).padStart(8, '0');
                    let prdVal = await xdsTransport.readValue(addr);
                    t.prd = parseRegValue(prdVal);
                } catch (e2) {
                    cdtDebugLog("  PRD direct read also failed: " + e2.message);
                    t.prd = 0;
                }
            }

            try {
                // Read TCR (control register)
                let tcrReg = 'CpuTimer' + i + 'Regs.TCR';

                let tcrVal = await xdsTransport.readValue(tcrReg);
                cdtDebugLog("  Raw TCR value: " + tcrVal);
                t.tcr = parseTimerTCR(tcrVal);
            } catch (e) {
                try {
                    let tcrVal = await xdsTransport.readValue('*0x' + (base + CPUTIMER_O_TCR).toString(16).padStart(8, '0'));
                    t.tcr = parseRegValue(tcrVal);
                } catch (e2) {
                    t.tcr = 0;
                }
            }

            try {
                // Read TPR and TPRH for full 16-bit prescale
                // TPR returns object with TDDR (divider) and PSC (counter) fields
                let tprReg = 'CpuTimer' + i + 'Regs.TPR';
                let tprVal = await xdsTransport.readValue(tprReg);
                let tpr = 0;
                if (typeof tprVal === 'object' && tprVal !== null && tprVal.TDDR !== undefined) {
                    tpr = parseRegValue(tprVal.TDDR) & 0xFF;
                } else {
                    tpr = parseRegValue(tprVal) & 0xFF;
                }

                let tprhReg = 'CpuTimer' + i + 'Regs.TPRH';
                let tprhVal = await xdsTransport.readValue(tprhReg);
                let tprh = 0;
                if (typeof tprhVal === 'object' && tprhVal !== null && tprhVal.TDDRH !== undefined) {
                    tprh = parseRegValue(tprhVal.TDDRH) & 0xFF;
                } else {
                    tprh = parseRegValue(tprhVal) & 0xFF;
                }

                t.prescale = (tprh << 8) | tpr;
                cdtDebugLog("  Prescale: TDDR=0x" + tpr.toString(16) + ", TDDRH=0x" + tprh.toString(16) + " => " + t.prescale);
            } catch (e) {
                cdtDebugLog("  Prescale read failed: " + e.message);
                t.prescale = 0;
            }

            // Log the timer state
            debugLog('read', 'TIMER' + i + ':', 'TIM=' + t.tim + ', PRD=' + t.prd + ', TCR=0x' + t.tcr.toString(16) + ', PS=' + t.prescale);

            // Update the card UI
            updateCputimerCard(i);
        }

        // Update SYSCLK display
        let sysclkEl = getCachedElement('cputimer_sysclk');
        if (sysclkEl) {
            sysclkEl.textContent = 'SYSCLK (' + cputimerState.sysclkMHz + ' MHz)';
        }

        debugLog('info', 'cputimerUpdate() completed');
        cdtDebugLog("cputimerUpdate() completed");
    } catch (error) {
        cdtError("cputimerUpdate() error:", error);
        debugLog('error', 'cputimerUpdate() exception:', '', error.message);
    }
}

//=============================================================================
// Auto-Update Feature - Periodic refresh of all diagnostic panels
//=============================================================================
// Update order matches GUI panel layout (left-to-right, top-to-bottom):
// Row 1: System, Pinmux
// Row 2: Clocking, Memory
// Row 3: Errata, Export Modules
// Tab 2: GPIO Diagnostics
//=============================================================================

let autoUpdateTimer = null;
let autoUpdateEnabled = false;
let autoUpdateInProgress = false;
let autoUpdateIntervalSec = 2;

/**
 * Perform a full update of all diagnostic panels
 * Order matches GUI panel layout for visual feedback consistency
 */
async function autoUpdateAll() {
    if (!autoUpdateEnabled) return;
    if (autoUpdateInProgress) {
        cdtDebugLog("Auto-update skipped - previous update still in progress");
        return;
    }
    if (!isXdsConnected('autoUpdateAll')) {
        stopAutoUpdate();
        return;
    }

    autoUpdateInProgress = true;
    cdtDebugLog("Auto-update running...");
    try {
        // Phase 1: Top row panels (System, Pinmux) - parallel
        await Promise.allSettled([
            systemUpdate(),
            pinmuxUpdate()
        ]);
        // Phase 2: Second row panels (Clocking, Memory) - parallel
        // Clocking must complete before errata (errata uses clock values)
        await Promise.allSettled([
            clockingUpdate(),
            memoryUpdate()
        ]);
        // Phase 3: Errata (depends on clocking), Interrupt, CPUTimer - parallel
        await Promise.allSettled([
            errataUpdate(),
            interruptUpdate(),
            cputimerUpdate()
        ]);
        // Phase 4: GPIO tab (includes XINT status LEDs)
        await gpioFullUpdate();
        cdtDebugLog("Auto-update completed");
    } catch (error) {
        cdtError("Auto-update error:", error);
    } finally {
        autoUpdateInProgress = false;
    }
}

/**
 * Start the auto-update timer
 */
function startAutoUpdate() {
    if (autoUpdateTimer) return;
    autoUpdateEnabled = true;
    let intervalMs = autoUpdateIntervalSec * 1000;
    autoUpdateTimer = setInterval(autoUpdateAll, intervalMs);
    updateAutoUpdateStatus(true);
    cdtDebugLog("Auto-update started: " + autoUpdateIntervalSec + "s interval");
}

/**
 * Stop the auto-update timer
 */
function stopAutoUpdate() {
    if (autoUpdateTimer) {
        clearInterval(autoUpdateTimer);
        autoUpdateTimer = null;
    }
    autoUpdateEnabled = false;
    updateAutoUpdateStatus(false);
    let checkbox = getCachedElement('auto_update_enable');
    if (checkbox) checkbox.checked = false;
    cdtDebugLog("Auto-update stopped");
}

/**
 * Update the auto-update status display
 */
function updateAutoUpdateStatus(active) {
    let status = getCachedElement('auto_update_status');
    if (status) {
        status.textContent = active ? 'Running' : '';
        status.className = 'auto_update_status' + (active ? ' active' : '');
    }
}

/**
 * Global cleanup handler for page unload
 * Ensures timers and event listeners are cleaned up when page is destroyed
 */
window.addEventListener('beforeunload', () => {
    stopAutoUpdate();
    cleanupEventListeners();
    clearDomCache();
});

//=============================================================================
// Timer Configuration Dialog Functions
//=============================================================================

let configTimerNum = 0;  // Which timer is being configured

/**
 * Open the timer configuration dialog with current values
 */
async function openTimerConfigDialog(timerNum) {
    configTimerNum = timerNum;
    let t = cputimerState.timer[timerNum];

    // Populate dialog with current values
    let timerName = getCachedElement('config_timer_name');
    if (timerName) timerName.textContent = 'TIMER' + timerNum;

    let prdInput = getCachedElement('config_prd');
    if (prdInput) prdInput.value = t.prd;

    let prescaleInput = getCachedElement('config_prescale');
    if (prescaleInput) prescaleInput.value = t.prescale;

    let intEnableInput = getCachedElement('config_int_enable');
    if (intEnableInput) intEnableInput.checked = (t.tcr & CPUTIMER_TCR_TIE) !== 0;

    // Update calculated frequencies
    updateConfigDialogFrequencies();

    // Open dialog
    let dialog = await gcWidgetQuery('#cputimer_config_dialog');
    if (dialog) {
        cdtDebugLog("Opening timer config dialog for TIMER" + timerNum);
        // Try different methods - gc-widget-dialog may use either
        if (typeof dialog.showModal === 'function') {
            dialog.showModal();
        } else if (typeof dialog.open === 'function') {
            dialog.open();
        } else {
            // Fallback: set open property
            dialog.open = true;
        }
    } else {
        cdtError("Timer config dialog not found");
        showToast('Could not open configuration dialog', 'error');
    }
}

/**
 * Update the frequency display in the configuration dialog
 */
function updateConfigDialogFrequencies() {
    let prdInput = getCachedElement('config_prd');
    let prescaleInput = getCachedElement('config_prescale');
    let counterFreqEl = getCachedElement('config_counter_freq');
    let intFreqEl = getCachedElement('config_int_freq');

    if (!prdInput || !prescaleInput || !counterFreqEl || !intFreqEl) return;

    let prd = parseInt(prdInput.value) || 0;
    let prescale = parseInt(prescaleInput.value) || 0;
    let sysclkMHz = cputimerState.sysclkMHz || 0;

    if (sysclkMHz > 0) {
        let counterFreqHz = (sysclkMHz * 1000000) / (prescale + 1);
        counterFreqEl.textContent = formatFrequency(counterFreqHz);

        if (prd > 0) {
            let intFreqHz = (sysclkMHz * 1000000) / ((prd + 1) * (prescale + 1));
            intFreqEl.textContent = formatFrequency(intFreqHz);
        } else {
            intFreqEl.textContent = '--';
        }
    } else {
        counterFreqEl.textContent = '--';
        intFreqEl.textContent = '--';
    }
}

/**
 * Apply the timer configuration from the dialog
 */
async function applyTimerConfig() {
    let timerNum = configTimerNum;

    let prdInput = getCachedElement('config_prd');
    let prescaleInput = getCachedElement('config_prescale');
    let intEnableInput = getCachedElement('config_int_enable');

    if (!prdInput || !prescaleInput || !intEnableInput) {
        cdtError("Cannot find config dialog inputs");
        return;
    }

    let prd = parseInt(prdInput.value) || 0;
    let prescale = parseInt(prescaleInput.value) || 0;
    let intEnable = intEnableInput.checked ? 1 : 0;

    // Validate and clamp values to valid ranges
    prd = Math.max(0, Math.min(4294967295, prd));  // 32-bit unsigned
    prescale = Math.max(0, Math.min(255, prescale));  // 8-bit unsigned

    cdtDebugLog("Applying timer config: TIMER" + timerNum + " PRD=" + prd + ", PS=" + prescale + ", TIE=" + intEnable);
    debugLog('info', 'Applying timer config to TIMER' + timerNum);

    if (!isXdsConnected('applyTimerConfig')) {
        showToast('Cannot configure timer - not connected', 'error');
        return;
    }

    try {
        // 1. Stop timer first (TSS=1)
        cdtDebugLog("  Step 1: Stopping timer");
        try {
            await xdsTransport.writeValue('CpuTimer' + timerNum + 'Regs.TCR.TSS', 1);
        } catch (e) {
            let base = CPUTIMER_BASES[timerNum];
            let tcrAddr = '*0x' + (base + CPUTIMER_O_TCR).toString(16).padStart(8, '0');
            let currentTcr = cputimerState.timer[timerNum].tcr || 0;
            let newTcr = currentTcr | CPUTIMER_TCR_TSS;
            await xdsTransport.writeValue(tcrAddr, newTcr);
        }
        debugLog('write', 'TIMER' + timerNum + '.TCR.TSS', '1');

        // 2. Write period
        cdtDebugLog("  Step 2: Writing PRD=" + prd);
        try {
            await xdsTransport.writeValue('CpuTimer' + timerNum + 'Regs.PRD', prd);
        } catch (e) {
            let base = CPUTIMER_BASES[timerNum];
            let prdAddr = '*0x' + (base + CPUTIMER_O_PRD).toString(16).padStart(8, '0');
            await xdsTransport.writeValue(prdAddr, prd);
        }
        debugLog('write', 'TIMER' + timerNum + '.PRD', String(prd));

        // 3. Write prescaler (lower 8 bits of TPR)
        cdtDebugLog("  Step 3: Writing prescaler=" + prescale);
        try {
            await xdsTransport.writeValue('CpuTimer' + timerNum + 'Regs.TPR.TDDR', prescale);
        } catch (e) {
            let base = CPUTIMER_BASES[timerNum];
            let tprAddr = '*0x' + (base + CPUTIMER_O_TPR).toString(16).padStart(8, '0');
            await xdsTransport.writeValue(tprAddr, prescale & 0xFF);
        }
        debugLog('write', 'TIMER' + timerNum + '.TPR.TDDR', String(prescale));

        // 4. Set interrupt enable
        cdtDebugLog("  Step 4: Setting TIE=" + intEnable);
        try {
            await xdsTransport.writeValue('CpuTimer' + timerNum + 'Regs.TCR.TIE', intEnable);
        } catch (e) {
            let base = CPUTIMER_BASES[timerNum];
            let tcrAddr = '*0x' + (base + CPUTIMER_O_TCR).toString(16).padStart(8, '0');
            let currentTcr = cputimerState.timer[timerNum].tcr || 0;
            let newTcr;
            if (intEnable) {
                newTcr = currentTcr | CPUTIMER_TCR_TIE;
            } else {
                newTcr = currentTcr & ~CPUTIMER_TCR_TIE;
            }
            await xdsTransport.writeValue(tcrAddr, newTcr);
        }
        debugLog('write', 'TIMER' + timerNum + '.TCR.TIE', String(intEnable));

        // 5. Reload timer (TRB=1)
        cdtDebugLog("  Step 5: Reloading timer (TRB)");
        try {
            await xdsTransport.writeValue('CpuTimer' + timerNum + 'Regs.TCR.TRB', 1);
        } catch (e) {
            cdtDebugLog("  TRB write failed, continuing...");
        }
        debugLog('write', 'TIMER' + timerNum + '.TCR.TRB', '1');

        // 6. Start timer (TSS=0)
        cdtDebugLog("  Step 6: Restarting timer");
        try {
            await xdsTransport.writeValue('CpuTimer' + timerNum + 'Regs.TCR.TSS', 0);
        } catch (e) {
            let base = CPUTIMER_BASES[timerNum];
            let tcrAddr = '*0x' + (base + CPUTIMER_O_TCR).toString(16).padStart(8, '0');
            let currentTcr = cputimerState.timer[timerNum].tcr || 0;
            let newTcr = currentTcr & ~CPUTIMER_TCR_TSS;
            await xdsTransport.writeValue(tcrAddr, newTcr);
        }
        debugLog('write', 'TIMER' + timerNum + '.TCR.TSS', '0');

        cdtDebugLog("Timer" + timerNum + " configuration applied - updating display");
        showToast('TIMER' + timerNum + ' configured successfully - click CDT tab to return', 'success', 4000);

        // Close dialog
        let dialog = await gcWidgetQuery('#cputimer_config_dialog');
        if (dialog) {
            dialog.close();
        }

        // 7. Refresh display
        await cputimerUpdate();

    } catch (error) {
        cdtError("Apply timer config error for TIMER" + timerNum + ":", error);
        debugLog('error', 'Apply timer config failed for TIMER' + timerNum + ':', '', error.message);
        showToast('Failed to configure TIMER' + timerNum, 'error');
    }
}

//=============================================================================
// Export All Functions - Export diagnostic data to JSON/Text/CSV
//=============================================================================

// Collect all diagnostic data from the panels
async function collectAllDiagnosticData() {
    cdtDebugLog("collectAllDiagnosticData() started");

    let data = {
        metadata: {
            exportDate: new Date().toISOString(),
            device: "`deviceName`",
            cdtVersion: "1.0.0",
            flashSizeKB: `deviceMem.flash`,
            ramSizeKB: `deviceMem.ram`
        },
        targetState: {},
        system: {},
        clocking: {},
        memory: {},
        errata: {},
        interrupt: {},
        timers: {},
        pinmux: {}
    };

    // Collect System panel values
    % for (var exportInfo of sysctlExports.exportsInfo) {
        % if (exportInfo.type === 'text' && exportInfo.applicable(null)){
    if (sysctl_`exportInfo.name`_value) {
        data.system['`exportInfo.name`'] = sysctl_`exportInfo.name`_value.label;
    }
        % }
        % if (exportInfo.type === 'led' && exportInfo.applicable(null)){
    if (sysctl_`exportInfo.name`_led) {
        data.system['`exportInfo.name`'] = sysctl_`exportInfo.name`_led.on;
    }
        % }
    % }

    // Collect Clocking panel values from global clockingCheckResults object
    // (LED.on is always true when loaded; actual pass/fail stored in clockingCheckResults)
    % for (var clockCheck of clockingChecks) {
        % if (clockCheck.applicable(deviceName)){
    if (clockingCheckResults.hasOwnProperty('`clockCheck.name`')) {
        data.clocking['`clockCheck.name`'] = clockingCheckResults['`clockCheck.name`'];
    }
        % }
    % }

    // Collect clock status flags from clockingCheckResults
    if (clockingCheckResults.hasOwnProperty('mclksts')) data.clocking['mclksts'] = clockingCheckResults['mclksts'];
    if (clockingCheckResults.hasOwnProperty('clockfail')) data.clocking['clockfail'] = clockingCheckResults['clockfail'];
    if (clockingCheckResults.hasOwnProperty('pllreflost')) data.clocking['pllreflost'] = clockingCheckResults['pllreflost'];

    // Collect Memory panel values
    data.memory.flashSizeKB = `deviceMem.flash`;
    data.memory.ramSizeKB = `deviceMem.ram`;
    % for (var exportInfo of memoryExports.exportsInfo) {
        % if (exportInfo.type === 'led' && exportInfo.applicable(null)){
    if (memory_`exportInfo.name`_led) {
        data.memory['`exportInfo.name`'] = memory_`exportInfo.name`_led.on;
    }
        % }
    % }

    // Collect Errata panel values from global errataCheckResults object
    // (LED.on indicates if peripheral is used; actual pass/fail stored in errataCheckResults)
    % for (var errataCheck of errataChecks) {
        % if (errataCheck.applicable(deviceName)){
    if (errataCheckResults.hasOwnProperty('`errataCheck.name`')) {
        data.errata['`errataCheck.name`'] = {
            status: !errataCheckResults['`errataCheck.name`'],  // Invert: result=true means NOT affected
            displayName: "`errataCheck.displayName`"
        };
    }
        % }
    % }

    // Collect Interrupt panel values
    % for (var exportInfo of interruptExports.exportsInfo) {
        % if (exportInfo.type === 'led' && exportInfo.applicable(null)){
    if (interrupt_`exportInfo.name`_led) {
        data.interrupt['`exportInfo.name`'] = interrupt_`exportInfo.name`_led.on;
    }
        % }
    % }

    // Collect Pinmux data - all GPIO banks with MUX, DIR, DAT, AMSEL registers
    data.pinmux = {
        packagePins: pinmuxState.packagePins,
        gpioUsed: pinmuxState.gpioUsed,
        gpioTotal: pinmuxState.gpioTotal,
        counts: {
            gpioInput: pinmuxState.counts.gpioInput,
            gpioOutput: pinmuxState.counts.gpioOutput,
            peripheral: pinmuxState.counts.periphInput + pinmuxState.counts.periphOutput,
            jtag: pinmuxState.counts.jtag,
            power: pinmuxState.counts.power,
            ground: pinmuxState.counts.ground,
            analog: pinmuxState.counts.analog,
            analogAvail: pinmuxState.counts.analogAvail
        },
        bankA: {
            dir: '0x' + pinmuxState.regs.dirA.toString(16).toUpperCase().padStart(8, '0'),
            dat: '0x' + pinmuxState.regs.datA.toString(16).toUpperCase().padStart(8, '0'),
            mux1: '0x' + pinmuxState.regs.mux1A.toString(16).toUpperCase().padStart(8, '0'),
            mux2: '0x' + pinmuxState.regs.mux2A.toString(16).toUpperCase().padStart(8, '0'),
            gmux1: '0x' + pinmuxState.regs.gmux1A.toString(16).toUpperCase().padStart(8, '0'),
            gmux2: '0x' + pinmuxState.regs.gmux2A.toString(16).toUpperCase().padStart(8, '0'),
            amsel: '0x' + pinmuxState.regs.amselA.toString(16).toUpperCase().padStart(8, '0')
        },
        bankB: {
            dir: '0x' + pinmuxState.regs.dirB.toString(16).toUpperCase().padStart(8, '0'),
            dat: '0x' + pinmuxState.regs.datB.toString(16).toUpperCase().padStart(8, '0'),
            mux1: '0x' + pinmuxState.regs.mux1B.toString(16).toUpperCase().padStart(8, '0'),
            mux2: '0x' + pinmuxState.regs.mux2B.toString(16).toUpperCase().padStart(8, '0'),
            gmux1: '0x' + pinmuxState.regs.gmux1B.toString(16).toUpperCase().padStart(8, '0'),
            gmux2: '0x' + pinmuxState.regs.gmux2B.toString(16).toUpperCase().padStart(8, '0')
        },
        bankH: {
            dir: '0x' + pinmuxState.regs.dirH.toString(16).toUpperCase().padStart(8, '0'),
            dat: '0x' + pinmuxState.regs.datH.toString(16).toUpperCase().padStart(8, '0'),
            mux1: '0x' + pinmuxState.regs.mux1H.toString(16).toUpperCase().padStart(8, '0'),
            mux2: '0x' + pinmuxState.regs.mux2H.toString(16).toUpperCase().padStart(8, '0'),
            gmux1: '0x' + pinmuxState.regs.gmux1H.toString(16).toUpperCase().padStart(8, '0'),
            gmux2: '0x' + pinmuxState.regs.gmux2H.toString(16).toUpperCase().padStart(8, '0'),
            amsel: '0x' + pinmuxState.regs.amselH.toString(16).toUpperCase().padStart(8, '0')
        }
    };

    // Collect Target State (debugger running/halted status)
    data.targetState = {
        state: currentTargetState,
        isRunning: currentTargetState === 'running' || currentTargetState === 'free_running',
        isHalted: currentTargetState === 'halted' || currentTargetState === 'suspended' || currentTargetState === 'stopped'
    };

    // Collect CPUTIMER data
    data.timers = {
        sysclkMHz: cputimerState.sysclkMHz || 0,
        timer0: {
            tim: cputimerState.timer[0].tim,
            prd: cputimerState.timer[0].prd,
            tcr: '0x' + (cputimerState.timer[0].tcr || 0).toString(16).toUpperCase().padStart(4, '0'),
            prescale: cputimerState.timer[0].prescale,
            isRunning: (cputimerState.timer[0].tcr & 0x0010) === 0,  // TSS bit
            isFreeRun: (cputimerState.timer[0].tcr & 0x1000) !== 0   // FREE bit
        },
        timer1: {
            tim: cputimerState.timer[1].tim,
            prd: cputimerState.timer[1].prd,
            tcr: '0x' + (cputimerState.timer[1].tcr || 0).toString(16).toUpperCase().padStart(4, '0'),
            prescale: cputimerState.timer[1].prescale,
            isRunning: (cputimerState.timer[1].tcr & 0x0010) === 0,
            isFreeRun: (cputimerState.timer[1].tcr & 0x1000) !== 0
        },
        timer2: {
            tim: cputimerState.timer[2].tim,
            prd: cputimerState.timer[2].prd,
            tcr: '0x' + (cputimerState.timer[2].tcr || 0).toString(16).toUpperCase().padStart(4, '0'),
            prescale: cputimerState.timer[2].prescale,
            isRunning: (cputimerState.timer[2].tcr & 0x0010) === 0,
            isFreeRun: (cputimerState.timer[2].tcr & 0x1000) !== 0
        }
    };

    cdtDebugLog("collectAllDiagnosticData() completed");
    return data;
}

// Format data as text report
function formatAsText(data) {
    let lines = [];
    lines.push("=".repeat(60));
    lines.push("CDT Diagnostic Export Report");
    lines.push("=".repeat(60));
    lines.push("");
    lines.push("METADATA");
    lines.push("-".repeat(40));
    lines.push("Export Date: " + data.metadata.exportDate);
    lines.push("Device: " + data.metadata.device);
    lines.push("Flash: " + data.metadata.flashSizeKB + " KB");
    lines.push("RAM: " + data.metadata.ramSizeKB + " KB");
    lines.push("");

    lines.push("TARGET STATE");
    lines.push("-".repeat(40));
    lines.push("State: " + (data.targetState.state || 'unknown').toUpperCase());
    lines.push("Is Running: " + (data.targetState.isRunning ? 'YES' : 'NO'));
    lines.push("Is Halted: " + (data.targetState.isHalted ? 'YES' : 'NO'));
    lines.push("");

    lines.push("SYSTEM");
    lines.push("-".repeat(40));
    for (let key in data.system) {
        let val = data.system[key];
        lines.push(key + ": " + (typeof val === 'boolean' ? (val ? 'ACTIVE' : 'OK') : val));
    }
    lines.push("");

    lines.push("CLOCKING");
    lines.push("-".repeat(40));
    for (let key in data.clocking) {
        let val = data.clocking[key];
        // val=true means check passed (green), val=false means check failed (red)
        lines.push(key + ": " + (val ? 'PASS' : 'FAIL'));
    }
    lines.push("");

    lines.push("MEMORY");
    lines.push("-".repeat(40));
    for (let key in data.memory) {
        let val = data.memory[key];
        if (typeof val === 'boolean') {
            lines.push(key + ": " + (val ? 'ERROR' : 'OK'));
        } else {
            lines.push(key + ": " + val);
        }
    }
    lines.push("");

    lines.push("ERRATA");
    lines.push("-".repeat(40));
    for (let key in data.errata) {
        let info = data.errata[key];
        lines.push(info.displayName + ": " + (info.status ? 'AFFECTED' : 'NOT AFFECTED'));
    }
    lines.push("");

    lines.push("INTERRUPT");
    lines.push("-".repeat(40));
    for (let key in data.interrupt) {
        let val = data.interrupt[key];
        lines.push(key + ": " + (val ? 'ACTIVE' : 'OK'));
    }
    lines.push("");

    lines.push("CPUTIMERS (SYSCLK = " + data.timers.sysclkMHz + " MHz)");
    lines.push("-".repeat(40));
    for (let i = 0; i < 3; i++) {
        let t = data.timers['timer' + i];
        let status = t.isRunning ? 'RUNNING' : 'STOPPED';
        if (t.isFreeRun) status += ' (FREE RUN)';
        lines.push("TIMER" + i + ": " + status);
        lines.push("  TIM: " + t.tim + ", PRD: " + t.prd + ", TCR: " + t.tcr + ", PS: " + t.prescale);
    }
    lines.push("");

    lines.push("PINMUX (" + data.pinmux.packagePins + "-pin package)");
    lines.push("-".repeat(40));
    lines.push("Pin Counts:");
    lines.push("  GPIO Input:  " + data.pinmux.counts.gpioInput + "    GPIO Output: " + data.pinmux.counts.gpioOutput);
    lines.push("  Peripheral:  " + data.pinmux.counts.peripheral + "    JTAG: " + data.pinmux.counts.jtag);
    lines.push("  Power:       " + data.pinmux.counts.power + "    Ground: " + data.pinmux.counts.ground);
    lines.push("  Analog:      " + data.pinmux.counts.analog + "/" + data.pinmux.counts.analogAvail + " (used/avail)");
    lines.push("");
    lines.push("Bank A (GPIO 0-31):");
    lines.push("  DIR:   " + data.pinmux.bankA.dir);
    lines.push("  DAT:   " + data.pinmux.bankA.dat);
    lines.push("  MUX1:  " + data.pinmux.bankA.mux1 + "  GMUX1: " + data.pinmux.bankA.gmux1);
    lines.push("  MUX2:  " + data.pinmux.bankA.mux2 + "  GMUX2: " + data.pinmux.bankA.gmux2);
    lines.push("  AMSEL: " + data.pinmux.bankA.amsel);
    lines.push("");
    lines.push("Bank B (GPIO 32-63):");
    lines.push("  DIR:   " + data.pinmux.bankB.dir);
    lines.push("  DAT:   " + data.pinmux.bankB.dat);
    lines.push("  MUX1:  " + data.pinmux.bankB.mux1 + "  GMUX1: " + data.pinmux.bankB.gmux1);
    lines.push("  MUX2:  " + data.pinmux.bankB.mux2 + "  GMUX2: " + data.pinmux.bankB.gmux2);
    lines.push("");
    lines.push("Bank H (GPIO 224-255):");
    lines.push("  DIR:   " + data.pinmux.bankH.dir);
    lines.push("  DAT:   " + data.pinmux.bankH.dat);
    lines.push("  MUX1:  " + data.pinmux.bankH.mux1 + "  GMUX1: " + data.pinmux.bankH.gmux1);
    lines.push("  MUX2:  " + data.pinmux.bankH.mux2 + "  GMUX2: " + data.pinmux.bankH.gmux2);
    lines.push("  AMSEL: " + data.pinmux.bankH.amsel);
    lines.push("");
    lines.push("=".repeat(60));

    return lines.join("\n");
}

// Format data as CSV
function formatAsCSV(data) {
    let lines = [];
    lines.push("Category,Name,Value,Status");

    // Metadata
    lines.push("Metadata,exportDate," + data.metadata.exportDate + ",");
    lines.push("Metadata,device," + data.metadata.device + ",");
    lines.push("Metadata,flashSizeKB," + data.metadata.flashSizeKB + ",");
    lines.push("Metadata,ramSizeKB," + data.metadata.ramSizeKB + ",");

    // Target State
    lines.push("TargetState,state," + data.targetState.state + "," + (data.targetState.state || 'unknown').toUpperCase());
    lines.push("TargetState,isRunning," + data.targetState.isRunning + "," + (data.targetState.isRunning ? 'YES' : 'NO'));
    lines.push("TargetState,isHalted," + data.targetState.isHalted + "," + (data.targetState.isHalted ? 'YES' : 'NO'));

    // System
    for (let key in data.system) {
        let val = data.system[key];
        let status = typeof val === 'boolean' ? (val ? 'ACTIVE' : 'OK') : '';
        lines.push("System," + key + "," + val + "," + status);
    }

    // Clocking
    for (let key in data.clocking) {
        let val = data.clocking[key];
        // val=true means check passed (green), val=false means check failed (red)
        lines.push("Clocking," + key + "," + val + "," + (val ? 'PASS' : 'FAIL'));
    }

    // Memory
    for (let key in data.memory) {
        let val = data.memory[key];
        let status = typeof val === 'boolean' ? (val ? 'ERROR' : 'OK') : '';
        lines.push("Memory," + key + "," + val + "," + status);
    }

    // Errata
    for (let key in data.errata) {
        let info = data.errata[key];
        lines.push("Errata," + info.displayName + "," + info.status + "," + (info.status ? 'AFFECTED' : 'NOT AFFECTED'));
    }

    // Interrupt
    for (let key in data.interrupt) {
        let val = data.interrupt[key];
        lines.push("Interrupt," + key + "," + val + "," + (val ? 'ACTIVE' : 'OK'));
    }

    // Timers
    lines.push("Timers,sysclkMHz," + data.timers.sysclkMHz + ",");
    for (let i = 0; i < 3; i++) {
        let t = data.timers['timer' + i];
        let status = t.isRunning ? 'RUNNING' : 'STOPPED';
        lines.push("Timers,timer" + i + "_tim," + t.tim + ",");
        lines.push("Timers,timer" + i + "_prd," + t.prd + ",");
        lines.push("Timers,timer" + i + "_tcr," + t.tcr + ",");
        lines.push("Timers,timer" + i + "_prescale," + t.prescale + ",");
        lines.push("Timers,timer" + i + "_isRunning," + t.isRunning + "," + status);
        lines.push("Timers,timer" + i + "_isFreeRun," + t.isFreeRun + "," + (t.isFreeRun ? 'FREE RUN' : ''));
    }

    // Pinmux
    lines.push("Pinmux,packagePins," + data.pinmux.packagePins + ",");
    lines.push("Pinmux,gpioInput," + data.pinmux.counts.gpioInput + ",");
    lines.push("Pinmux,gpioOutput," + data.pinmux.counts.gpioOutput + ",");
    lines.push("Pinmux,peripheral," + data.pinmux.counts.peripheral + ",");
    lines.push("Pinmux,jtag," + data.pinmux.counts.jtag + ",");
    lines.push("Pinmux,power," + data.pinmux.counts.power + ",");
    lines.push("Pinmux,ground," + data.pinmux.counts.ground + ",");
    lines.push("Pinmux,analog," + data.pinmux.counts.analog + "/" + data.pinmux.counts.analogAvail + ",");
    lines.push("Pinmux,bankA_dir," + data.pinmux.bankA.dir + ",");
    lines.push("Pinmux,bankA_dat," + data.pinmux.bankA.dat + ",");
    lines.push("Pinmux,bankA_mux1," + data.pinmux.bankA.mux1 + ",");
    lines.push("Pinmux,bankA_mux2," + data.pinmux.bankA.mux2 + ",");
    lines.push("Pinmux,bankB_dir," + data.pinmux.bankB.dir + ",");
    lines.push("Pinmux,bankB_dat," + data.pinmux.bankB.dat + ",");
    lines.push("Pinmux,bankB_mux1," + data.pinmux.bankB.mux1 + ",");
    lines.push("Pinmux,bankB_mux2," + data.pinmux.bankB.mux2 + ",");

    return lines.join("\n");
}

// Format export data based on selected format
function formatExportData(data, format) {
    switch (format) {
        case 'json':
            return JSON.stringify(data, null, 2);
        case 'text':
            return formatAsText(data);
        case 'csv':
            return formatAsCSV(data);
        default:
            return JSON.stringify(data, null, 2);
    }
}

// Download export as file
function downloadExport(content, format) {
    let filename = 'cdt_export_' + new Date().toISOString().replace(/[:.]/g, '-');
    let mimeType = 'text/plain';

    switch (format) {
        case 'json':
            filename += '.json';
            mimeType = 'application/json';
            break;
        case 'csv':
            filename += '.csv';
            mimeType = 'text/csv';
            break;
        default:
            filename += '.txt';
    }

    let blob = new Blob([content], { type: mimeType });
    let url = URL.createObjectURL(blob);
    let a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);

    cdtInfo("Downloaded export as: " + filename);
}

// Copy to clipboard - uses textarea selection method for GUI Composer compatibility
function copyToClipboard(content, sourceTextarea = null) {
    try {
        // Method 1: If we have a source textarea, select and copy from it directly
        if (sourceTextarea && sourceTextarea.value) {
            sourceTextarea.focus();
            sourceTextarea.select();
            sourceTextarea.setSelectionRange(0, sourceTextarea.value.length);
            let success = document.execCommand('copy');
            if (success) {

                return true;
            }
        }

        // Method 2: Create temporary textarea and copy
        let tempTextarea = document.createElement('textarea');
        tempTextarea.value = content;
        tempTextarea.style.position = 'fixed';
        tempTextarea.style.left = '-9999px';
        tempTextarea.style.top = '0';
        tempTextarea.setAttribute('readonly', '');
        document.body.appendChild(tempTextarea);
        tempTextarea.focus();
        tempTextarea.select();
        tempTextarea.setSelectionRange(0, content.length);
        let success = document.execCommand('copy');
        document.body.removeChild(tempTextarea);
        if (success) {

            return true;
        }

        // Method 3: Try navigator.clipboard as last resort
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(content).then(() => {

            }).catch(err => {
                cdtError("All clipboard methods failed:", err);
            });
            return true;
        }

        cdtError("No clipboard method available");
        return false;
    } catch (e) {
        cdtError("Clipboard copy error:", e);
        return false;
    }
}

// Main export handler - collects all diagnostic data and formats it
// If showDialog=true, opens the export dialog with the content
// If showDialog=false, just returns the content (for clipboard copy)
async function exportAllDiagnostics(format, showDialog = false) {
    cdtDebugLog("exportAllDiagnostics() started - format:", format, "showDialog:", showDialog);

    try {
        let data = await collectAllDiagnosticData();
        let content = formatExportData(data, format);
        cdtDebugLog("exportAllDiagnostics() data collected - " + content.length + " bytes");

        if (showDialog) {
            // Open the export dialog and populate it with content
            // Use document.querySelector for gc-widget-dialog (same pattern as show_registers_dialog)
            let dialog = document.querySelector('#export_all_dialog');
            let textarea = document.getElementById('export_all_textarea');

            cdtDebugLog("Dialog elements - dialog:", !!dialog, "textarea:", !!textarea);

            // Populate textarea with content
            if (textarea) {
                textarea.value = content;
                cdtDebugLog("Textarea populated with " + content.length + " bytes");
            }

            // Update labels using document.querySelector
            let formatLabel = document.querySelector('#export_dialog_format_lbl');
            let sizeLabel = document.querySelector('#export_dialog_size_lbl');
            if (formatLabel) {
                formatLabel.setAttribute('label', "Format: " + format.toUpperCase());
            }
            if (sizeLabel) {
                sizeLabel.setAttribute('label', "Size: " + content.length + " bytes");
            }

            // Open the dialog using .open() METHOD (not .open property!)
            // This is the same pattern used by show_registers_dialog
            if (dialog) {
                cdtDebugLog("Calling dialog.open() method...");
                dialog.open();
                cdtDebugLog("Dialog opened successfully");
            } else {
                cdtError("Export dialog element not found - check element ID");
                alert("Export data ready (" + content.length + " bytes).\nDialog unavailable - check console for data.");
                cdtDebugLog("EXPORT DATA:\n" + content);
            }
        }

        return content;
    } catch (error) {
        cdtError("exportAllDiagnostics() error:", error);
        cdtError("Stack:", error.stack);
        alert("Export failed: " + error.message);
        return null;
    }
}

% }

/**
 -------------------------------------------------------------------------------------------------------------------------------
Bindings setup
-------------------------------------------------------------------------------------------------------------------------------
**/
(async () => {
    /* Wait for widget and target models to be ready */
    await bindingRegistry.waitForModelReady('widget');
    
    % if (transferCommon.isC2000() && (gui.deviceDiagnosticExportMode != "none")) {
    % for (var expModName of expModuleNames) {
        % let mod = system.modules["/driverlib/" + expModName + ".js"];
        % let modExports = system.getScript("/utilities/transfer/export/mods/export_mod_" + expModName + ".js");
        % if (mod && (exportCommon.getNonExporterInstances(mod).length > 0)) {
    //
    // `expModName.toUpperCase()`
    //
            % for (var modInst of exportCommon.getNonExporterInstances(mod)) {
    /* A simple computed values based on simple expression */
    bindingRegistry.bind(
        'widget.page_module_`modInst.$name`_led.on', {
        /* Dependant bindings needed in order to compute the date, in name/value pairs */
            % for (let exportInfo of exportCommon.getInstanceExportModsInfoWithType(modInst, modExports.exportsInfo, "led")) {
            `exportInfo.name`: "widget.page_`expModName`_`modInst.$name`_`exportInfo.name`_led.on",
            % }
        },
        /* Getter for date computation */
        function(values) {
            /* compute and return the string value to bind to the widget with id 'date' */
            return `exportCommon.getInstanceExportModsInfoWithType(modInst, modExports.exportsInfo, "led").map(exportInfo => "values." + exportInfo.name).join(" || ")`;
        }
    );
            % }
        % }
    % }
    // Note: Always modules (sysctl) summary LED is updated directly in systemUpdate()
    // instead of using bindings, to avoid binding errors when individual LEDs don't exist
    % }
    
    % if (gui.deviceDiagnosticExportMode == "xds") {
    await bindingRegistry.waitForModelReady('pm');
    % } 
    % if (gui.exporter) {
    await bindingRegistry.waitForModelReady('streaming');
    % }

    const activeConfigurationChangedHandler = () => {
        cdtDebugLog("[CDT INIT] activeConfigurationChangedHandler triggered");
        for (let activeTransport of connectionManager.getActiveTransports()) {
            if (activeTransport.id === "xds")
            {
                cdtDebugLog("[CDT INIT] XDS transport found, state: " + activeTransport.state);
                xdsTransport = activeTransport;
                cdtInitState.xdsReady = true;

                // Check if already connected
                if (activeTransport.state === 'connected') {
                    cdtInitState.xdsConnected = true;
                    cdtDebugLog("[CDT INIT] XDS already connected!");
                    processPendingOperations();
                }

                registerEventListener(activeTransport,
                    connectedStateChangedEventType,
                    xdsTransportConnectionChangeHandler);
            }
            if (activeTransport.id === "usb")
            {
                usbTransport = activeTransport;
                registerEventListener(activeTransport,
                    connectedStateChangedEventType,
                    usbTransportConnectionChangeHandler);
            }
        }
    };
    registerEventListener(connectionManager, activeConfigurationChangedEvent, activeConfigurationChangedHandler);

    % if (transferCommon.isC2000() && (gui.deviceDiagnosticExportMode != "none")) {
    % for (var expModName of expModuleNames) {
        % let mod = system.modules["/driverlib/" + expModName + ".js"];
        % let modExports = system.getScript("/utilities/transfer/export/mods/export_mod_" + expModName + ".js");
        % if (gui.deviceDiagnosticExportMode == "xds") {
    //
    // `expModName.toUpperCase()`
    //
        % if (mod) {
            % for (var modInst of exportCommon.getNonExporterInstances(mod)) {
                % for (let exportInfo of exportCommon.getInstanceExportModsInfo(modInst, modExports.exportsInfo)) {
                    % let regInstName = exportCommon.getExportModInfoBitfieldRegForInst(modInst, expModName, modExports.bitfieldInstanceNames, exportInfo);
                    % if (exportInfo.type == "led") {
    bindingRegistry.bind("widget.page_`expModName`_`modInst.$name`_`exportInfo.name`_led.on", 'pm.`regInstName`.`exportInfo.register`',
        function(value) {
            /* compute and return the string value to bind to the widget with id 'date' */
            return !!parseInt(value);
        }
    );
                    % } else if (exportInfo.type == "value") {
    // Bind value type to label text instead of LED
    // Handle 32-bit values that may come as objects with low/high properties
    bindingRegistry.bind("widget.page_`expModName`_`modInst.$name`_`exportInfo.name`_val.label", 'pm.`regInstName`.`exportInfo.register`',
        function(value) {
            if (value === undefined || value === null) return '--';
            // Handle object values (32-bit registers may return {low, high} or similar)
            if (typeof value === 'object') {
                // Try common object formats for 32-bit values
                if (value.low !== undefined && value.high !== undefined) {
                    return String((value.high * 0x10000) + value.low);
                } else if (value.value !== undefined) {
                    return String(value.value);
                } else {
                    // Try to extract numeric value
                    return String(parseInt(value) || JSON.stringify(value));
                }
            }
            return String(value);
        }
    );
                    % } else {
    bindingRegistry.bind("widget.page_`expModName`_`modInst.$name`_`exportInfo.name`_led.on", 'pm.`regInstName`.`exportInfo.register`');
                    % }
                % }
            % }
        % }
    % } else if (gui.deviceDiagnosticExportMode == "exporter") {
        % if (mod && (exportCommon.getNonExporterInstances(mod).length > 0)) {
    //
    // `expModName.toUpperCase()`
    //
            % for (var modInst of exportCommon.getNonExporterInstances(mod)) {
                % for (let exportInfo of exportCommon.getInstanceExportModsInfo(modInst, modExports.exportsInfo)) {
                    % if (exportInfo.type == "led") {
    bindingRegistry.bind("widget.page_`expModName`_`modInst.$name`_`exportInfo.name`_led.on", "streaming.`modInst.$name`_`exportInfo.name`",
        function(value) {
            /* compute and return the string value to bind to the widget with id 'date' */
            return !!parseInt(value);
        }
    );
                    % } else if (exportInfo.type == "value") {
    // Bind value type to label text instead of LED
    // Handle 32-bit values that may come as objects with low/high properties
    bindingRegistry.bind("widget.page_`expModName`_`modInst.$name`_`exportInfo.name`_val.label", "streaming.`modInst.$name`_`exportInfo.name`",
        function(value) {
            if (value === undefined || value === null) return '--';
            // Handle object values (32-bit registers may return {low, high} or similar)
            if (typeof value === 'object') {
                // Try common object formats for 32-bit values
                if (value.low !== undefined && value.high !== undefined) {
                    return String((value.high * 0x10000) + value.low);
                } else if (value.value !== undefined) {
                    return String(value.value);
                } else {
                    // Try to extract numeric value
                    return String(parseInt(value) || JSON.stringify(value));
                }
            }
            return String(value);
        }
    );
                    % } else {
    bindingRegistry.bind("widget.page_`expModName`_`modInst.$name`_`exportInfo.name`_led.on", "streaming.`modInst.$name`_`exportInfo.name`");
                    % }
                % }
            % }
        % }
    % }
    % }
    % //
    % // Always Modules (sysctl) - Skip bindings since we use direct updates in systemUpdate()
    % // The LEDs are updated directly via systemUpdate() function instead of using bindings
    % }
% if (gui.fsilogger) {
    //
    // FSI Logger bindings
    //
    bindingRegistry.getBinding('model.streaming.fsiLog').addEventListener(valueChangedEventType, e => {
        var fsiLoggerElement = {
            user_data: e.newValue.u,
            frame_tag: e.newValue.ta,
            frame_type: e.newValue.ty,
            crc: e.newValue.c,
            data_words: e.newValue.d,
        };
        if (e.newValue.d && (e.newValue.d.split(",").length > 0)){
            fsiLoggerElement.data_words_child = []
            for (var childDw of e.newValue.d.split(",")){
                fsiLoggerElement.data_words_child.push({
                    data_words: childDw
                })
            }
        }
        fsiLoggerGridData.push(fsiLoggerElement);
        fsiLoggerGridUpdateUI();

    % if (gui.rtlogger) {
        var rtLoggerElement = {
            user_data: e.newValue.u,
            frame_tag: e.newValue.ta,
            frame_type: e.newValue.ty,
            crc: e.newValue.c,
            data_words: e.newValue.d,
            log_var_name: "",
            log_varval: "",
        };           
        rtLoggerElement.data_words_child = [];
        % let index = 0;
        let fsiFrame = e.newValue;
        let fsiDataArray = fsiFrame.d.split(",").map(Number);

        % let msgTypes = rtLogMsgTypes;
        % if (msgTypes){         
        % for (let mt of msgTypes){
        if (fsiFrame.u == `mt.id`) {            
        let variables = RTLogParseMessage`mt.id`(fsiDataArray);
        % for (let logVar of mt.logVariables) {
        rtLoggerElement.data_words_child.push({
        log_var_name: "`logVar.$name`",
        log_varval: variables[`index`]
        })
            % index++;
        % }
        }

            % index = 0;
            % }
        % }
    % }
        rtLoggerGridData.push(rtLoggerElement);
        rtLoggerGridUpdateUI();
    });
% }

