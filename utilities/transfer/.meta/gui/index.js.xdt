GcConsole.setLevel('myapp', 4);         // enable console output for myapp console instance
// Load notification moved to cdtInfo() after logging system is initialized (see initLogging())

//=============================================================================
// Debug Panel - XDS/XDT Debug Log
//=============================================================================

let debugLogEntries = [];
let debugReadCount = 0;
let debugWriteCount = 0;
let debugErrorCount = 0;
let debugPanelOpen = false;
const DEBUG_LOG_MAX_ENTRIES = 1000;

// Toggle debug panel visibility
function toggleDebugPanel() {
    let panel = getCachedElement('debug_panel');
    let toggle = getCachedElement('debug_panel_toggle');
    if (panel && toggle) {
        debugPanelOpen = !debugPanelOpen;
        if (debugPanelOpen) {
            panel.classList.remove('collapsed');
            toggle.classList.add('panel_open');
            // Update UI immediately when panel is opened to show collected entries
            updateDebugLogUI();
        } else {
            panel.classList.add('collapsed');
            toggle.classList.remove('panel_open');
            // Reset inline styles set by resize handler to allow CSS to control position
            toggle.style.right = '';
            panel.style.width = '';
            document.documentElement.style.removeProperty('--debug-panel-width');
        }
    }
}

// Debug panel resize functionality
let debugPanelResizing = false;
let debugPanelStartX = 0;
let debugPanelStartWidth = 450;

function initDebugPanelResize() {
    const resizeHandle = document.getElementById('debug_panel_resize_handle');
    const panel = document.getElementById('debug_panel');
    const toggle = document.getElementById('debug_panel_toggle');

    if (!resizeHandle || !panel) return;

    resizeHandle.addEventListener('mousedown', (e) => {
        debugPanelResizing = true;
        debugPanelStartX = e.clientX;
        debugPanelStartWidth = panel.offsetWidth;
        resizeHandle.classList.add('dragging');
        e.preventDefault();
    });

    document.addEventListener('mousemove', (e) => {
        if (!debugPanelResizing) return;

        const deltaX = debugPanelStartX - e.clientX;
        let newWidth = debugPanelStartWidth + deltaX;

        // Clamp width between min and max
        newWidth = Math.max(300, Math.min(newWidth, window.innerWidth * 0.8));

        panel.style.width = newWidth + 'px';
        document.documentElement.style.setProperty('--debug-panel-width', newWidth + 'px');

        if (toggle) {
            toggle.style.right = newWidth + 'px';
        }
    });

    document.addEventListener('mouseup', () => {
        if (debugPanelResizing) {
            debugPanelResizing = false;
            const resizeHandle = document.getElementById('debug_panel_resize_handle');
            if (resizeHandle) resizeHandle.classList.remove('dragging');
        }
    });
}

// Add entry to debug log
function debugLog(type, message, register, value) {
    register = register || '';
    value = (value !== undefined) ? value : '';
    let timestamp = new Date().toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
    let entry = { timestamp: timestamp, type: type, message: message, register: register, value: value };
    debugLogEntries.push(entry);

    // Update counters
    if (type === 'read') debugReadCount++;
    else if (type === 'write') debugWriteCount++;
    else if (type === 'error') debugErrorCount++;

    // Trim log if too large
    if (debugLogEntries.length > DEBUG_LOG_MAX_ENTRIES) {
        debugLogEntries = debugLogEntries.slice(-DEBUG_LOG_MAX_ENTRIES);
    }

    // Update UI if panel is open
    if (debugPanelOpen) {
        updateDebugLogUI();
    }
}

// Track last rendered index for incremental updates
let debugLogLastRenderedIndex = 0;

// Create a log entry element using safe DOM methods
function createDebugLogEntryElement(e) {
    let div = document.createElement('div');
    div.className = 'debug_log_entry';

    let timestamp = document.createElement('span');
    timestamp.className = 'debug_log_timestamp';
    timestamp.textContent = e.timestamp;
    div.appendChild(timestamp);

    let type = document.createElement('span');
    type.className = 'debug_log_type ' + e.type;
    type.textContent = '[' + e.type.toUpperCase() + ']';
    div.appendChild(type);

    div.appendChild(document.createTextNode(e.message + ' '));

    if (e.register) {
        let reg = document.createElement('span');
        reg.className = 'debug_log_register';
        reg.textContent = e.register;
        div.appendChild(reg);
    }
    if (e.value !== '') {
        div.appendChild(document.createTextNode(' = '));
        let val = document.createElement('span');
        val.className = 'debug_log_value';
        val.textContent = e.value;
        div.appendChild(val);
    }
    return div;
}

// Update debug log UI - uses incremental updates for performance
function updateDebugLogUI() {
    let content = getCachedElement('debug_log_content');
    if (!content) return;

    // Only append new entries since last render
    let newEntries = debugLogEntries.slice(debugLogLastRenderedIndex);
    if (newEntries.length > 0) {
        let fragment = document.createDocumentFragment();
        newEntries.forEach(e => fragment.appendChild(createDebugLogEntryElement(e)));
        content.appendChild(fragment);
        debugLogLastRenderedIndex = debugLogEntries.length;

        // Trim old entries from DOM if over 200
        while (content.children.length > 200) {
            content.removeChild(content.firstChild);
        }
    }

    content.scrollTop = content.scrollHeight;

    // Update stats (using cached elements)
    setCachedElementText('debug_read_count', debugReadCount);
    setCachedElementText('debug_write_count', debugWriteCount);
    setCachedElementText('debug_error_count', debugErrorCount);
}

// Clear debug log
function clearDebugLog() {
    debugLogEntries = [];
    debugReadCount = 0;
    debugWriteCount = 0;
    debugErrorCount = 0;
    debugLogLastRenderedIndex = 0;
    let content = getCachedElement('debug_log_content');
    if (content) content.textContent = '';  // Clear all entries
    updateDebugLogUI();
}

// Copy debug log to clipboard
function copyDebugLog() {
    let text = debugLogEntries.map(function(e) {
        let line = '[' + e.timestamp + '] [' + e.type.toUpperCase() + '] ' + e.message;
        if (e.register) line += ' ' + e.register;
        if (e.value !== '') line += ' = ' + e.value;
        return line;
    }).join('\n');

    navigator.clipboard.writeText(text).then(function() {
        alert('Debug log copied to clipboard (' + debugLogEntries.length + ' entries)');
    }).catch(function(err) {
        cdtError('Failed to copy debug log:', err);
    });
}

// XDS Read with debug logging
async function xdsReadValue(register) {
    if (!isXdsConnected('xdsReadValue')) return null;
    try {
        let value = await xdsTransport.readValue(register);
        debugLog('read', '', register, value);
        return value;
    } catch (err) {
        debugLog('error', err.message, register);
        throw err;
    }
}

// XDS Write with debug logging
async function xdsWriteValue(register, value) {
    if (!isXdsConnected('xdsWriteValue')) return false;
    try {
        await xdsTransport.writeValue(register, value);
        debugLog('write', '', register, value);
        return true;
    } catch (err) {
        debugLog('error', err.message, register);
        throw err;
    }
}

/**
 * Check if XDS transport is connected
 * @param {string} callerName - Name of calling function for logging
 * @returns {boolean} - True if connected
 */
function isXdsConnected(callerName) {
    if (!xdsTransport || xdsTransport.state !== 'connected') {
        cdtWarn(callerName + " skipped - XDS not connected");
        debugLog('error', callerName + ' - XDS not connected');
        return false;
    }
    return true;
}

/**
 * Wrap an update function with XDS connection check and toast notification.
 * @param {Function} updateFn - The update function to call
 * @param {string} panelName - Name of the panel for error message (e.g., "pinmux", "GPIO")
 * @returns {Function} - Wrapped function that checks XDS before calling updateFn
 */
function withXdsGuard(updateFn, panelName) {
    return function(...args) {
        debugLog('info', 'Update button clicked:', panelName.toUpperCase(), 'panel');
        cdtDebugLog('[CDT] Update button clicked: ' + panelName);
        if (!isXdsReady()) {
            debugLog('error', 'Update failed - XDS not connected:', panelName.toUpperCase(), '');
            showToast('XDS not connected - cannot update ' + panelName, 'error');
            return;
        }
        return updateFn.apply(this, args);
    };
}

/**
 * Read multiple registers in parallel for better performance
 * @param {Array<string>} registers - Array of register names to read
 * @returns {Promise<Array<{name: string, value: number, error: string|null}>>}
 */
async function readRegistersParallel(registers) {
    if (!isXdsConnected('readRegistersParallel')) {
        return registers.map(reg => ({ name: reg, value: 0, error: 'Not connected' }));
    }
    const results = await Promise.allSettled(
        registers.map(reg => xdsTransport.readValue(reg))
    );
    return results.map((r, i) => ({
        name: registers[i],
        value: r.status === 'fulfilled' ? (parseInt(r.value) || 0) : 0,
        error: r.status === 'rejected' ? r.reason?.message : null
    }));
}

/**
 * Write to a register with symbolic name fallback to direct address
 * @param {string} symbolicReg - Symbolic register name (e.g., 'CpuTimer0Regs.TCR.TSS')
 * @param {string} addressReg - Direct address register (e.g., '*0x00000C04')
 * @param {number} value - Value to write
 * @param {string} logName - Name for debug logging
 * @returns {Promise<boolean>} - True if write succeeded
 */
async function xdsWriteWithFallback(symbolicReg, addressReg, value, logName) {
    if (!isXdsConnected('xdsWriteWithFallback')) return false;
    try {
        await xdsTransport.writeValue(symbolicReg, value);
        debugLog('write', logName, String(value));
        return true;
    } catch (e) {
        cdtDebugLog("  Symbolic write failed, trying direct address");
        try {
            await xdsTransport.writeValue(addressReg, value);
            debugLog('write', logName, String(value));
            return true;
        } catch (e2) {
            cdtError("  Direct address write also failed:", e2.message);
            debugLog('error', logName + ' write failed:', '', e2.message);
            return false;
        }
    }
}

/**
 * CDT Log Level Configuration
 * Set to control console output verbosity:
 *   0 = NONE   - No logging (production)
 *   1 = ERROR  - Only errors
 *   2 = WARN   - Errors + warnings
 *   3 = INFO   - Errors + warnings + info
 *   4 = DEBUG  - All messages (development)
 */
const CDT_LOG_LEVEL = 4;  // DEBUG level (shows all messages for troubleshooting)

// Log level constants
const CDT_LOG = {
    NONE: 0,
    ERROR: 1,
    WARN: 2,
    INFO: 3,
    DEBUG: 4
};

/**
 * CDT unified logging function with level support
 * @param {number} level - Log level (CDT_LOG.ERROR, CDT_LOG.WARN, etc.)
 * @param {...any} args - Arguments to log
 */
function cdtLog(level, ...args) {
    if (level <= CDT_LOG_LEVEL) {
        // Convert all args to strings and join into single message
        const messageParts = args.map(arg => {
            if (arg === undefined) return '';
            if (arg === null) return '';
            if (typeof arg === 'string') return arg;
            if (typeof arg === 'object') {
                try {
                    return JSON.stringify(arg);
                } catch (e) {
                    return String(arg);
                }
            }
            return String(arg);
        }).filter(s => s && s.trim() !== '');

        // Skip if no meaningful content
        if (messageParts.length === 0) {
            return;
        }

        const message = messageParts.join(' ');
        if (!message || message.trim() === '') {
            return;
        }

        const prefix = ['', '[CDT ERROR]', '[CDT WARN]', '[CDT INFO]', '[CDT DEBUG]'][level] || '';
        const fullMessage = prefix + ' ' + message;

        // GUI Composer may not have console.warn/console.error - use console.log as fallback
        if (level === CDT_LOG.ERROR && typeof console.error === 'function') {
            console.error(fullMessage);
        } else if (level === CDT_LOG.WARN && typeof console.warn === 'function') {
            console.warn(fullMessage);
        } else {
            console.log(fullMessage);
        }
    }
}

// Convenience aliases
const cdtError = (...args) => cdtLog(CDT_LOG.ERROR, ...args);
const cdtWarn = (...args) => cdtLog(CDT_LOG.WARN, ...args);
const cdtInfo = (...args) => cdtLog(CDT_LOG.INFO, ...args);

/**
 * Conditional debug logging - backwards compatible with CDT_DEBUG
 * @param {...any} args - Arguments to pass to console.log
 */
function cdtDebugLog(...args) {
    cdtLog(CDT_LOG.DEBUG, ...args);
}

/**
 * DOM element cache for frequently-accessed elements
 * Reduces repeated document.getElementById calls in update loops
 */
const domCache = new Map();

/**
 * GC Widget element cache for gc-widget-* web components
 * These elements cannot be accessed via document.getElementById - they require GcWidget.querySelector
 */
const gcWidgetCache = new Map();

/**
 * Get a cached DOM element by ID (lazy initialization with validation)
 * Validates that cached element is still in the DOM to prevent stale references
 * @param {string} id - Element ID
 * @returns {HTMLElement|null}
 */
function getCachedElement(id) {
    if (domCache.has(id)) {
        const cached = domCache.get(id);
        // Validate element is still in DOM (not stale)
        if (cached && document.body.contains(cached)) {
            return cached;
        }
        // Element was removed from DOM, clear stale reference
        domCache.delete(id);
    }
    const el = document.getElementById(id);
    if (el) {
        domCache.set(id, el);
    }
    return el;
}

/**
 * Safe wrapper for GcWidget.querySelector that never rejects.
 * Returns null and logs a warning if the query fails.
 * @param {string} selector - CSS selector string
 * @returns {Promise<HTMLElement|null>}
 */
function gcWidgetQuery(selector) {
    return GcWidget.querySelector(selector).catch(e => {
        cdtWarn("[CDT] Widget query failed: " + selector);
        return null;
    });
}

/**
 * Get a cached GC Widget element by ID (for gc-widget-* web components)
 * Web components require GcWidget.querySelector, not document.getElementById
 * @param {string} id - Element ID (without #)
 * @returns {Promise<HTMLElement|null>}
 */
async function getCachedGcWidget(id) {
    if (gcWidgetCache.has(id)) {
        return gcWidgetCache.get(id);
    }
    const el = await gcWidgetQuery('#' + id);
    if (el) {
        gcWidgetCache.set(id, el);
    }
    return el;
}

/**
 * Store a GC Widget element in the cache (for pre-initialization)
 * @param {string} id - Element ID (without #)
 * @param {HTMLElement} element - The element to cache
 */
function cacheGcWidget(id, element) {
    if (element) {
        gcWidgetCache.set(id, element);
    }
}

/**
 * Clear DOM cache (call when elements may have been recreated)
 */
function clearDomCache() {
    domCache.clear();
}

/**
 * Clear GC Widget cache (call when elements may have been recreated)
 */
function clearGcWidgetCache() {
    gcWidgetCache.clear();
}

/**
 * Event listener registry for cleanup
 * Tracks all registered event listeners to prevent memory leaks
 */
const eventListenerRegistry = [];

/**
 * CDT Initialization State Tracking
 * Tracks XDS connection readiness and provides queuing for operations
 */
let cdtInitState = {
    xdsReady: false,
    xdsConnected: false,
    domReady: false,
    buttonsRegistered: 0,
    buttonsFailed: 0,
    pendingOperations: [],  // Queue operations until XDS is ready
    initComplete: false
};

/**
 * Check if XDS is ready for operations
 */
function isXdsReady() {
    return cdtInitState.xdsReady && cdtInitState.xdsConnected && xdsTransport && xdsTransport.state === 'connected';
}

/**
 * Execute a function when XDS is ready, or queue it for later
 * @param {Function} fn - Function to execute
 * @param {string} description - Description for logging
 */
function whenXdsReady(fn, description) {
    if (isXdsReady()) {
        fn();
    } else {
        cdtDebugLog("[CDT QUEUE] Queuing operation until XDS ready: " + description);
        cdtInitState.pendingOperations.push({ fn, description });
    }
}

/**
 * Process all pending operations (called when XDS becomes ready)
 */
function processPendingOperations() {
    cdtDebugLog("[CDT QUEUE] Processing " + cdtInitState.pendingOperations.length + " pending operations");
    while (cdtInitState.pendingOperations.length > 0) {
        let op = cdtInitState.pendingOperations.shift();
        cdtDebugLog("[CDT QUEUE] Executing: " + op.description);
        try {
            op.fn();
        } catch (e) {
            cdtError("[CDT QUEUE] Error in queued operation: " + e.message);
        }
    }
}

/**
 * Register an event listener with automatic tracking for cleanup
 * @param {EventTarget} target - Element or object to attach listener to
 * @param {string} eventType - Event type (e.g., 'click', 'change')
 * @param {Function} handler - Event handler function
 * @param {object} options - Optional addEventListener options
 * @returns {boolean} - True if registration succeeded
 */
function registerEventListener(target, eventType, handler, options) {
    if (!target || typeof target.addEventListener !== 'function') {
        cdtWarn('Invalid target for event listener:', eventType);
        cdtInitState.buttonsFailed++;
        return false;
    }
    try {
        target.addEventListener(eventType, handler, options);
        eventListenerRegistry.push({ target, eventType, handler, options });
        cdtInitState.buttonsRegistered++;
        return true;
    } catch (e) {
        cdtWarn('Failed to register event listener:', eventType, e.message);
        cdtInitState.buttonsFailed++;
        return false;
    }
}

/**
 * Remove all registered event listeners (call on cleanup/disconnect)
 */
function cleanupEventListeners() {
    while (eventListenerRegistry.length > 0) {
        const { target, eventType, handler, options } = eventListenerRegistry.pop();
        try {
            target.removeEventListener(eventType, handler, options);
        } catch (e) {
            // Log unexpected errors (not just DOM removal) for debugging
            if (e && e.message && !e.message.includes('removeEventListener')) {
                cdtDebugLog("Event listener cleanup error for " + eventType + ": " + e.message);
            }
        }
    }
}


/**
 * Robust button registration with retry logic (async version)
 * Handles both gc-widget-button and regular DOM elements
 * @param {string} buttonId - The button element ID
 * @param {Function} clickHandler - Handler function for click events
 * @param {string} description - Description for logging
 * @param {number} maxRetries - Maximum retry attempts (default 3)
 */
async function registerButtonHandler(buttonId, clickHandler, description, maxRetries = 3) {
    cdtDebugLog("[CDT BTN REG] Registering: " + description + " (id=" + buttonId + ")");

    for (let attempt = 1; attempt <= maxRetries; attempt++) {
        // Try GcWidget.querySelector first (for gc-widget-button elements)
        try {
            let button = await gcWidgetQuery('#' + buttonId);
            if (button) {
                let success = registerEventListener(button, 'click', clickHandler);
                if (success) {
                    cdtDebugLog("[CDT BTN REG] SUCCESS via GcWidget: " + description);
                    return true;
                }
            }
        } catch (e) {
            // GcWidget.querySelector failed, try fallback
        }

        // Fallback: try document.getElementById (for div buttons)
        let button = document.getElementById(buttonId);
        if (button) {
            let success = registerEventListener(button, 'click', clickHandler);
            if (success) {
                cdtDebugLog("[CDT BTN REG] SUCCESS via getElementById: " + description);
                return true;
            }
        }

        // Wait before retry
        if (attempt < maxRetries) {
            cdtDebugLog("[CDT BTN REG] Attempt " + attempt + " failed for " + description + ", retrying in 500ms...");
            await new Promise(resolve => setTimeout(resolve, 500));
        }
    }

    cdtDebugLog("[CDT BTN REG] FAILED after " + maxRetries + " attempts: " + description);
    return false;
}

// NOTE: registerButtonsDelayed() removed - document-level click delegation handles all buttons


/**
 * Update text content of a cached element
 * @param {string} id - Element ID
 * @param {string|number} text - Text content to set
 */
function setCachedElementText(id, text) {
    const el = getCachedElement(id);
    if (el) el.textContent = text;
}

/**
 * Show a toast notification to the user
 * @param {string} message - Message to display
 * @param {string} type - Type: 'success', 'error', 'warning', 'info'
 * @param {number} duration - Duration in ms (default 3000)
 */
function showToast(message, type = 'info', duration = 3000) {
    // Create toast container if it doesn't exist
    let container = document.getElementById('cdt_toast_container');
    if (!container) {
        container = document.createElement('div');
        container.id = 'cdt_toast_container';
        container.className = 'cdt_toast_container';
        document.body.appendChild(container);
    }

    // Create toast element
    const toast = document.createElement('div');
    toast.className = 'cdt_toast cdt_toast_' + type;
    toast.textContent = message;

    // Add to container
    container.appendChild(toast);

    // Trigger animation
    requestAnimationFrame(() => {
        toast.classList.add('cdt_toast_show');
    });

    // Remove after duration
    setTimeout(() => {
        toast.classList.remove('cdt_toast_show');
        setTimeout(() => {
            if (toast.parentNode) {
                toast.parentNode.removeChild(toast);
            }
        }, 300);
    }, duration);
}

// Make debug functions globally accessible
window.toggleDebugPanel = toggleDebugPanel;
window.clearDebugLog = clearDebugLog;
window.copyDebugLog = copyDebugLog;

//=============================================================================
// GLOBAL CDT UPDATE FUNCTIONS - Called via onclick from gc-widget-button
// These are registered on window to work with onclick="window.cdtXxxUpdate()"
//
// NOTE: Window handlers are registered inside init() because the update
// functions (pinmuxUpdate, systemUpdate, etc.) are defined later in the file.
// The SysConfig template pipeline does not hoist function declarations, so
// references at module parse time would cause ReferenceError.
//=============================================================================

//=============================================================================
// LED Helper Functions - Consolidated LED update patterns
//=============================================================================

// LED color constants
const LED_COLOR = {
    GREEN: '#00cc00',
    RED: '#ff0000',
    YELLOW: '#ffaa00',
    ORANGE: '#ff9800',
    BLUE: '#1565c0',
    GRAY: '#808080'
};

/**
 * Update LED to show pass (green) or fail (red) state
 * @param {HTMLElement} led - LED element
 * @param {boolean} pass - True for pass (green), false for fail (red)
 */
function setLedPassFail(led, pass) {
    if (!led) {
        cdtWarn("setLedPassFail: LED element is null/undefined");
        return;
    }
    led.on = true;
    led.style.setProperty('--gc-on-color', pass ? LED_COLOR.GREEN : LED_COLOR.RED);
}

/**
 * Update LED to show active (green) or inactive (gray) state
 * @param {HTMLElement} led - LED element
 * @param {boolean} active - True for active (green), false for inactive (gray)
 */
function setLedActive(led, active) {
    if (!led) return;
    led.on = active ? true : false;
    led.style.setProperty('--gc-on-color', active ? LED_COLOR.GREEN : LED_COLOR.GRAY);
}

/**
 * Update LED to show error (red) or normal (green) state
 * @param {HTMLElement} led - LED element
 * @param {boolean} error - True for error (red), false for normal (green)
 */
function setLedError(led, error) {
    if (!led) return;
    led.on = true;
    led.style.setProperty('--gc-on-color', error ? LED_COLOR.RED : LED_COLOR.GREEN);
}

/**
 * Update LED to show warning (yellow) state
 * @param {HTMLElement} led - LED element
 * @param {boolean} warning - True for warning (yellow), false for normal (green)
 */
function setLedWarning(led, warning) {
    if (!led) return;
    led.on = true;
    led.style.setProperty('--gc-on-color', warning ? LED_COLOR.YELLOW : LED_COLOR.GREEN);
}

/**
 * Update LED to show info (blue) state - for informational indicators
 * @param {HTMLElement} led - LED element
 * @param {boolean} info - True for info (blue), false for normal (green)
 */
function setLedInfo(led, info) {
    if (!led) return;
    led.on = true;
    led.style.setProperty('--gc-on-color', info ? LED_COLOR.BLUE : LED_COLOR.GREEN);
}

/**
 * Update LED to show pending (orange) state - for boot ROM, processing, etc.
 * @param {HTMLElement} led - LED element
 * @param {boolean} pending - True for pending (orange), false for normal (green)
 */
function setLedPending(led, pending) {
    if (!led) return;
    led.on = true;
    led.style.setProperty('--gc-on-color', pending ? LED_COLOR.ORANGE : LED_COLOR.GREEN);
}

/**
 * Reset LED to disabled/inactive state (gray, off)
 * @param {HTMLElement} led - LED element
 */
function setLedDisabled(led) {
    if (!led) return;
    led.on = false;
    led.style.setProperty('--gc-on-color', LED_COLOR.GRAY);
}

/**
 * Set LED to a specific color
 * @param {HTMLElement} led - LED element
 * @param {boolean} on - LED on state
 * @param {string} color - Color value (use LED_COLOR constants)
 */
function setLedColor(led, on, color) {
    if (!led) return;
    led.on = on;
    led.style.setProperty('--gc-on-color', color);
}

// Make LED helper functions globally accessible
window.LED_COLOR = LED_COLOR;
window.setLedPassFail = setLedPassFail;
window.setLedActive = setLedActive;
window.setLedError = setLedError;
window.setLedWarning = setLedWarning;
window.setLedInfo = setLedInfo;
window.setLedPending = setLedPending;
window.setLedDisabled = setLedDisabled;
window.setLedColor = setLedColor;

//=============================================================================
// PARTID Decoding Constants - Runtime device identification
//=============================================================================

// Devices that have FLASH_SIZE field directly in PARTIDL register
const DEVICES_WITH_FLASH_IN_PARTIDL = [
    "F28002x", "F28003x", "F28004x", "F2807x",
    "F2837xD", "F2837xS", "F2838x", "F28P55x", "F28P65x"
];

// RAM sizes by device family (not encoded in PARTID - requires lookup)
const RAM_BY_FAMILY_KB = {
    "F280013x": 12,   "F280015x": 12,   "F28002x": 24,
    "F28003x": 69,    "F28004x": 100,   "F2807x": 174,
    "F2837xD": 204,   "F2837xS": 164,   "F2838x": 512,
    "F28P55x": 256,   "F28P65x": 1024
};

// Pin count decoding (PARTIDL bits 10:8)
const PIN_COUNT_MAP = {
    0: "Unknown", 1: "32-pin", 2: "48-pin", 3: "56-pin",
    4: "64-pin",  5: "80-pin", 6: "100-pin", 7: "176-pin"
};

//=============================================================================
// ADC Clock Prescale Helper Function
// Converts ADC_ClkPrescale register value to actual divider value
//=============================================================================

/**
 * Calculate ADC clock prescale divider from register value
 * All Gen3 devices support register values 0-16 for dividers /1 through /8.5
 *
 * @param {number} prescaleReg - ADCCTL2.PRESCALE register value (0-16)
 * @returns {number|false} Divider value (1.0 to 8.5), or false if invalid
 */
function calcAdcPrescaleValue(prescaleReg) {
    // Register value 0 = divider 1 (no division)
    if (prescaleReg === 0) return 1.0;

    // Register value 1 is reserved/invalid on all devices
    if (prescaleReg === 1) return false;

    // Register values 2-16: formula = (prescaleReg - 2) * 0.5 + 2
    // This gives: reg=2 -> /2, reg=3 -> /2.5, reg=4 -> /3, etc.
    if (prescaleReg >= 2 && prescaleReg <= 16) {
        return (prescaleReg - 2) * 0.5 + 2.0;
    }

    // Values > 16 are out of range
    return false;
}
window.calcAdcPrescaleValue = calcAdcPrescaleValue;

//=============================================================================
// Tooltip Helper Functions - Consolidated tooltip update patterns
//=============================================================================

/**
 * Set tooltip for a clock frequency check
 * @param {string} selector - CSS selector for the tooltip container
 * @param {number} value - Current value in Hz
 * @param {number|string} max - Maximum allowed value in Hz, or 'N/A'
 * @param {number|string} min - Minimum allowed value in Hz, or 'N/A'
 */
function setClockTooltip(selector, value, max, min) {
    let container = document.querySelector(selector);
    if (!container) return;
    let valueMHz = (value / 1000000).toFixed(1) + " MHz";
    let maxMHz = (typeof max === 'number') ? (max / 1000000).toFixed(1) + " MHz" : "N/A";
    let minMHz = (typeof min === 'number') ? (min / 1000000).toFixed(1) + " MHz" : "N/A";
    container.title = "Max: " + maxMHz + "\nValue: " + valueMHz + "\nMin: " + minMHz;
}

/**
 * Set tooltip for an errata check
 * @param {string} selector - CSS selector for the tooltip container
 * @param {string} errataDoc - Errata document ID (e.g., "SPRZ458")
 * @param {string} description - Errata description
 * @param {boolean} pass - True if check passed, false if failed
 * @param {boolean} applicable - True if peripheral is in use
 */
function setErrataTooltip(selector, errataDoc, description, pass, applicable) {
    let container = document.querySelector(selector);
    if (!container) return;
    let status = !applicable ? "N/A - Peripheral not used" :
                 (pass ? "PASS - No issue detected" : "FAIL - Errata condition present");
    container.title = "Errata Doc: " + errataDoc + "\n" + description + "\nStatus: " + status;
}

/**
 * Set simple status tooltip
 * @param {string} selector - CSS selector for the tooltip container
 * @param {string} label - Label for the status
 * @param {string} status - Status text
 */
function setStatusTooltip(selector, label, status) {
    let container = document.querySelector(selector);
    if (!container) return;
    container.title = label + ": " + status;
}

/**
 * Set multi-line tooltip
 * @param {string} selector - CSS selector for the tooltip container
 * @param {string[]} lines - Array of tooltip lines
 */
function setMultiLineTooltip(selector, lines) {
    let container = document.querySelector(selector);
    if (!container) return;
    container.title = lines.join("\n");
}

// Make tooltip helper functions globally accessible
window.setClockTooltip = setClockTooltip;
window.setErrataTooltip = setErrataTooltip;
window.setStatusTooltip = setStatusTooltip;
window.setMultiLineTooltip = setMultiLineTooltip;

/**
 -------------------------------------------------------------------------------------------------------------------------------
Connections Page
-------------------------------------------------------------------------------------------------------------------------------
**/

var xdsConnectionDiv;
var usbConnectionDiv;
var xdsLed;
var usbLed;
var statusbar;

let xdsTransport;
function xdsTransportConnectionChangeHandler(details){
    cdtDebugLog("[CDT XDS] Connection state changed: " + details.transport.state);

    if (details.transport.state === 'connected'){
        if (xdsLed) xdsLed.on = true;
        // Update CDT init state
        cdtInitState.xdsConnected = true;
        cdtInitState.xdsReady = true;
        cdtDebugLog("[CDT XDS] XDS CONNECTED - CDT ready for operations");

        // Process any pending operations that were queued before connection
        processPendingOperations();

        // Auto-run initial updates now that XDS is connected
        // Use async/await with ordering to ensure dependent panels get correct data
        cdtDebugLog("[CDT XDS] Running initial diagnostics update...");
        setTimeout(async () => {
            if (isXdsReady()) {
                try {
                    // Phase 1: Independent panels (parallel)
                    await Promise.allSettled([
                        clockingUpdate(),
                        systemUpdate(),
                        memoryUpdate(),
                        interruptUpdate()
                    ]);
                    // Phase 2: Depends on clockingUpdate results
                    await Promise.allSettled([
                        errataUpdate(),
                        cputimerUpdate()
                    ]);
                    // Phase 3: GPIO (calls pinmuxUpdate internally + renders grid + XINT)
                    await gpioFullUpdate();
                } catch (error) {
                    cdtError("[CDT XDS] Initial diagnostics update error:", error);
                }
            }
        }, 500);
    }
    else
    {
        if (xdsLed) xdsLed.on = false;
        cdtInitState.xdsConnected = false;
        cdtDebugLog("[CDT XDS] XDS DISCONNECTED");
        // Stop auto-update when XDS disconnects to prevent errors
        if (typeof stopAutoUpdate === 'function') {
            stopAutoUpdate();
        }
        // NOTE: Do NOT call cleanupEventListeners() here - it destroys all button
        // handlers and connection listeners, making reconnection impossible.
        // Listeners are only cleaned up on page unload (beforeunload handler).
    }
    // Use textContent for safe text insertion (avoid innerHTML with external data)
    if (xdsConnectionDiv) {
        xdsConnectionDiv.textContent += "\n" + details.transport.state;
        if (details.transport.lastLog && details.transport.lastLog.message) {
            xdsConnectionDiv.textContent += "\n" + details.transport.lastLog.message;
        }
    }
}
let usbTransport;
function usbTransportConnectionChangeHandler(details){

    if (details.transport.state === 'connected'){
        if (usbLed) usbLed.on = true;
    }
    else
    {
        if (usbLed) usbLed.on = false;
    }
    // Use textContent for safe text insertion (avoid innerHTML with external data)
    if (usbConnectionDiv) {
        usbConnectionDiv.textContent += "\n" + details.transport.state;
        if (details.transport.lastLog && details.transport.lastLog.message) {
            usbConnectionDiv.textContent += "\n" + details.transport.lastLog.message;
        }
    }
}

//
// Logger Data Provider Factory
// Creates data providers for logger grids with optional child row support
//
function createLoggerDataProvider(gridData, childKey, childColumns) {
    return {
        get rowCount() { return gridData.length; },
        getValue(row, columnName) { return gridData[row][columnName]; },
        isExpandable(row) {
            return childKey && gridData[row][childKey] && gridData[row][childKey].length > 0;
        },
        getChildDataProvider(row) {
            if (!childKey || !childColumns) return null;
            return {
                get rowCount() { return gridData[row][childKey].length; },
                getValue(childRow, childColumn) {
                    if (childColumns.includes(childColumn)) {
                        return gridData[row][childKey][childRow][childColumn];
                    }
                }
            };
        }
    };
}

