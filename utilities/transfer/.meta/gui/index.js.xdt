                // Build CPUTIMER register dump from cputimerState
                let regDump = '=== CPUTIMER Register Dump ===\n\n';
                for (let i = 0; i < 3; i++) {
                    let t = cputimerState.timer[i];
                    regDump += 'TIMER' + i + ':\n';
                    regDump += '  TIM = ' + t.tim.toLocaleString() + ' (0x' + t.tim.toString(16).toUpperCase().padStart(8, '0') + ')\n';
                    regDump += '  PRD = ' + t.prd.toLocaleString() + ' (0x' + t.prd.toString(16).toUpperCase().padStart(8, '0') + ')\n';
                    regDump += '  TCR = 0x' + t.tcr.toString(16).toUpperCase().padStart(4, '0') + '\n';
                    regDump += '        TSS=' + ((t.tcr & CPUTIMER_TCR_TSS) ? '1 (Stopped)' : '0 (Running)') + '\n';
                    regDump += '        TIE=' + ((t.tcr & CPUTIMER_TCR_TIE) ? '1 (INT Enabled)' : '0 (INT Disabled)') + '\n';
                    regDump += '        TIF=' + ((t.tcr & CPUTIMER_TCR_TIF) ? '1 (Flag Set)' : '0 (Flag Clear)') + '\n';
                    regDump += '        FREE=' + ((t.tcr & CPUTIMER_TCR_FREE) ? '1' : '0') + '\n';
                    regDump += '  Prescale = ' + t.prescale + '\n\n';
                }
                regDump += 'SYSCLK = ' + cputimerState.sysclkMHz + ' MHz\n';

                cdtDebugLog("[CDT] CPUTIMER Show Registers clicked");
                // Use document.querySelector for gc-widget-dialog (same pattern as export_all_dialog)
                let dialog = document.querySelector('#show_registers_dialog');
                let textarea = document.getElementById('show_registers_textarea');
                if (dialog && textarea) {
                    // Set heading using setAttribute for gc-widget-dialog
                    dialog.setAttribute('heading', 'CPUTIMER Register Values');
                    textarea.value = regDump;
                    // Open dialog using .open() method
                    dialog.open();
                    cdtDebugLog("[CDT] CPUTIMER Show Registers dialog opened");
                } else {
                    console.error("[CDT] CPUTIMER Show Registers: dialog or textarea not found");
                    // Fallback - show in alert
                    alert(regDump);
                }
            });
        }
    });

    // Initialize CPUTIMER LEDs for all 3 timers and cache them for later use
    for (let i = 0; i < 3; i++) {
        let prefix = 'cputimer' + i;

        gcWidgetQuery('#' + prefix + '_running_led').then(led => {
            if (led) {
                cacheGcWidget(prefix + '_running_led', led);
                led.on = false;
                led.onColor = LED_COLOR.GREEN;
                led.offColor = LED_COLOR.RED;
            }
        });

        gcWidgetQuery('#' + prefix + '_int_led').then(led => {
            if (led) {
                cacheGcWidget(prefix + '_int_led', led);
                led.on = false;
                led.onColor = LED_COLOR.GREEN;
                led.offColor = LED_COLOR.GRAY;
            }
        });

        gcWidgetQuery('#' + prefix + '_tif_led').then(led => {
            if (led) {
                cacheGcWidget(prefix + '_tif_led', led);
                led.on = false;
                led.onColor = LED_COLOR.ORANGE;
                led.offColor = LED_COLOR.GRAY;
            }
        });

        gcWidgetQuery('#' + prefix + '_free_led').then(led => {
            if (led) {
                cacheGcWidget(prefix + '_free_led', led);
                led.on = false;
                led.onColor = LED_COLOR.GREEN;
                led.offColor = LED_COLOR.GRAY;
            }
        });

        // Timer Free Run and Start/Stop use onclick attributes in HTML
        // calling window.cdtTimerFreeRun(N) and window.cdtTimerStartStop(N)
        // which delegate to toggleTimerFreeRun() and toggleTimerStartStop()

        // Configure button for this timer - use closure to capture timerNum
        (function(timerNum) {
            registerButtonHandler('cputimer' + timerNum + '_config', async (event) => {
                cdtDebugLog("[CDT TIMER ACTION] Configure button clicked for timer" + timerNum);
                event.preventDefault();
                event.stopPropagation();

                // Get button reference for focus management
                let btn = document.getElementById('cputimer' + timerNum + '_config');
                if (btn) btn.focus();

                cdtDebugLog("Configure clicked for TIMER" + timerNum);
                await openTimerConfigDialog(timerNum);
            }, 'TIMER' + timerNum + ' Configure');
        })(i);
    }

    //
    // Auto-Update Controls
    //
    let autoUpdateCheckbox = document.getElementById('auto_update_enable');
    if (autoUpdateCheckbox) {
        registerEventListener(autoUpdateCheckbox, 'change', (e) => {
            if (e.target.checked) {
                startAutoUpdate();
            } else {
                stopAutoUpdate();
            }
        });
    }

    let intervalInput = document.getElementById('auto_update_interval');
    if (intervalInput) {
        registerEventListener(intervalInput, 'change', (e) => {
            autoUpdateIntervalSec = parseFloat(e.target.value) || 2;
            // Clamp to valid range
            if (autoUpdateIntervalSec < 0.5) autoUpdateIntervalSec = 0.5;
            if (autoUpdateIntervalSec > 60) autoUpdateIntervalSec = 60;
            intervalInput.value = autoUpdateIntervalSec;
            if (autoUpdateEnabled) {
                stopAutoUpdate();
                startAutoUpdate();
            }
        });
    }

    //
    // Timer Configuration Dialog Handlers
    //
    gcWidgetQuery('#config_apply_btn').then(button => {
        if (button) {
            registerEventListener(button, 'click', async (event) => {
                event.preventDefault();
                event.stopPropagation();
                // Show processing state on Apply button
                button.disabled = true;
                let origLabel = button.label;
                button.label = 'Applying...';
                try {
                    await applyTimerConfig();
                } finally {
                    button.disabled = false;
                    button.label = origLabel || 'Apply';
                }
                return false;
            });
        }
    });

    // Live frequency calculation on input change
    let prdInput = document.getElementById('config_prd');
    let prescaleInput = document.getElementById('config_prescale');
    if (prdInput) {
        registerEventListener(prdInput, 'input', updateConfigDialogFrequencies);
    }
    if (prescaleInput) {
        registerEventListener(prescaleInput, 'input', updateConfigDialogFrequencies);
    }

% if (gui.deviceDiagnosticExportMode == "xds") {
    //
    // Export All button - opens dialog with diagnostic data
    //
    registerButtonHandler('export_all_b', async () => {
        cdtDebugLog("Export All clicked - opening dialog");
        let formatSelect = await gcWidgetQuery('#export_format_select');
        let format = formatSelect ? (formatSelect.selectedValue || 'json') : 'json';
        await exportAllDiagnostics(format, true);  // true = show dialog
    }, 'Export All');

    //
    // Dialog Download button - downloads content as file
    //
    registerButtonHandler('export_download_b', async () => {
        let textarea = document.getElementById('export_all_textarea');
        let formatSelect = await gcWidgetQuery('#export_format_select');
        let format = formatSelect ? (formatSelect.selectedValue || 'json') : 'json';
        if (textarea && textarea.value) {
            downloadExport(textarea.value, format);
        }
    }, 'Export Download');

    //
    // Dialog Copy All button - copies from dialog textarea
    //
    registerButtonHandler('export_dialog_copy_b', async () => {
        let textarea = document.getElementById('export_all_textarea');
        let button = await gcWidgetQuery('#export_dialog_copy_b');
        if (textarea && textarea.value) {
            // Pass textarea directly for more reliable selection-based copy
            let success = copyToClipboard(textarea.value, textarea);
            cdtDebugLog("Copy from dialog: " + (success ? "success" : "failed") + " (" + textarea.value.length + " bytes)");
            if (button) {
                if (success) {
                    button.label = "Copied!";
                    setTimeout(() => { button.label = "Copy All"; }, 1500);
                } else {
                    button.label = "Failed";
                    setTimeout(() => { button.label = "Copy All"; }, 1500);
                }
            }
        }
    }, 'Export Copy All');
% }

    % function getBitfieldRegisterName(expModName, regName){
        % if(["adc","dcc","i2c","nmi","sci","spi","xbar"].includes(expModName)){
            % return expModName.toUpperCase() + regName;
        % }
        % else if(["can"].includes(expModName)){
            % return expModName.toUpperCase() + "_" + regName;
        % }
        % else if(["lin"].includes(expModName)){
            % if(["COMP","RD0","RD1","MASK","ID","TD0","TD1"].includes(regName)){
                % return expModName.toUpperCase() + regName;
            % }
            % else if(["GLB_INT_EN","GLB_INT_FLG","GLB_INT_CLR"].includes(regName)){
                % return expModName.toUpperCase() + "_" + regName;
            % }
            % else{
                % return regName;
            % }
        % }
        % else {
            % return regName;   
        % }
    % }
    % let Common   = system.getScript("/driverlib/Common.js");
    % for (var expModName of expModuleNames) {
        % let mod = system.modules["/driverlib/" + expModName + ".js"];
        % if (["fsirx", "fsitx"].includes(expModName)) {
        % var registersFile = system.getScript("/driverlib/device_driverlib_peripherals/" + 
        %                       Common.getDeviceName().toLowerCase() + "_" + "fsi" + "_registers.js");
        % var registers = registersFile["FSIRegisters"];
        % }
        % else {
        % var registersFile = system.getScript("/driverlib/device_driverlib_peripherals/" + 
        %                       Common.getDeviceName().toLowerCase() + "_" + expModName + "_registers.js");
        % var registers = registersFile[expModName.toUpperCase() + "Registers"];
        % }
        % let modExports = system.getScript("/utilities/transfer/export/mods/export_mod_" + expModName + ".js");
        % if (mod && (exportCommon.getNonExporterInstances(mod).length > 0)) {
            % for (var modInst of exportCommon.getNonExporterInstances(mod)) {
                % let regInstName = exportCommon.getExportModInfoBitfieldRegForInst(modInst, expModName, modExports.bitfieldInstanceNames,{});
    
    //
    //  `modInst.$name` Show Register Function
    //
    async function showRegisters_`modInst.$name`() {
        let registerInfo = {};
        registerInfo['`modInst.$name`_sr'] = {};
                        % let exportableRegisters = registers.filter(
                        %    reg => (modExports.exportsRegisterSkips.filter(regSkip => regSkip.name == reg.name).length == 0));
                        % for (let reg of exportableRegisters) {
        registerInfo['`modInst.$name`_sr']['`getBitfieldRegisterName(expModName,reg.name)`'] = await xdsTransport.readValue('`regInstName`.`getBitfieldRegisterName(expModName,reg.name)`');
                        % }
        // Populate textarea and open dialog
        const registerText = JSON.stringify(registerInfo['`modInst.$name`_sr'], null, 4);
        const textarea = document.querySelector('#show_registers_textarea');
        const dialog = document.querySelector('#show_registers_dialog');
        if (textarea && dialog) {
            textarea.value = registerText;
            currentRegisterInstanceName = '`modInst.$name`';
            dialog.setAttribute('heading', '`modInst.$name` Registers');
            // Open dialog using .open() method (gc-widget-dialog pattern)
            dialog.open();
            cdtDebugLog("[CDT] `modInst.$name` Show Registers dialog opened");
        } else {
            console.error("[CDT] `modInst.$name` Show Registers: dialog or textarea not found");
            // Fallback - show in alert
            alert(registerText);
        }
    }

    //
    //  `modInst.$name` Show Register Button Event Listeners
    //
    gcWidgetQuery('#page_`expModName`_show_`modInst.$name`_registers_b').then(button => {
        if (button) {
            registerEventListener(button, 'click', async () => {
                try {
                    await showRegisters_`modInst.$name`();
                } catch (e) {
                    cdtError("Show registers failed for `modInst.$name`:", e);
                    showToast('Failed to read registers for `modInst.$name`: ' + (e?.message || 'Unknown error'), 'error');
                }
            });
            cdtDebugLog("[CDT] `modInst.$name` Show Registers button handler registered");
        } else {
            console.warn("[CDT] `modInst.$name` Show Registers button not found");
        }
    });

    //
    //  `modInst.$name` Update Function - callable from window for cdtModuleUpdate
    //
    window.cdtInstanceUpdate_`modInst.$name` = async function() {
        cdtDebugLog("Manual update triggered for `modInst.$name`");
        statusbar.statusText = 'Updating `modInst.$name`...';
        try {
            // Re-read all the export values for this instance
            % for (let exportInfo of exportCommon.getInstanceExportModsInfo(modInst, modExports.exportsInfo)) {
                % let regInstName = exportCommon.getExportModInfoBitfieldRegForInst(modInst, expModName, modExports.bitfieldInstanceNames, exportInfo);
                % if (exportInfo.type === 'value') {
            try {
                let val_`exportInfo.name` = await xdsTransport.readValue('`regInstName`.`exportInfo.register`');
                let valElem_`exportInfo.name` = document.getElementById('page_`expModName`_`modInst.$name`_`exportInfo.name`_val');
                if (valElem_`exportInfo.name`) {
                    // Handle 32-bit values that may come as objects
                    let displayVal = val_`exportInfo.name`;
                    if (typeof displayVal === 'object' && displayVal !== null) {
                        if (displayVal.low !== undefined && displayVal.high !== undefined) {
                            displayVal = (displayVal.high * 0x10000) + displayVal.low;
                        } else if (displayVal.value !== undefined) {
                            displayVal = displayVal.value;
                        } else {
                            // Fallback for unrecognized object formats
                            displayVal = parseInt(displayVal) || JSON.stringify(displayVal);
                        }
                    }
                    valElem_`exportInfo.name`.setAttribute('label', String(displayVal));
                }
            } catch (e) { cdtWarn("Read error `exportInfo.name`:", e.message); }
                % } else {
            try {
                let val_`exportInfo.name` = await xdsTransport.readValue('`regInstName`.`exportInfo.register`');
                // Use GcWidget.querySelector for gc-widget-led elements (not document.getElementById)
                let ledElem_`exportInfo.name` = await gcWidgetQuery('#page_`expModName`_`modInst.$name`_`exportInfo.name`_led');
                if (ledElem_`exportInfo.name`) {
                    // Use setLedActive to properly set both on state and color
                    setLedActive(ledElem_`exportInfo.name`, !!parseInt(val_`exportInfo.name`));
                }
            } catch (e) { cdtWarn("Read error `exportInfo.name`:", e.message); }
                % }
            % }
            statusbar.statusText = '`modInst.$name` updated';
        } catch (e) {
            cdtError("Update error for `modInst.$name`:", e);
            statusbar.statusText = 'Update failed: ' + e.message;
        }
    };
    // Register update function in module registry for cdtModuleUpdate
    if (!window.cdtModuleRegistry) window.cdtModuleRegistry = {};
    if (!window.cdtModuleRegistry['`expModName`']) window.cdtModuleRegistry['`expModName`'] = [];
    window.cdtModuleRegistry['`expModName`'].push('`modInst.$name`');

    //
    //  `modInst.$name` Update Button Event Listeners
    //
    gcWidgetQuery('#page_`expModName`_update_`modInst.$name`_b').then(button => {
        if (!button) {
            console.warn("[CDT] `modInst.$name` Update button not found");
            return;
        }
        cdtDebugLog("[CDT] `modInst.$name` Update button handler registered");
        registerEventListener(button, 'click', window.cdtInstanceUpdate_`modInst.$name`);
    });
            % }
        % }
    % }

    // Auto-run all diagnostic panel updates after GUI initializes
    // Order matches GUI panel layout for visual feedback consistency
    // Reduced delay from 2.5s to 1.5s - GcWidget promises resolve faster
    setTimeout(async () => {
        cdtInfo("Auto-running all diagnostic panel updates...");
        // Verify LED elements are initialized before running updates
        if (!sysclkMaxMinFreq_led) {
            cdtWarn("LED elements not yet initialized, retrying in 500ms...");
            await new Promise(r => setTimeout(r, 500));
        }
        try {
            // Phase 1: Top row (System, Pinmux) - visible first
            await Promise.allSettled([
                systemUpdate(),
                pinmuxUpdate()
            ]);
            // Phase 2: Second row (Clocking, Memory)
            await Promise.allSettled([
                clockingUpdate(),
                memoryUpdate()
            ]);
            // Phase 3: Third row (Errata depends on clocking), plus Interrupt/Timer
            await Promise.allSettled([
                errataUpdate(),
                interruptUpdate(),
                cputimerUpdate()
            ]);
            // Phase 4: GPIO tab (renders grid + XINT status)
            await gpioFullUpdate();
        } catch (error) {
            cdtError("[CDT] Auto-run diagnostics error:", error);
        }
    }, 1500);

    //=========================================================================
    // Target State Change Listener - Auto-update on halt (breakpoint hit)
    //=========================================================================
    // Subscribe to target state changes to automatically refresh diagnostics
    // when the target halts (e.g., breakpoint hit, manual halt)
    //=========================================================================
    // Wrap in async IIFE since init() is not async
    (async () => {
        try {
            // Access the DS service for target state events
            const { ServicesRegistry } = await import('./components/@ti/gc-core-services/lib/ServicesRegistry.js');
            const { dsServiceType, targetStateChangedEventType } = await import('./components/@ti/gc-service-ds/lib/DSService.js');

            const dsService = ServicesRegistry.getService(dsServiceType);
            if (dsService) {
                cdtInfo("CDT: Registering target state change listener for auto-update on halt");

                registerEventListener(dsService, targetStateChangedEventType, (event) => {
                    const state = event?.data?.state || event?.state;
                    cdtDebugLog("CDT: Target state changed to: " + state);

                    // Immediately update target status display (before full panel refresh)
                    if (state === 'running' || state === 'free_running') {
                        updateTargetStatus(state, null);
                    }

                    // Auto-update all panels when target halts
                    // Order matches GUI panel layout for visual feedback consistency
                    if (state === 'halted' || state === 'suspended' || state === 'stopped') {
                        cdtDebugLog("CDT: Target halted - auto-refreshing all diagnostic panels");

                        // Small delay to ensure target is fully halted before reading registers
                        setTimeout(async () => {
                            try {
                                // First, read PC and update target status card
                                await refreshTargetStatus();

                                // Phase 1: Top row (System, Pinmux)
                                await Promise.allSettled([
                                    systemUpdate(),
                                    pinmuxUpdate()
                                ]);
                                // Phase 2: Second row (Clocking, Memory)
                                await Promise.allSettled([
                                    clockingUpdate(),
                                    memoryUpdate()
                                ]);
                                // Phase 3: Third row (Errata, Interrupt, Timer)
                                await Promise.allSettled([
                                    errataUpdate(),
                                    interruptUpdate(),
                                    cputimerUpdate()
                                ]);
                                // Phase 4: GPIO tab
                                await gpioFullUpdate();
                            } catch (error) {
                                cdtError("[CDT] Target-halt auto-update error:", error);
                            }
                        }, 100);
                    }
                });
                cdtDebugLog("CDT: Target state listener registered successfully");

                // Query initial target state immediately after registering listener
                // This handles the case where target is already running when CDT loads
                setTimeout(async () => {
                    cdtDebugLog("CDT: Checking initial target state...");
                    try {
                        // Try to read PC - success means halted, failure means running
                        let pc = parseRegValue(await xdsTransport.readValue('PC'));
                        cdtDebugLog("CDT: Initial state = HALTED (PC read succeeded)");
                        updateTargetStatus('halted', pc);
                    } catch (e) {
                        cdtDebugLog("CDT: Initial state = RUNNING (PC read failed: " + e.message + ")");
                        updateTargetStatus('running', null);
                    }
                }, 500);  // Small delay to ensure widgets are initialized
            } else {
                cdtWarn("CDT: DS service not available - auto-update on halt disabled");
            }
        } catch (e) {
            cdtWarn("CDT: Could not register target state listener: " + e.message);
            cdtInfo("CDT: Auto-update on halt not available - use manual Update buttons");
        }
    })();

    % }

};
document.readyState === 'complete' ? init() : document.addEventListener('DOMContentLoaded', init);


