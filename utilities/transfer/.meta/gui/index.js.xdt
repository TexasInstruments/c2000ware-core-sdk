//
// Send JSON objects through the Encoder and package them with padding for the receiver size
//
function jsonSendWithPadding(o)
{
    var keys = Object.keys(o);
    if (keys.length != 1)
    {
        cdtError("Bad object in send")
    }
    
    var lengthOfKey = keys[0].length;
    var lengthOfVal = o[keys[0]].toString().length;
    var jsonObjOverhead = "{\"\":}\n".length;
    if (typeof o[keys[0]] === "string")
    {
        jsonObjOverhead = jsonObjOverhead + 2;
    }
    
    var sendSize = lengthOfKey + lengthOfVal + jsonObjOverhead;
    if (sendSize > 16) {
        // Object too large for 16-char buffer
        return false;
    }
    else if (sendSize === 16) {
        // Exact fit - no padding needed
        codecRegistry.getInstance('json').encode(o);
        return true;
    }
    else {
        // Pad smaller objects to 16 chars
        codecRegistry.getInstance('json').encode(o);
        codecRegistry.getInstance('json').targetEncoder.encode(" ".repeat(16 - sendSize - 1));
        return true;
    }
    
}
% }

// Track current register instance name for saving
let currentRegisterInstanceName = '';

const init = () => {
    cdtDebugLog("[CDT] ============================================");
    cdtDebugLog("[CDT] init() STARTED - CDT Initialization Beginning");
    cdtDebugLog("[CDT] ============================================");
    cdtInfo("CDT init() starting...");

    // Initialize debug panel resize functionality
    initDebugPanelResize();

    // Register global onclick handlers now that all functions are defined
    window.cdtPinmuxUpdate = withXdsGuard(pinmuxUpdate, 'pinmux');
    window.cdtGpioUpdate = withXdsGuard(gpioFullUpdate, 'GPIO');
    window.cdtTimerUpdate = withXdsGuard(cputimerUpdate, 'timers');
    window.cdtSystemUpdate = withXdsGuard(systemUpdate, 'system');
    window.cdtClockingUpdate = withXdsGuard(clockingUpdate, 'clocking');
    window.cdtMemoryUpdate = withXdsGuard(memoryUpdate, 'memory');
    window.cdtInterruptUpdate = withXdsGuard(interruptUpdate, 'interrupts');
    window.cdtErrataUpdate = withXdsGuard(errataUpdate, 'errata');

    // Module-level update handler - triggers update for all instances in a peripheral module
    window.cdtModuleUpdate = async function(moduleName) {
        if (!isXdsReady()) {
            showToast('XDS not connected', 'error');
            return;
        }
        cdtDebugLog('[CDT] Module update triggered for: ' + moduleName);
        statusbar.statusText = 'Updating ' + moduleName.toUpperCase() + '...';

        // Use the module registry to find all instances and call their update functions
        const instances = window.cdtModuleRegistry ? window.cdtModuleRegistry[moduleName] : null;
        if (instances && instances.length > 0) {
            cdtDebugLog('[CDT] Found ' + instances.length + ' instances for ' + moduleName + ': ' + instances.join(', '));
            for (const instName of instances) {
                const updateFn = window['cdtInstanceUpdate_' + instName];
                if (updateFn && typeof updateFn === 'function') {
                    try {
                        await updateFn();
                        await new Promise(r => setTimeout(r, 50)); // Small delay between updates
                    } catch (e) {
                        cdtWarn('Failed to update instance ' + instName + ': ' + e.message);
                    }
                } else {
                    cdtWarn('Update function not found for instance: ' + instName);
                }
            }
        } else {
            cdtDebugLog('[CDT] No instances registered for module: ' + moduleName);
        }
        statusbar.statusText = moduleName.toUpperCase() + ' updated';
    };

    // Add menubar product-name-clicked event listener
    gcWidgetQuery('gc-widget-menubar').then(menubar => {
        registerEventListener(menubar, 'product-name-clicked', () => window.open('https://dev.ti.com/gc', 'gc'));
    });

